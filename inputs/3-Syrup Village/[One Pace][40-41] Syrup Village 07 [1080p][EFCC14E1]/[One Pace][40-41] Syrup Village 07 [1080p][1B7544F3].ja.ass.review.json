{"episode": "[One Pace][40-41] Syrup Village 07 [1080p][1B7544F3]", "video": "[One Pace][40-41] Syrup Village 07 [1080p][1B7544F3].mkv", "lines": [{"n": 0, "text": "富 名声 力", "method": "cover", "start": 1.21, "end": 3.212, "vtt": 2.21, "vdur": 2.002, "emitted": true}, {"n": 1, "text": "この世のすべてを手に入れた男\\N海賊王 ゴールド･ロジャー", "method": "cover", "start": 3.31, "end": 7.35, "vtt": 4.337, "vdur": 3.629, "emitted": true}, {"n": 2, "text": "彼の死に際に放ったひと言は\\N人々を海へ駆り立てた", "method": "cover", "start": 7.61, "end": 11.28, "vtt": 8.508, "vdur": 3.754, "emitted": true}, {"n": 3, "text": "俺の財宝か？\\N欲しけりゃくれてやる", "method": "cover", "start": 11.31, "end": 15.17, "vtt": 12.47, "vdur": 3.546, "emitted": true}, {"n": 4, "text": "探せ！ この世のすべてを\\Nそこに置いてきた", "method": "cover", "start": 15.35, "end": 18.91, "vtt": 16.182, "vdur": 3.504, "emitted": true}, {"n": 5, "text": "男たちは\\Nグランドラインを目指し", "method": "cover", "start": 21.41, "end": 23.94, "vtt": 22.23, "vdur": 2.586, "emitted": true}, {"n": 6, "text": "夢を追い続ける", "method": "cover", "start": 23.97, "end": 25.93, "vtt": 24.941, "vdur": 1.96, "emitted": true}, {"n": 7, "text": "世は まさに大海賊時代！", "method": "cover", "start": 26.09, "end": 29.25, "vtt": 27.068, "vdur": 2.711, "emitted": true}, {"n": 8, "text": "クソ", "method": null, "start": null, "end": null, "vtt": 113.613, "vdur": 0.876, "emitted": false}, {"n": 9, "text": "何だ？", "method": null, "start": null, "end": null, "vtt": 114.614, "vdur": 0.584, "emitted": false}, {"n": 10, "text": "うわっ", "method": null, "start": null, "end": null, "vtt": 116.032, "vdur": 1.043, "emitted": false}, {"n": 11, "text": "ああっ", "method": null, "start": null, "end": null, "vtt": 117.2, "vdur": 0.918, "emitted": false}, {"n": 12, "text": "うわあ", "method": null, "start": null, "end": null, "vtt": 119.202, "vdur": 1.001, "emitted": false}, {"n": 13, "text": "お前は仲間を何だと思ってるんだ", "method": null, "start": null, "end": null, "vtt": 121.788, "vdur": 2.961, "emitted": false}, {"n": 14, "text": "いた", "method": null, "start": null, "end": null, "vtt": 126.376, "vdur": 0.667, "emitted": false}, {"n": 15, "text": "「怒り爆発！\\Nクロ 対 ルフィ 決着の行方！」", "method": null, "start": null, "end": null, "vtt": 135.552, "vdur": 4.546, "emitted": false}, {"n": 16, "text": "疲れたのか？", "method": null, "start": null, "end": null, "vtt": 151.234, "vdur": 1.043, "emitted": false}, {"n": 17, "text": "杓死って\\Nムダな動きが多いからな", "method": null, "start": null, "end": null, "vtt": 153.111, "vdur": 3.712, "emitted": false}, {"n": 18, "text": "いい気になるな", "method": null, "start": null, "end": null, "vtt": 157.031, "vdur": 2.253, "emitted": false}, {"n": 19, "text": "今までのはお遊びだ", "method": null, "start": null, "end": null, "vtt": 160.91, "vdur": 2.169, "emitted": false}, {"n": 20, "text": "ふーん", "method": null, "start": null, "end": null, "vtt": 164.122, "vdur": 0.709, "emitted": false}, {"n": 21, "text": "お前だけは特別だ", "method": null, "start": null, "end": null, "vtt": 164.956, "vdur": 1.71, "emitted": false}, {"n": 22, "text": "とことん恐怖を味わわせ―", "method": null, "start": null, "end": null, "vtt": 168.209, "vdur": 2.503, "emitted": false}, {"n": 23, "text": "それからゆっくり\\N料理してやる", "method": null, "start": null, "end": null, "vtt": 170.837, "vdur": 2.961, "emitted": false}, {"n": 24, "text": "杓死！", "method": null, "start": null, "end": null, "vtt": 176.426, "vdur": 1.168, "emitted": false}, {"n": 25, "text": "ううっ", "method": null, "start": null, "end": null, "vtt": 190.44, "vdur": 1.293, "emitted": false}, {"n": 26, "text": "やってみろ 足技", "method": null, "start": null, "end": null, "vtt": 199.365, "vdur": 1.71, "emitted": false}, {"n": 27, "text": "クソ… 離れろ 貴様", "method": null, "start": null, "end": null, "vtt": 201.326, "vdur": 2.002, "emitted": false}, {"n": 28, "text": "これで お前の３年間の計画も\\N完全に失敗だ", "method": null, "start": null, "end": null, "vtt": 203.745, "vdur": 4.129, "emitted": false}, {"n": 29, "text": "何だと？", "method": null, "start": null, "end": null, "vtt": 207.999, "vdur": 1.501, "emitted": false}, {"n": 30, "text": "あいつ\\Nキャプテン･クロをとらえた", "method": null, "start": null, "end": null, "vtt": 209.626, "vdur": 2.877, "emitted": false}, {"n": 31, "text": "もしかして―", "method": null, "start": null, "end": null, "vtt": 213.129, "vdur": 1.043, "emitted": false}, {"n": 32, "text": "あいつが勝てば 俺たち\\N殺されずに済むんじゃねえのか？", "method": null, "start": null, "end": null, "vtt": 214.297, "vdur": 3.67, "emitted": false}, {"n": 33, "text": "死んでもらう", "method": null, "start": null, "end": null, "vtt": 220.47, "vdur": 1.793, "emitted": false}, {"n": 34, "text": "そうはさせるか", "method": null, "start": null, "end": null, "vtt": 222.597, "vdur": 2.044, "emitted": false}, {"n": 35, "text": "ワアーッ", "method": null, "start": null, "end": null, "vtt": 224.766, "vdur": 0.917, "emitted": false}, {"n": 36, "text": "うおっ", "method": null, "start": null, "end": null, "vtt": 225.892, "vdur": 1.752, "emitted": false}, {"n": 37, "text": "このガキどもが", "method": null, "start": null, "end": null, "vtt": 230.688, "vdur": 1.71, "emitted": false}, {"n": 38, "text": "わあーっ", "method": null, "start": null, "end": null, "vtt": 232.523, "vdur": 1.335, "emitted": false}, {"n": 39, "text": "ハッ 一足遅かったな\\N腹巻き！", "method": null, "start": null, "end": null, "vtt": 235.36, "vdur": 2.586, "emitted": false}, {"n": 40, "text": "そうでもないぜ", "method": null, "start": null, "end": null, "vtt": 238.238, "vdur": 1.251, "emitted": false}, {"n": 41, "text": "そう その枝が\\N邪魔だったんだ", "method": null, "start": null, "end": null, "vtt": 243.284, "vdur": 2.878, "emitted": false}, {"n": 42, "text": "何っ", "method": "cover", "start": 48.67, "end": 49.629, "vtt": 247.58, "vdur": 0.959, "emitted": true}, {"n": 43, "text": "ウソップさん…", "method": null, "start": null, "end": null, "vtt": 248.665, "vdur": 0.75, "emitted": false}, {"n": 44, "text": "フッ", "method": null, "start": null, "end": null, "vtt": 249.54, "vdur": 0.751, "emitted": false}, {"n": 45, "text": "やっちまえ ゴム人間！", "method": null, "start": null, "end": null, "vtt": 251.96, "vdur": 2.002, "emitted": false}, {"n": 46, "text": "キャプテン･クロを\\Nぶっ潰してくれ", "method": null, "start": null, "end": null, "vtt": 254.087, "vdur": 1.751, "emitted": false}, {"n": 47, "text": "離れろ", "method": null, "start": null, "end": null, "vtt": 256.756, "vdur": 0.792, "emitted": false}, {"n": 48, "text": "ふんっ", "method": null, "start": null, "end": null, "vtt": 257.674, "vdur": 1.084, "emitted": false}, {"n": 49, "text": "お前らに\\N応援される筋合いはねえ", "method": null, "start": null, "end": null, "vtt": 258.925, "vdur": 4.629, "emitted": false}, {"n": 50, "text": "食らえ 催眠術師！", "method": null, "start": null, "end": null, "vtt": 263.93, "vdur": 1.835, "emitted": false}, {"n": 51, "text": "ウソップさん…", "method": null, "start": null, "end": null, "vtt": 267.058, "vdur": 1.084, "emitted": false}, {"n": 52, "text": "ああっ キャプテン！", "method": null, "start": null, "end": null, "vtt": 268.268, "vdur": 1.668, "emitted": false}, {"n": 53, "text": "離せ", "method": null, "start": null, "end": null, "vtt": 270.77, "vdur": 1.668, "emitted": false}, {"n": 54, "text": "ゴムゴムの…", "method": null, "start": null, "end": null, "vtt": 272.563, "vdur": 2.545, "emitted": false}, {"n": 55, "text": "必殺 火薬星！", "method": null, "start": null, "end": null, "vtt": 275.9, "vdur": 2.086, "emitted": false}, {"n": 56, "text": "俺の 俺の計画は\\N鐘！", "method": null, "start": null, "end": null, "vtt": 281.406, "vdur": 3.545, "emitted": false}, {"n": 57, "text": "絶対に狂わない", "method": null, "start": null, "end": null, "vtt": 285.535, "vdur": 3.754, "emitted": false}, {"n": 58, "text": "あっ", "method": null, "start": null, "end": null, "vtt": 289.664, "vdur": 0.626, "emitted": false}, {"n": 59, "text": "ああ…", "method": null, "start": null, "end": null, "vtt": 294.335, "vdur": 2.67, "emitted": false}, {"n": 60, "text": "とっと", "method": null, "start": null, "end": null, "vtt": 310.643, "vdur": 1.335, "emitted": false}, {"n": 61, "text": "倒しちまった", "method": "interp1", "start": 132.784, "end": 133.868, "vtt": 329.037, "vdur": 1.084, "emitted": true}, {"n": 62, "text": "や… やりやがった\\Nキャプテン･クロを", "method": "cover", "start": 134.41, "end": 136.82, "vtt": 330.663, "vdur": 2.753, "emitted": true}, {"n": 63, "text": "海軍でもかなわなかった\\Nあの“百計のクロ”を―", "method": "cover", "start": 136.85, "end": 140.69, "vtt": 333.541, "vdur": 3.504, "emitted": true}, {"n": 64, "text": "ホントに潰しやがった", "method": "cover", "start": 140.83, "end": 142.18, "vtt": 337.17, "vdur": 1.543, "emitted": true}, {"n": 65, "text": "てめえは 一体 何なんだ？", "method": "cover", "start": 142.21, "end": 144.462, "vtt": 338.838, "vdur": 2.252, "emitted": true}, {"n": 66, "text": "モンキー･Ｄ･ルフィ", "method": "cover", "start": 144.89, "end": 146.93, "vtt": 344.343, "vdur": 1.919, "emitted": true}, {"n": 67, "text": "名前を捨てて\\N海から逃げるような海賊に―", "method": "cover", "start": 147.15, "end": 150.48, "vtt": 347.805, "vdur": 3.17, "emitted": true}, {"n": 68, "text": "俺が負けるわけねえだろ", "method": "cover", "start": 150.51, "end": 152.721, "vtt": 351.1, "vdur": 2.211, "emitted": true}, {"n": 69, "text": "海賊が名前を捨てる時は\\N死ぬ時だけで十分だ", "method": "cover", "start": 152.77, "end": 157.03, "vtt": 353.436, "vdur": 3.837, "emitted": true}, {"n": 70, "text": "ルフィ…\\Nやっぱり聞かねえ名だ", "method": "cover", "start": 157.33, "end": 160.5, "vtt": 357.899, "vdur": 3.17, "emitted": true}, {"n": 71, "text": "俺の名前を 一生覚えてろ", "method": "cover", "start": 160.81, "end": 163.77, "vtt": 361.444, "vdur": 2.794, "emitted": true}, {"n": 72, "text": "俺は 海賊王になる男だ", "method": "cover", "start": 164.39, "end": 167.059, "vtt": 364.906, "vdur": 2.669, "emitted": true}, {"n": 73, "text": "こいつ…", "method": "cover", "start": 169.01, "end": 170.178, "vtt": 369.702, "vdur": 1.168, "emitted": true}, {"n": 74, "text": "うっ… 持って帰れ！", "method": "cover+snap", "start": 170.799, "end": 174.886, "vtt": 371.496, "vdur": 4.087, "emitted": true}, {"n": 75, "text": "二度と来るな", "method": "cover", "start": 176.87, "end": 178.747, "vtt": 377.585, "vdur": 1.877, "emitted": true}, {"n": 76, "text": "あっ", "method": null, "start": null, "end": null, "vtt": 390.807, "vdur": 0.625, "emitted": false}, {"n": 77, "text": "あっ あ…", "method": null, "start": null, "end": null, "vtt": 391.557, "vdur": 1.585, "emitted": false}, {"n": 78, "text": "お疲れさま", "method": "cover", "start": 189.73, "end": 191.31, "vtt": 394.435, "vdur": 1.377, "emitted": true}, {"n": 79, "text": "さすがのあんたも\\Nそれだけやられたら倒れるのね", "method": "cover", "start": 194.97, "end": 198.97, "vtt": 400.191, "vdur": 3.754, "emitted": true}, {"n": 80, "text": "ねえ", "method": "cover", "start": 199.43, "end": 200.557, "vtt": 404.403, "vdur": 1.127, "emitted": true}, {"n": 81, "text": "さっき 何 怒ってたの？", "method": "cover", "start": 201.71, "end": 203.84, "vtt": 406.823, "vdur": 2.419, "emitted": true}, {"n": 82, "text": "俺 あいつら嫌いだ", "method": "cover", "start": 203.87, "end": 205.7, "vtt": 410.368, "vdur": 2.169, "emitted": true}, {"n": 83, "text": "あいつら 間違ってる", "method": "cover", "start": 205.73, "end": 207.97, "vtt": 412.87, "vdur": 1.669, "emitted": true}, {"n": 84, "text": "仲間ってのは\\Nあんなもんじゃねえ", "method": "cover", "start": 209.31, "end": 212.396, "vtt": 416.207, "vdur": 3.086, "emitted": true}, {"n": 85, "text": "何 言ってんの\\N当たり前じゃない", "method": "cover", "start": 212.45, "end": 215.6, "vtt": 420.962, "vdur": 3.295, "emitted": true}, {"n": 86, "text": "海賊なんて あんたが\\N考えてるような―", "method": "cover", "start": 215.63, "end": 218.36, "vtt": 424.382, "vdur": 2.335, "emitted": true}, {"n": 87, "text": "きれいなもんじゃないわ", "method": "cover", "start": 218.39, "end": 219.891, "vtt": 426.843, "vdur": 1.501, "emitted": true}, {"n": 88, "text": "キャプテン･クロのほうが\\Nスタンダードなんじゃない？", "method": null, "start": null, "end": null, "vtt": 428.594, "vdur": 2.837, "emitted": false}, {"n": 89, "text": "肉が食いてえ", "method": "cover", "start": 220.15, "end": 221.443, "vtt": 433.474, "vdur": 1.293, "emitted": true}, {"n": 90, "text": "こいつは！", "method": "cover", "start": 221.503, "end": 223.672, "vtt": 434.976, "vdur": 2.169, "emitted": true}, {"n": 91, "text": "今 ここで起こったことを\\N全部 秘密にできるか？", "method": "cover", "start": 231.25, "end": 234.89, "vtt": 444.569, "vdur": 3.587, "emitted": true}, {"n": 92, "text": "えっ 秘密に？", "method": "cover", "start": 235.47, "end": 236.74, "vtt": 448.573, "vdur": 1.585, "emitted": true}, {"n": 93, "text": "どうしてそんなこと\\Nするんですか", "method": "cover", "start": 236.77, "end": 238.74, "vtt": 450.283, "vdur": 1.751, "emitted": true}, {"n": 94, "text": "そうっすよ 俺たち\\N村のために戦ったのに", "method": "cover", "start": 238.77, "end": 242.56, "vtt": 452.16, "vdur": 3.837, "emitted": true}, {"n": 95, "text": "キャプテンだって\\Nみんなから見直されますよ", "method": "cover", "start": 242.59, "end": 245.54, "vtt": 456.122, "vdur": 2.961, "emitted": true}, {"n": 96, "text": "村の英雄になれるのに", "method": "cover", "start": 245.57, "end": 247.81, "vtt": 459.208, "vdur": 2.169, "emitted": true}, {"n": 97, "text": "そうだ　そうだ", "method": "interp", "start": 247.946, "end": 249.039, "vtt": 461.502, "vdur": 1.001, "emitted": true}, {"n": 98, "text": "ウソップさん\\Nみんなの誤解を解かなきゃ", "method": "cover", "start": 249.95, "end": 253.53, "vtt": 463.337, "vdur": 3.17, "emitted": true}, {"n": 99, "text": "誤解も何も\\N俺はいつもどおり―", "method": "cover", "start": 254.47, "end": 257.04, "vtt": 467.675, "vdur": 2.461, "emitted": true}, {"n": 100, "text": "“ほら吹き小僧”と\\N言われるだけさ", "method": "cover", "start": 257.07, "end": 259.239, "vtt": 470.261, "vdur": 2.169, "emitted": true}, {"n": 101, "text": "もう終わったことを\\Nわざわざみんなに話して―", "method": "cover", "start": 260.29, "end": 262.64, "vtt": 473.639, "vdur": 2.461, "emitted": true}, {"n": 102, "text": "恐怖を与えることはねえ", "method": "cover", "start": 262.67, "end": 264.714, "vtt": 476.225, "vdur": 2.044, "emitted": true}, {"n": 103, "text": "フッ 今回みてえなことでも\\Nない限り―", "method": "cover", "start": 266.91, "end": 269.44, "vtt": 479.479, "vdur": 3.086, "emitted": true}, {"n": 104, "text": "こんな辺ぴな村を\\N襲おうなんて海賊は―", "method": "cover", "start": 269.47, "end": 272.22, "vtt": 482.69, "vdur": 3.003, "emitted": true}, {"n": 105, "text": "今後 現れねえだろ", "method": "cover", "start": 272.25, "end": 274.07, "vtt": 485.818, "vdur": 1.543, "emitted": true}, {"n": 106, "text": "このまま\\N何もなかったことにする", "method": "cover", "start": 275.17, "end": 278.35, "vtt": 488.571, "vdur": 3.003, "emitted": true}, {"n": 107, "text": "何も…\\Nみんなウソだったんだ", "method": "cover", "start": 278.65, "end": 282.112, "vtt": 492.158, "vdur": 3.462, "emitted": true}, {"n": 108, "text": "強制はしねえが…", "method": "cover", "start": 286.15, "end": 287.72, "vtt": 500.208, "vdur": 1.251, "emitted": true}, {"n": 109, "text": "いえ できます\\Nそれが一番 村のためになるなら", "method": "cover", "start": 287.75, "end": 291.588, "vtt": 501.792, "vdur": 3.838, "emitted": true}, {"n": 110, "text": "俺だって", "method": "cover", "start": 291.71, "end": 292.94, "vtt": 505.755, "vdur": 1.251, "emitted": true}, {"n": 111, "text": "僕も 一生 黙ってる", "method": "cover", "start": 292.97, "end": 295.74, "vtt": 507.131, "vdur": 2.002, "emitted": true}, {"n": 112, "text": "カヤ　お前はつらいか？", "method": "cover", "start": 296.25, "end": 300.22, "vtt": 510.551, "vdur": 3.754, "emitted": true}, {"n": 113, "text": "いいえ", "method": null, "start": null, "end": null, "vtt": 518.601, "vdur": 1.46, "emitted": false}, {"n": 114, "text": "今朝はどうしたのかしら\\Nウソップ君", "method": "cover", "start": 309.05, "end": 312.49, "vtt": 523.147, "vdur": 3.379, "emitted": true}, {"n": 115, "text": "何か調子狂うなあ\\Nやる気が出ないや", "method": "cover", "start": 313.35, "end": 317.09, "vtt": 527.36, "vdur": 3.67, "emitted": true}, {"n": 116, "text": "ママ！", "method": "cover", "start": 317.12, "end": 318.8, "vtt": 531.781, "vdur": 1.752, "emitted": true}, {"n": 117, "text": "今日は ウソのお兄ちゃん\\N来ないの？", "method": "cover", "start": 318.83, "end": 322.72, "vtt": 533.991, "vdur": 2.836, "emitted": true}, {"n": 118, "text": "ほら吹き坊主め\\N今日は まだか！", "method": "cover", "start": 323.25, "end": 327.213, "vtt": 537.411, "vdur": 3.963, "emitted": true}, {"n": 119, "text": "昨日 少し\\N強く言いすぎたかな", "method": "cover", "start": 328.01, "end": 330.93, "vtt": 542.333, "vdur": 2.92, "emitted": true}, {"n": 120, "text": "明日になりゃ\\Nまた懲りずに来るわよ", "method": "cover", "start": 331.39, "end": 334.79, "vtt": 545.586, "vdur": 3.087, "emitted": true}, {"n": 121, "text": "きっと…", "method": "cover", "start": 334.99, "end": 336.534, "vtt": 549.131, "vdur": 1.544, "emitted": true}, {"n": 122, "text": "ヘヘッ ありがとう", "method": "cover", "start": 339.527, "end": 341.863, "vtt": 554.637, "vdur": 2.336, "emitted": true}, {"n": 123, "text": "お前たちがいなかったら\\N村は守りきれなかった", "method": "cover", "start": 342.29, "end": 345.501, "vtt": 557.098, "vdur": 3.211, "emitted": true}, {"n": 124, "text": "何 言ってやがんだ", "method": "cover", "start": 346.41, "end": 348.079, "vtt": 561.143, "vdur": 1.669, "emitted": true}, {"n": 125, "text": "お前が何もしなきゃ\\N俺は動かなかったぜ", "method": "cover", "start": 348.17, "end": 351.44, "vtt": 562.937, "vdur": 3.211, "emitted": true}, {"n": 126, "text": "俺も", "method": "cover", "start": 352.21, "end": 353.419, "vtt": 566.816, "vdur": 1.209, "emitted": true}, {"n": 127, "text": "どうでもいいじゃない\\Nそんなこと", "method": "cover", "start": 353.67, "end": 356.506, "vtt": 568.359, "vdur": 2.836, "emitted": true}, {"n": 128, "text": "宝が手に入ったんだし", "method": "cover", "start": 356.81, "end": 358.937, "vtt": 571.32, "vdur": 2.127, "emitted": true}, {"n": 129, "text": "アッハハハハハッ…", "method": null, "start": null, "end": null, "vtt": 573.823, "vdur": 2.919, "emitted": false}, {"n": 130, "text": "俺は この機会に１つ\\N腹に決めたことがある", "method": "cover", "start": 363.53, "end": 368.01, "vtt": 582.498, "vdur": 4.254, "emitted": true}, {"n": 131, "text": "キャプテン･ウソップ\\N何ですか？ 話って", "method": "cover", "start": 374.35, "end": 377.979, "vtt": 608.399, "vdur": 3.629, "emitted": true}, {"n": 132, "text": "お前ら よく戦ったなあ\\Nあのクロネコ海賊団を相手にだ", "method": "cover", "start": 378.33, "end": 383.585, "vtt": 613.446, "vdur": 5.255, "emitted": true}, {"n": 133, "text": "俺は キャプテンとして\\N非常に鼻が高い", "method": "cover", "start": 383.95, "end": 387.89, "vtt": 618.951, "vdur": 3.545, "emitted": true}, {"n": 134, "text": "そんな…", "method": null, "start": null, "end": null, "vtt": 622.83, "vdur": 1.71, "emitted": false}, {"n": 135, "text": "キャプテンに比べれば", "method": null, "start": null, "end": null, "vtt": 624.665, "vdur": 1.752, "emitted": false}, {"n": 136, "text": "てれちゃうよね", "method": null, "start": null, "end": null, "vtt": 626.542, "vdur": 1.418, "emitted": false}, {"n": 137, "text": "いや 本当によくやったよ", "method": null, "start": null, "end": null, "vtt": 628.21, "vdur": 2.586, "emitted": false}, {"n": 138, "text": "死ぬほど怖い思いもしたが―", "method": null, "start": null, "end": null, "vtt": 630.921, "vdur": 1.919, "emitted": false}, {"n": 139, "text": "ちゃんとカヤを\\N守り通してくれた", "method": null, "start": null, "end": null, "vtt": 632.965, "vdur": 2.753, "emitted": false}, {"n": 140, "text": "５年前 お前らが\\Nまだ４歳だった頃に結成した―", "method": "cover", "start": 388.63, "end": 392.16, "vtt": 636.427, "vdur": 3.712, "emitted": true}, {"n": 141, "text": "このウソップ海賊団", "method": "cover", "start": 392.19, "end": 393.88, "vtt": 640.264, "vdur": 1.46, "emitted": true}, {"n": 142, "text": "最大にして最高の戦いを\\N乗り切ったんだ", "method": "cover", "start": 393.91, "end": 397.27, "vtt": 641.849, "vdur": 2.92, "emitted": true}, {"n": 143, "text": "はい！", "method": null, "start": null, "end": null, "vtt": 644.894, "vdur": 0.792, "emitted": false}, {"n": 144, "text": "そこで 唐突だが―", "method": "cover", "start": 397.93, "end": 399.807, "vtt": 645.811, "vdur": 1.877, "emitted": true}, {"n": 145, "text": "俺は １人で海へ出ようと思う", "method": "cover", "start": 400.65, "end": 403.69, "vtt": 648.439, "vdur": 2.628, "emitted": true}, {"n": 146, "text": "俺は 本物の海賊になるんだ\\Nヒヒヒヒヒヒッ…", "method": null, "start": null, "end": null, "vtt": 655.988, "vdur": 4.38, "emitted": false}, {"n": 147, "text": "ずっと迷ってたんだ", "method": "cover", "start": 414.11, "end": 415.87, "vtt": 664.08, "vdur": 1.751, "emitted": true}, {"n": 148, "text": "俺は このまま\\Nここにいていいのかって", "method": "cover", "start": 416.03, "end": 418.04, "vtt": 665.956, "vdur": 2.336, "emitted": true}, {"n": 149, "text": "だが あいつらを見てたら\\Nやっと決心がついた", "method": "cover", "start": 418.07, "end": 421.897, "vtt": 668.417, "vdur": 3.587, "emitted": true}, {"n": 150, "text": "やっぱり 男と\\N生まれたからには―", "method": "cover", "start": 422.23, "end": 424.06, "vtt": 672.129, "vdur": 1.919, "emitted": true}, {"n": 151, "text": "あの大海原に\\N出なきゃダメなんだ", "method": "cover", "start": 424.09, "end": 426.46, "vtt": 674.173, "vdur": 2.252, "emitted": true}, {"n": 152, "text": "だから 俺はこの村を出る", "method": "cover", "start": 426.79, "end": 429.835, "vtt": 676.55, "vdur": 3.045, "emitted": true}, {"n": 153, "text": "理由は ただ１つ", "method": "cover", "start": 432.43, "end": 434.64, "vtt": 682.348, "vdur": 2.21, "emitted": true}, {"n": 154, "text": "海賊旗が\\N俺を呼んでいるからだ", "method": "cover", "start": 434.87, "end": 439.584, "vtt": 684.683, "vdur": 4.714, "emitted": true}, {"n": 155, "text": "キャプテン ウソでしょ", "method": "cover", "start": 441.71, "end": 443.803, "vtt": 691.69, "vdur": 2.002, "emitted": true}, {"n": 156, "text": "それもウソなんでしょ？", "method": "cover", "start": 445.77, "end": 447.73, "vtt": 695.528, "vdur": 1.96, "emitted": true}, {"n": 157, "text": "そんなの急すぎるし", "method": "cover", "start": 448.07, "end": 449.54, "vtt": 697.613, "vdur": 1.794, "emitted": true}, {"n": 158, "text": "キャプテン この村\\N大好きじゃないですか", "method": "cover", "start": 449.57, "end": 452.239, "vtt": 699.532, "vdur": 2.669, "emitted": true}, {"n": 159, "text": "ウソップ海賊団は\\Nどうなるんですか？", "method": "cover", "start": 452.43, "end": 455.975, "vtt": 702.326, "vdur": 3.545, "emitted": true}, {"n": 160, "text": "世話になったな お前ら", "method": "cover", "start": 457.61, "end": 460.195, "vtt": 707.415, "vdur": 2.585, "emitted": true}, {"n": 161, "text": "村のみんなには\\N黙って行くつもりだ", "method": "cover", "start": 460.75, "end": 463.753, "vtt": 710.501, "vdur": 3.003, "emitted": true}, {"n": 162, "text": "よろしく言っといてくれ", "method": "cover", "start": 463.89, "end": 465.6, "vtt": 713.629, "vdur": 1.71, "emitted": true}, {"n": 163, "text": "イヤだよ", "method": "cover", "start": 465.75, "end": 466.918, "vtt": 715.464, "vdur": 1.168, "emitted": true}, {"n": 164, "text": "そんなのイヤだよ", "method": "cover", "start": 466.95, "end": 468.67, "vtt": 716.882, "vdur": 1.669, "emitted": true}, {"n": 165, "text": "行くな キャプテン！", "method": "cover", "start": 468.85, "end": 470.79, "vtt": 718.676, "vdur": 1.793, "emitted": true}, {"n": 166, "text": "この場所を覚えてるか？", "method": "cover", "start": 472.63, "end": 475.508, "vtt": 722.555, "vdur": 2.878, "emitted": true}, {"n": 167, "text": "俺たちが\\N初めて会った場所だ", "method": "cover", "start": 477.03, "end": 481.075, "vtt": 726.684, "vdur": 4.045, "emitted": true}, {"n": 168, "text": "ヘヘヘヘッ できた", "method": "rescue+snap", "start": 487.077, "end": 488.87, "vtt": 736.861, "vdur": 1.793, "emitted": true}, {"n": 169, "text": "ウソのお兄ちゃん", "method": "cover", "start": 488.97, "end": 490.067, "vtt": 738.779, "vdur": 1.669, "emitted": true}, {"n": 170, "text": "ん？ お前ら誰だよ\\Nなれなれしいぞ", "method": "cover", "start": 490.097, "end": 494.0, "vtt": 740.573, "vdur": 3.42, "emitted": true}, {"n": 171, "text": "だって有名じゃん", "method": "cover", "start": 494.03, "end": 496.17, "vtt": 744.118, "vdur": 1.668, "emitted": true}, {"n": 172, "text": "うん 有名人だよ", "method": "cover", "start": 496.35, "end": 498.269, "vtt": 745.911, "vdur": 1.919, "emitted": true}, {"n": 173, "text": "そっか", "method": "cover", "start": 498.89, "end": 499.7, "vtt": 748.789, "vdur": 0.959, "emitted": true}, {"n": 174, "text": "キャプテン･ウソップと\\N尊敬を込めて―", "method": "cover", "start": 499.73, "end": 502.2, "vtt": 749.874, "vdur": 1.96, "emitted": true}, {"n": 175, "text": "呼ばれるようになってきたか", "method": "cover", "start": 502.23, "end": 504.315, "vtt": 751.959, "vdur": 2.085, "emitted": true}, {"n": 176, "text": "みんな“ウソつきウソップ”\\Nって呼んでるよね", "method": "cover", "start": 505.09, "end": 507.67, "vtt": 754.837, "vdur": 2.419, "emitted": true}, {"n": 177, "text": "よし 今日からお前らも\\Nウソップ海賊団だ", "method": "cover", "start": 510.37, "end": 513.748, "vtt": 759.675, "vdur": 3.378, "emitted": true}, {"n": 178, "text": "えーっ", "method": null, "start": null, "end": null, "vtt": 763.554, "vdur": 0.918, "emitted": false}, {"n": 179, "text": "“えーっ”じゃない", "method": "cover", "start": 514.066, "end": 515.818, "vtt": 764.722, "vdur": 1.752, "emitted": true}, {"n": 180, "text": "いろいろあったな", "method": "cover", "start": 518.69, "end": 520.734, "vtt": 768.642, "vdur": 2.044, "emitted": true}, {"n": 181, "text": "ケルベロスだ　追い払え！", "method": "cover", "start": 521.834, "end": 524.336, "vtt": 771.187, "vdur": 2.502, "emitted": true}, {"n": 182, "text": "待てーっ", "method": null, "start": null, "end": null, "vtt": 773.814, "vdur": 1.502, "emitted": false}, {"n": 183, "text": "ドラゴンだ　捕獲しろ", "method": "cover", "start": 526.43, "end": 529.1, "vtt": 775.649, "vdur": 2.67, "emitted": true}, {"n": 184, "text": "小麦粉星！", "method": "cover", "start": 529.61, "end": 531.32, "vtt": 779.528, "vdur": 1.71, "emitted": true}, {"n": 185, "text": "すっげえ キャプテン", "method": "cover", "start": 531.71, "end": 533.56, "vtt": 781.614, "vdur": 1.793, "emitted": true}, {"n": 186, "text": "当ったり前よ", "method": "cover", "start": 533.73, "end": 534.78, "vtt": 783.782, "vdur": 1.585, "emitted": true}, {"n": 187, "text": "俺は 勇敢なる\\N海の戦士だからな", "method": "cover", "start": 534.81, "end": 538.57, "vtt": 785.493, "vdur": 2.669, "emitted": true}, {"n": 188, "text": "そんな思い出話\\N聞きたくないよ", "method": "cover", "start": 539.37, "end": 542.22, "vtt": 789.246, "vdur": 2.544, "emitted": true}, {"n": 189, "text": "そうだ\\N聞きたくなんかない", "method": "cover", "start": 542.25, "end": 544.36, "vtt": 792.374, "vdur": 2.002, "emitted": true}, {"n": 190, "text": "何だよ\\Nキャプテンらしくない", "method": "cover", "start": 544.39, "end": 546.54, "vtt": 794.502, "vdur": 2.043, "emitted": true}, {"n": 191, "text": "なんでそんな話を\\N今するんだよ", "method": "cover", "start": 546.57, "end": 549.87, "vtt": 796.67, "vdur": 2.92, "emitted": true}, {"n": 192, "text": "それじゃあ まるで…", "method": "cover", "start": 550.23, "end": 552.649, "vtt": 800.132, "vdur": 2.419, "emitted": true}, {"n": 193, "text": "キャプテンのバカ バカ…", "method": "cover", "start": 553.03, "end": 556.992, "vtt": 803.177, "vdur": 3.962, "emitted": true}, {"n": 194, "text": "お前らの野望は何だ？", "method": "cover", "start": 565.17, "end": 567.29, "vtt": 815.272, "vdur": 1.585, "emitted": true}, {"n": 195, "text": "酒場を経営することです", "method": "cover", "start": 567.33, "end": 570.12, "vtt": 817.358, "vdur": 2.711, "emitted": true}, {"n": 196, "text": "大工の棟りょうに\\Nなることです", "method": "cover", "start": 570.15, "end": 572.86, "vtt": 820.194, "vdur": 2.544, "emitted": true}, {"n": 197, "text": "小説家になることです", "method": "cover", "start": 572.89, "end": 575.45, "vtt": 822.863, "vdur": 2.044, "emitted": true}, {"n": 198, "text": "それぞれの野望の火を\\N絶やすことなく―", "method": "cover", "start": 576.39, "end": 579.56, "vtt": 826.033, "vdur": 3.17, "emitted": true}, {"n": 199, "text": "己の道を突き進むことを\\Nここに誓う！", "method": "cover", "start": 580.09, "end": 584.969, "vtt": 829.954, "vdur": 4.879, "emitted": true}, {"n": 200, "text": "今日限りをもって―", "method": "cover", "start": 586.07, "end": 587.83, "vtt": 836.043, "vdur": 1.46, "emitted": true}, {"n": 201, "text": "ウソップ海賊団を…", "method": "interp", "start": 589.001, "end": 592.588, "vtt": 838.712, "vdur": 3.587, "emitted": true}, {"n": 202, "text": "解散する！", "method": "cover", "start": 597.73, "end": 600.316, "vtt": 847.721, "vdur": 2.586, "emitted": true}, {"n": 203, "text": "メシは食った\\Nそろそろ行くか", "method": "cover", "start": 607.11, "end": 609.77, "vtt": 859.733, "vdur": 2.545, "emitted": true}, {"n": 204, "text": "そうだな", "method": "cover", "start": 609.95, "end": 610.97, "vtt": 862.403, "vdur": 0.917, "emitted": true}, {"n": 205, "text": "ここにいらしたんですね", "method": "cover", "start": 612.51, "end": 613.94, "vtt": 865.114, "vdur": 1.501, "emitted": true}, {"n": 206, "text": "よう お嬢様", "method": "cover", "start": 613.97, "end": 615.54, "vtt": 866.74, "vdur": 1.168, "emitted": true}, {"n": 207, "text": "寝てなくても平気なの？", "method": "cover", "start": 615.57, "end": 617.41, "vtt": 868.033, "vdur": 1.627, "emitted": true}, {"n": 208, "text": "ええ", "method": null, "start": null, "end": null, "vtt": 869.785, "vdur": 1.168, "emitted": false}, {"n": 209, "text": "ここ１年の私の病気は―", "method": "cover", "start": 619.61, "end": 622.09, "vtt": 872.079, "vdur": 2.461, "emitted": true}, {"n": 210, "text": "両親を失った 精神的な\\N気落ちが原因だったので", "method": "cover", "start": 622.17, "end": 626.27, "vtt": 874.665, "vdur": 4.046, "emitted": true}, {"n": 211, "text": "ウソップさんにも ずいぶん\\N励まされましたし―", "method": "cover", "start": 626.65, "end": 629.93, "vtt": 879.128, "vdur": 3.086, "emitted": true}, {"n": 212, "text": "甘えてばかりはいられません", "method": "cover", "start": 630.77, "end": 632.67, "vtt": 883.09, "vdur": 1.794, "emitted": true}, {"n": 213, "text": "フッ", "method": null, "start": null, "end": null, "vtt": 885.885, "vdur": 0.625, "emitted": false}, {"n": 214, "text": "ずいぶんと\\Nお世話になりました", "method": null, "start": null, "end": null, "vtt": 886.635, "vdur": 1.961, "emitted": false}, {"n": 215, "text": "ありがとうございます", "method": "interp1", "start": 632.7, "end": 634.201, "vtt": 888.721, "vdur": 1.501, "emitted": true}, {"n": 216, "text": "皆さんに 私からの\\N心ばかりのプレゼントを―", "method": "cover", "start": 634.91, "end": 638.52, "vtt": 890.931, "vdur": 3.545, "emitted": true}, {"n": 217, "text": "用意させていただきました", "method": "cover", "start": 638.55, "end": 640.05, "vtt": 894.602, "vdur": 1.334, "emitted": true}, {"n": 218, "text": "ぜひ 受け取ってください", "method": "cover", "start": 640.65, "end": 642.86, "vtt": 896.854, "vdur": 2.21, "emitted": true}, {"n": 219, "text": "いよっ", "method": null, "start": null, "end": null, "vtt": 900.399, "vdur": 1.251, "emitted": false}, {"n": 220, "text": "にーっ", "method": null, "start": null, "end": null, "vtt": 902.818, "vdur": 1.168, "emitted": false}, {"n": 221, "text": "ハア… 入った", "method": "interp1", "start": 644.357, "end": 645.984, "vtt": 908.699, "vdur": 1.627, "emitted": true}, {"n": 222, "text": "この家とも お別れだ", "method": "cover", "start": 649.07, "end": 653.03, "vtt": 913.412, "vdur": 2.961, "emitted": true}, {"n": 223, "text": "よし", "method": null, "start": null, "end": null, "vtt": 932.64, "vdur": 0.959, "emitted": false}, {"n": 224, "text": "なーにーっ", "method": null, "start": null, "end": null, "vtt": 935.684, "vdur": 3.671, "emitted": false}, {"n": 225, "text": "なんてこった 出られねえ…", "method": "cover", "start": 664.53, "end": 668.09, "vtt": 942.608, "vdur": 3.045, "emitted": true}, {"n": 226, "text": "チクショー", "method": "cover", "start": 669.83, "end": 671.65, "vtt": 947.446, "vdur": 1.668, "emitted": true}, {"n": 227, "text": "ふんーっ", "method": null, "start": null, "end": null, "vtt": 953.243, "vdur": 1.627, "emitted": false}, {"n": 228, "text": "ウリャーッ", "method": null, "start": null, "end": null, "vtt": 954.995, "vdur": 1.168, "emitted": false}, {"n": 229, "text": "うおーっ\\Nうわっ キャラヴェル", "method": "interp", "start": 690.293, "end": 692.731, "vtt": 967.299, "vdur": 2.378, "emitted": true}, {"n": 230, "text": "これ ホントに\\Nもらっていいのか？", "method": "cover", "start": 694.27, "end": 696.856, "vtt": 971.178, "vdur": 2.586, "emitted": true}, {"n": 231, "text": "ええ ぜひ使ってください", "method": "cover", "start": 697.25, "end": 699.252, "vtt": 973.889, "vdur": 2.002, "emitted": true}, {"n": 232, "text": "少々 古い型ですが\\Nこれは私がデザインしました船で", "method": "cover", "start": 700.89, "end": 705.71, "vtt": 977.977, "vdur": 4.295, "emitted": true}, {"n": 233, "text": "カーヴェル造り\\Nラティーン･スル使用の―", "method": "cover", "start": 705.81, "end": 708.8, "vtt": 982.94, "vdur": 2.836, "emitted": true}, {"n": 234, "text": "船尾中央舵方式 キャラヴェル", "method": "cover", "start": 708.83, "end": 712.243, "vtt": 985.901, "vdur": 3.087, "emitted": true}, {"n": 235, "text": "ゴーイング･メリー号で\\Nございます", "method": "cover", "start": 712.273, "end": 715.35, "vtt": 989.905, "vdur": 2.753, "emitted": true}, {"n": 236, "text": "動索の説明をしますが―", "method": "cover", "start": 716.59, "end": 718.36, "vtt": 993.701, "vdur": 1.876, "emitted": true}, {"n": 237, "text": "まず クルーガーネットによる\\Nヤードの調節に関しましては…", "method": "cover", "start": 718.39, "end": 722.08, "vtt": 995.703, "vdur": 3.003, "emitted": true}, {"n": 238, "text": "ああ ダメダメ\\N船の説明なら私が聞くわ", "method": "cover", "start": 722.11, "end": 725.39, "vtt": 998.831, "vdur": 3.211, "emitted": true}, {"n": 239, "text": "いい船だなあ", "method": "cover", "start": 726.13, "end": 727.72, "vtt": 1002.918, "vdur": 1.919, "emitted": true}, {"n": 240, "text": "特にこの船首\\Nカッコいい", "method": "cover", "start": 727.75, "end": 731.17, "vtt": 1004.962, "vdur": 3.42, "emitted": true}, {"n": 241, "text": "航海に必要そうな物は\\Nすべて積んでおきましたから", "method": "cover", "start": 731.61, "end": 735.38, "vtt": 1008.674, "vdur": 3.712, "emitted": true}, {"n": 242, "text": "ありがとう\\N踏んだり蹴ったりだな", "method": "cover", "start": 735.41, "end": 738.17, "vtt": 1012.511, "vdur": 2.711, "emitted": true}, {"n": 243, "text": "“至れり尽くせり”だ アホ", "method": "cover", "start": 738.33, "end": 740.65, "vtt": 1015.347, "vdur": 2.044, "emitted": true}, {"n": 244, "text": "ウソップさん", "method": "interp1", "start": 746.124, "end": 747.167, "vtt": 1022.521, "vdur": 1.043, "emitted": true}, {"n": 245, "text": "何やってんだ？ あいつ", "method": "cover", "start": 748.71, "end": 749.88, "vtt": 1025.107, "vdur": 2.169, "emitted": true}, {"n": 246, "text": "とりあえず止めとくか", "method": "cover", "start": 749.91, "end": 752.13, "vtt": 1027.401, "vdur": 1.877, "emitted": true}, {"n": 247, "text": "このコースは 船に直撃だ", "method": "cover", "start": 752.41, "end": 754.63, "vtt": 1029.445, "vdur": 1.96, "emitted": true}, {"n": 248, "text": "わ… 悪いな", "method": "cover", "start": 759.01, "end": 760.72, "vtt": 1035.826, "vdur": 1.71, "emitted": true}, {"n": 249, "text": "ああ", "method": null, "start": null, "end": null, "vtt": 1037.661, "vdur": 0.834, "emitted": false}, {"n": 250, "text": "やっぱり海へ出るんですね\\Nウソップさん", "method": "cover", "start": 762.17, "end": 766.45, "vtt": 1039.371, "vdur": 4.088, "emitted": true}, {"n": 251, "text": "ああ 決心が揺れねえうちに\\Nとっとと行くことにするよ", "method": "cover", "start": 767.51, "end": 772.014, "vtt": 1043.876, "vdur": 4.504, "emitted": true}, {"n": 252, "text": "止めるなよ", "method": "cover", "start": 772.21, "end": 773.33, "vtt": 1050.215, "vdur": 1.001, "emitted": true}, {"n": 253, "text": "止めません\\Nそんな気がしてたから", "method": "cover", "start": 773.39, "end": 776.45, "vtt": 1051.341, "vdur": 2.67, "emitted": true}, {"n": 254, "text": "何か それも寂しいな", "method": "cover", "start": 776.67, "end": 779.08, "vtt": 1054.178, "vdur": 2.419, "emitted": true}, {"n": 255, "text": "フッ 今度\\Nこの村に来る時はよ", "method": "cover", "start": 779.11, "end": 781.64, "vtt": 1056.722, "vdur": 2.627, "emitted": true}, {"n": 256, "text": "ウソよりずっとウソみてえな\\N冒険話を聞かせてやるよ", "method": "cover", "start": 781.67, "end": 785.25, "vtt": 1059.475, "vdur": 3.461, "emitted": true}, {"n": 257, "text": "うん 楽しみにしています", "method": "cover+snap", "start": 786.531, "end": 788.825, "vtt": 1064.438, "vdur": 2.294, "emitted": true}, {"n": 258, "text": "お前らも元気でな\\Nまたどこかで会おう", "method": "cover", "start": 789.35, "end": 793.42, "vtt": 1067.316, "vdur": 3.879, "emitted": true}, {"n": 259, "text": "なんで？", "method": "cover", "start": 793.45, "end": 794.02, "vtt": 1071.32, "vdur": 0.792, "emitted": true}, {"n": 260, "text": "え？ “なんで”って…", "method": "cover", "start": 794.05, "end": 796.32, "vtt": 1072.237, "vdur": 2.127, "emitted": true}, {"n": 261, "text": "お前 愛想のねえ野郎だな", "method": "cover", "start": 796.35, "end": 798.46, "vtt": 1074.49, "vdur": 2.294, "emitted": true}, {"n": 262, "text": "これから\\N同じ海賊やるってんだから―", "method": "cover", "start": 798.49, "end": 801.2, "vtt": 1076.909, "vdur": 2.419, "emitted": true}, {"n": 263, "text": "そのうち海で会ったり…", "method": "cover", "start": 801.23, "end": 803.25, "vtt": 1079.453, "vdur": 1.585, "emitted": true}, {"n": 264, "text": "何 言ってんだ\\N早く乗れよ", "method": "cover", "start": 803.41, "end": 806.28, "vtt": 1081.371, "vdur": 2.628, "emitted": true}, {"n": 265, "text": "俺たち もう仲間だろ", "method": "cover", "start": 806.31, "end": 809.53, "vtt": 1085.25, "vdur": 2.127, "emitted": true}, {"n": 266, "text": "キャ… キャプテンは…", "method": "cover", "start": 812.73, "end": 814.28, "vtt": 1096.053, "vdur": 1.918, "emitted": true}, {"n": 267, "text": "キャプテンは俺だろうな？", "method": "cover", "start": 814.31, "end": 816.595, "vtt": 1098.806, "vdur": 2.085, "emitted": true}, {"n": 268, "text": "バカ言え\\N俺がキャプテンだ！", "method": "cover+snap", "start": 816.625, "end": 819.086, "vtt": 1101.016, "vdur": 2.461, "emitted": true}, {"n": 269, "text": "行っちゃったな\\Nキャプテン", "method": "cover", "start": 842.27, "end": 844.04, "vtt": 1125.499, "vdur": 1.793, "emitted": true}, {"n": 270, "text": "ああ　でもさ\\Nあの人たちと一緒だから―", "method": "cover", "start": 844.07, "end": 847.06, "vtt": 1127.417, "vdur": 2.878, "emitted": true}, {"n": 271, "text": "ちょっと安心したよ", "method": "cover", "start": 847.09, "end": 848.63, "vtt": 1130.42, "vdur": 1.127, "emitted": true}, {"n": 272, "text": "そうそう あんな強い人たち\\N見たことないもん", "method": "cover", "start": 848.75, "end": 852.337, "vtt": 1131.672, "vdur": 3.587, "emitted": true}, {"n": 273, "text": "仕方ないか 昔から\\N海賊になりたいって言ってたし", "method": "cover", "start": 852.75, "end": 856.48, "vtt": 1135.884, "vdur": 3.837, "emitted": true}, {"n": 274, "text": "村の人たちに話したら\\N寂しがるだろうけどな", "method": "cover", "start": 856.51, "end": 859.38, "vtt": 1139.847, "vdur": 2.794, "emitted": true}, {"n": 275, "text": "突然の話だしさ", "method": "cover", "start": 859.41, "end": 861.162, "vtt": 1142.766, "vdur": 1.627, "emitted": true}, {"n": 276, "text": "１人でにぎやかだったからね\\Nキャプテンは", "method": "cover+snap", "start": 861.192, "end": 865.029, "vtt": 1144.518, "vdur": 3.837, "emitted": true}, {"n": 277, "text": "俺 １つ考えたんだ", "method": "cover", "start": 867.77, "end": 869.98, "vtt": 1150.983, "vdur": 2.21, "emitted": true}, {"n": 278, "text": "何を？", "method": "cover", "start": 870.19, "end": 871.358, "vtt": 1153.318, "vdur": 1.168, "emitted": true}, {"n": 279, "text": "気持ちのいい人たちでしたね", "method": null, "start": null, "end": null, "vtt": 1155.737, "vdur": 2.837, "emitted": false}, {"n": 280, "text": "メリー…\\N何です？", "method": "cover", "start": 873.25, "end": 875.252, "vtt": 1159.074, "vdur": 2.002, "emitted": true}, {"n": 281, "text": "ウソをつくのってつらいわ", "method": "cover", "start": 876.17, "end": 878.88, "vtt": 1161.827, "vdur": 2.753, "emitted": true}, {"n": 282, "text": "クラハドールのことですか？", "method": "cover", "start": 878.91, "end": 881.204, "vtt": 1164.872, "vdur": 2.294, "emitted": true}, {"n": 283, "text": "ううん", "method": null, "start": null, "end": null, "vtt": 1167.291, "vdur": 0.959, "emitted": false}, {"n": 284, "text": "本当は ウソップ君を\\N引き止めたかったことですか", "method": "cover", "start": 883.33, "end": 888.127, "vtt": 1169.084, "vdur": 4.797, "emitted": true}, {"n": 285, "text": "お嬢様", "method": "cover", "start": 891.01, "end": 892.35, "vtt": 1177.134, "vdur": 1.209, "emitted": true}, {"n": 286, "text": "私 前に村の人から―", "method": "cover", "start": 893.23, "end": 895.0, "vtt": 1178.969, "vdur": 1.877, "emitted": true}, {"n": 287, "text": "彼の子供の頃の話を\\N聞いたことがあります", "method": "cover", "start": 895.03, "end": 898.39, "vtt": 1180.971, "vdur": 3.212, "emitted": true}, {"n": 288, "text": "ウソップ君の父親が\\Nこの村を飛び出して まもなく―", "method": "cover", "start": 899.83, "end": 903.81, "vtt": 1185.726, "vdur": 3.92, "emitted": true}, {"n": 289, "text": "彼は 母親をも\\N亡くしているのです", "method": "cover", "start": 904.05, "end": 906.97, "vtt": 1189.771, "vdur": 2.92, "emitted": true}, {"n": 290, "text": "海賊が来たぞーっ", "method": "cover", "start": 909.75, "end": 913.88, "vtt": 1195.485, "vdur": 4.13, "emitted": true}, {"n": 291, "text": "海賊が来たぞ", "method": "cover", "start": 914.25, "end": 916.377, "vtt": 1200.115, "vdur": 2.127, "emitted": true}, {"n": 292, "text": "父ちゃんの海賊船が来た！\\Nコ… コラ ウソップ", "method": "cover", "start": 916.55, "end": 919.0, "vtt": 1202.451, "vdur": 2.294, "emitted": true}, {"n": 293, "text": "大声 出しちゃいかん", "method": "cover", "start": 919.03, "end": 920.69, "vtt": 1204.87, "vdur": 1.293, "emitted": true}, {"n": 294, "text": "父ちゃんが 俺たちのこと\\N迎えに来たよ", "method": "cover", "start": 921.75, "end": 924.75, "vtt": 1207.581, "vdur": 2.669, "emitted": true}, {"n": 295, "text": "バ… バカなこと\\N言うもんじゃないよ", "method": "cover", "start": 925.99, "end": 929.16, "vtt": 1211.043, "vdur": 3.92, "emitted": true}, {"n": 296, "text": "ウソップ", "method": "cover", "start": 929.19, "end": 930.55, "vtt": 1215.13, "vdur": 1.21, "emitted": true}, {"n": 297, "text": "そんな…", "method": "cover", "start": 930.58, "end": 932.08, "vtt": 1216.506, "vdur": 1.544, "emitted": true}, {"n": 298, "text": "母ちゃんが\\N元気になったら―", "method": "cover", "start": 932.11, "end": 933.86, "vtt": 1218.175, "vdur": 1.46, "emitted": true}, {"n": 299, "text": "航海に連れてってくれるって", "method": "cover", "start": 933.89, "end": 936.01, "vtt": 1219.76, "vdur": 2.085, "emitted": true}, {"n": 300, "text": "父さんは\\N帰ってきやしないさ", "method": "cover", "start": 936.83, "end": 940.876, "vtt": 1222.846, "vdur": 4.046, "emitted": true}, {"n": 301, "text": "でもね 誇りに思ってるよ", "method": "cover", "start": 941.29, "end": 944.56, "vtt": 1227.1, "vdur": 3.337, "emitted": true}, {"n": 302, "text": "父さんと結婚したこと", "method": "cover", "start": 944.59, "end": 947.51, "vtt": 1230.562, "vdur": 2.92, "emitted": true}, {"n": 303, "text": "伝説の薬があるんだ\\Nどんな病気でも治しちゃう", "method": "cover", "start": 948.43, "end": 952.61, "vtt": 1234.358, "vdur": 3.92, "emitted": true}, {"n": 304, "text": "バカだねえ　夢の見すぎだよ", "method": "cover", "start": 952.73, "end": 956.818, "vtt": 1238.403, "vdur": 4.088, "emitted": true}, {"n": 305, "text": "バカでいい　夢なら見るよ", "method": "cover", "start": 956.93, "end": 960.37, "vtt": 1242.866, "vdur": 3.42, "emitted": true}, {"n": 306, "text": "俺だって\\N海賊の息子だから", "method": "cover", "start": 960.57, "end": 964.574, "vtt": 1246.411, "vdur": 4.004, "emitted": true}, {"n": 307, "text": "父さんのような\\N勇敢な男になるんだよ", "method": "cover", "start": 964.89, "end": 970.35, "vtt": 1250.874, "vdur": 5.297, "emitted": true}, {"n": 308, "text": "海賊が来たぞーっ", "method": "cover", "start": 976.81, "end": 981.44, "vtt": 1262.719, "vdur": 4.63, "emitted": true}, {"n": 309, "text": "寂しさからか 母の死後も\\N彼は叫び続けました", "method": "cover", "start": 981.75, "end": 987.047, "vtt": 1267.474, "vdur": 5.297, "emitted": true}, {"n": 310, "text": "彼の父親の乗る海賊船が―", "method": "cover", "start": 987.19, "end": 989.52, "vtt": 1272.98, "vdur": 2.627, "emitted": true}, {"n": 311, "text": "いつの日か\\N海岸に現れやしないかと", "method": "cover", "start": 989.55, "end": 992.95, "vtt": 1275.732, "vdur": 2.962, "emitted": true}, {"n": 312, "text": "自分を迎えに\\N来てくれるんじゃないかと", "method": "cover", "start": 993.31, "end": 996.47, "vtt": 1279.236, "vdur": 2.961, "emitted": true}, {"n": 313, "text": "あのウソには 彼の願いも\\N込められているのだと―", "method": "cover", "start": 999.79, "end": 1003.88, "vtt": 1285.617, "vdur": 3.921, "emitted": true}, {"n": 314, "text": "村の人たちは言います", "method": "cover", "start": 1003.91, "end": 1005.8, "vtt": 1289.788, "vdur": 1.835, "emitted": true}, {"n": 315, "text": "海賊だーっ", "method": "cover", "start": 1005.83, "end": 1008.749, "vtt": 1291.832, "vdur": 2.919, "emitted": true}, {"n": 316, "text": "この村で両親を失ってしまった\\N彼にとって―", "method": "cover", "start": 1009.23, "end": 1012.6, "vtt": 1295.21, "vdur": 3.337, "emitted": true}, {"n": 317, "text": "同じ境遇に立たされたお嬢様を\\N放ってはおけなかったのでしょう", "method": "cover", "start": 1012.63, "end": 1017.2, "vtt": 1298.672, "vdur": 4.963, "emitted": true}, {"n": 318, "text": "あなたは これから もっと\\N強くなる必要がありますね", "method": "cover", "start": 1017.23, "end": 1022.33, "vtt": 1304.219, "vdur": 4.088, "emitted": true}, {"n": 319, "text": "今日までの彼の好意に\\N応えるためには", "method": "cover", "start": 1022.77, "end": 1026.857, "vtt": 1308.682, "vdur": 4.087, "emitted": true}, {"n": 320, "text": "うん", "method": null, "start": null, "end": null, "vtt": 1314.604, "vdur": 0.876, "emitted": false}, {"n": 321, "text": "新しい船と仲間に…", "method": "cover", "start": 1034.03, "end": 1036.53, "vtt": 1320.027, "vdur": 2.043, "emitted": true}, {"n": 322, "text": "乾杯だーっ", "method": null, "start": null, "end": null, "vtt": 1322.404, "vdur": 2.044, "emitted": false}, {"n": 323, "text": "彼らが言ってたわ", "method": "cover", "start": 1042.11, "end": 1043.98, "vtt": 1327.868, "vdur": 1.877, "emitted": true}, {"n": 324, "text": "“死ぬためじゃない\\N生きるために戦うんだ”って", "method": "cover", "start": 1044.01, "end": 1047.847, "vtt": 1329.87, "vdur": 3.837, "emitted": true}, {"n": 325, "text": "ウソップさんのウソはいつも\\N生きる楽しさを語っていた", "method": "cover", "start": 1048.33, "end": 1052.73, "vtt": 1334.249, "vdur": 4.296, "emitted": true}, {"n": 326, "text": "生きろって\\N励ましてくれていた", "method": "cover", "start": 1053.01, "end": 1055.22, "vtt": 1338.879, "vdur": 2.21, "emitted": true}, {"n": 327, "text": "そうでしたね", "method": "cover", "start": 1055.79, "end": 1057.709, "vtt": 1341.506, "vdur": 1.919, "emitted": true}, {"n": 328, "text": "いくぞ", "method": "cover", "start": 1057.85, "end": 1059.143, "vtt": 1343.842, "vdur": 1.293, "emitted": true}, {"n": 329, "text": "ホントにやるのかよ", "method": "cover", "start": 1059.41, "end": 1060.93, "vtt": 1345.26, "vdur": 1.502, "emitted": true}, {"n": 330, "text": "やるさ キャプテンのあとは\\N俺たちが継ぐんだ", "method": "cover", "start": 1061.29, "end": 1064.77, "vtt": 1347.137, "vdur": 3.17, "emitted": true}, {"n": 331, "text": "いっせーの", "method": null, "start": null, "end": null, "vtt": 1350.932, "vdur": 2.461, "emitted": false}, {"n": 332, "text": "海賊が来たぞーっ", "method": "interp1", "start": 1067.54, "end": 1074.005, "vtt": 1356.229, "vdur": 6.465, "emitted": true}, {"n": 333, "text": "あのね メリー", "method": "cover", "start": 1074.13, "end": 1076.007, "vtt": 1362.819, "vdur": 1.877, "emitted": true}, {"n": 334, "text": "私 医者になる", "method": "cover", "start": 1076.19, "end": 1078.609, "vtt": 1364.863, "vdur": 2.419, "emitted": true}, {"n": 335, "text": "ほう それは\\N立派な目標ができましたね", "method": "cover", "start": 1078.69, "end": 1083.195, "vtt": 1367.407, "vdur": 4.505, "emitted": true}, {"n": 336, "text": "おい この島 不気味だよ\\N戻ろうぜ", "method": null, "start": null, "end": null, "vtt": 1450.949, "vdur": 2.586, "emitted": false}, {"n": 337, "text": "宝探しか\\N何かワクワクすんな", "method": null, "start": null, "end": null, "vtt": 1453.66, "vdur": 2.544, "emitted": false}, {"n": 338, "text": "気をつけろ 何かいるぞ", "method": null, "start": null, "end": null, "vtt": 1456.329, "vdur": 1.252, "emitted": false}, {"n": 339, "text": "うわーっ", "method": null, "start": null, "end": null, "vtt": 1457.706, "vdur": 0.959, "emitted": false}, {"n": 340, "text": "何なの？ こいつ\\Nめちゃめちゃ怪しいわね", "method": null, "start": null, "end": null, "vtt": 1458.832, "vdur": 2.669, "emitted": false}, {"n": 341, "text": "島の守り神だってよ", "method": null, "start": null, "end": null, "vtt": 1461.877, "vdur": 1.793, "emitted": false}, {"n": 342, "text": "面白え タワシか？", "method": null, "start": null, "end": null, "vtt": 1463.962, "vdur": 2.211, "emitted": false}, {"n": 343, "text": "次回 ワンピース", "method": null, "start": null, "end": null, "vtt": 1466.59, "vdur": 1.251, "emitted": false}, {"n": 344, "text": "「あんたが珍獣！\\Nガイモンと奇妙な仲間」", "method": null, "start": null, "end": null, "vtt": 1467.966, "vdur": 3.212, "emitted": false}, {"n": 345, "text": "海賊王に 俺はなる！", "method": null, "start": null, "end": null, "vtt": 1471.303, "vdur": 2.419, "emitted": false}], "parts": [{"parent": 146, "text": "俺は 本物の海賊になるんだ", "start": 405.97, "end": 408.73}]}
{"episode": "[One Pace][56-59] Baratie 05 [1080p][ACEA0537]", "video": "[One Pace][56-59] Baratie 05 [1080p][ACEA0537].mkv", "lines": [{"n": 0, "text": "富 名声 力", "method": "cover", "start": 1.27, "end": 3.272, "vtt": 2.168, "vdur": 2.002, "emitted": true}, {"n": 1, "text": "この世のすべてを手に入れた男\\N海賊王 ゴールド･ロジャー", "method": "cover", "start": 3.37, "end": 7.458, "vtt": 4.295, "vdur": 4.088, "emitted": true}, {"n": 2, "text": "彼の死に際に放ったひと言は\\N人々を海へ駆り立てた", "method": "cover", "start": 7.65, "end": 11.32, "vtt": 8.508, "vdur": 3.629, "emitted": true}, {"n": 3, "text": "俺の財宝か？\\N欲しけりゃくれてやる", "method": "cover", "start": 11.35, "end": 15.21, "vtt": 12.262, "vdur": 3.754, "emitted": true}, {"n": 4, "text": "探せ！ この世のすべてを\\Nそこに置いてきた", "method": "cover", "start": 15.39, "end": 18.97, "vtt": 16.141, "vdur": 3.503, "emitted": true}, {"n": 5, "text": "男たちは\\Nグランドラインを目指し", "method": "cover", "start": 21.45, "end": 24.0, "vtt": 22.272, "vdur": 2.502, "emitted": true}, {"n": 6, "text": "夢を追い続ける", "method": "cover", "start": 24.03, "end": 25.782, "vtt": 24.899, "vdur": 1.752, "emitted": true}, {"n": 7, "text": "世は まさに大海賊時代！", "method": "cover", "start": 26.13, "end": 29.29, "vtt": 27.027, "vdur": 3.044, "emitted": true}, {"n": 8, "text": "「ゼフとサンジの夢\\N幻のオールブルー」", "method": null, "start": null, "end": null, "vtt": 115.323, "vdur": 4.046, "emitted": false}, {"n": 9, "text": "ギン！", "method": "cover", "start": 112.591, "end": 113.55, "vtt": 123.456, "vdur": 0.959, "emitted": true}, {"n": 10, "text": "過去にどれだけ\\Nすごかった男でも―", "method": "cover", "start": 114.25, "end": 116.4, "vtt": 125.041, "vdur": 2.419, "emitted": true}, {"n": 11, "text": "こうなっちゃ ただのコック", "method": "cover", "start": 116.43, "end": 118.69, "vtt": 127.585, "vdur": 1.794, "emitted": true}, {"n": 12, "text": "頭を撃ち抜くのも簡単だ", "method": "cover", "start": 119.17, "end": 121.923, "vtt": 129.796, "vdur": 2.753, "emitted": true}, {"n": 13, "text": "この男を助けたいだろ？\\Nサンジさん", "method": "cover", "start": 122.99, "end": 125.617, "vtt": 133.8, "vdur": 2.627, "emitted": true}, {"n": 14, "text": "頼む おとなしく\\Nこの船を下りてくれ", "method": "cover", "start": 125.83, "end": 129.542, "vtt": 136.553, "vdur": 3.712, "emitted": true}, {"n": 15, "text": "俺は あんたを\\N殺したくねえんだ", "method": "cover", "start": 129.65, "end": 132.403, "vtt": 140.39, "vdur": 2.753, "emitted": true}, {"n": 16, "text": "船を下りろ？", "method": "cover", "start": 135.43, "end": 137.14, "vtt": 146.104, "vdur": 1.71, "emitted": true}, {"n": 17, "text": "やなこった", "method": "cover", "start": 137.97, "end": 139.18, "vtt": 148.439, "vdur": 1.21, "emitted": true}, {"n": 18, "text": "あっ…", "method": null, "start": null, "end": null, "vtt": 149.899, "vdur": 0.876, "emitted": false}, {"n": 19, "text": "なんてマヌケな姿だよ\\Nクソジジイ", "method": "cover", "start": 140.93, "end": 144.26, "vtt": 151.693, "vdur": 3.336, "emitted": true}, {"n": 20, "text": "そんなんじゃ 戦うコックどもに\\N示しがつかねえだろ", "method": "cover", "start": 144.29, "end": 147.57, "vtt": 155.155, "vdur": 3.128, "emitted": true}, {"n": 21, "text": "フン チビナスには\\N何も言われたくねえな", "method": "cover+snap", "start": 147.77, "end": 151.315, "vtt": 158.533, "vdur": 3.545, "emitted": true}, {"n": 22, "text": "何がチビナスだ クソ野郎", "method": "cover", "start": 151.55, "end": 153.844, "vtt": 162.203, "vdur": 2.294, "emitted": true}, {"n": 23, "text": "いつまでも\\Nガキ扱いすんじゃねえ！", "method": "cover", "start": 153.95, "end": 156.21, "vtt": 164.622, "vdur": 2.169, "emitted": true}, {"n": 24, "text": "サンジの野郎", "method": "cover", "start": 156.35, "end": 157.58, "vtt": 167.167, "vdur": 1.334, "emitted": true}, {"n": 25, "text": "オーナーを見捨てる気じゃ\\Nねえだろうな", "method": "cover", "start": 157.61, "end": 160.393, "vtt": 168.626, "vdur": 2.378, "emitted": true}, {"n": 26, "text": "ギン そのピストル\\N俺に向けろ", "method": "cover+snap", "start": 160.423, "end": 163.801, "vtt": 171.379, "vdur": 3.378, "emitted": true}, {"n": 27, "text": "お前 バカか 死ぬぞ", "method": "cover", "start": 165.11, "end": 167.07, "vtt": 175.967, "vdur": 1.96, "emitted": true}, {"n": 28, "text": "まあな", "method": "cover", "start": 167.27, "end": 168.27, "vtt": 178.052, "vdur": 0.751, "emitted": true}, {"n": 29, "text": "サンジさん なんで…", "method": "cover", "start": 168.79, "end": 171.334, "vtt": 179.512, "vdur": 2.544, "emitted": true}, {"n": 30, "text": "そんなに死にたきゃ\\N殺してやるぜ", "method": "cover", "start": 171.93, "end": 175.508, "vtt": 182.515, "vdur": 3.587, "emitted": true}, {"n": 31, "text": "いぶし銀にな", "method": "cover", "start": 175.538, "end": 176.956, "vtt": 186.227, "vdur": 1.418, "emitted": true}, {"n": 32, "text": "動くなよ", "method": "cover", "start": 178.09, "end": 179.675, "vtt": 188.98, "vdur": 1.585, "emitted": true}, {"n": 33, "text": "オーナーの頭を\\N吹き飛ばされたくなかったらな", "method": "cover", "start": 179.75, "end": 183.05, "vtt": 190.69, "vdur": 2.711, "emitted": true}, {"n": 34, "text": "超天然パール―", "method": "cover", "start": 184.51, "end": 186.376, "vtt": 195.278, "vdur": 2.002, "emitted": true}, {"n": 35, "text": "プレゼント！\\Nうおっ", "method": "cover", "start": 186.406, "end": 189.296, "vtt": 197.405, "vdur": 1.21, "emitted": true}, {"n": 36, "text": "ああっ！", "method": null, "start": null, "end": null, "vtt": 199.115, "vdur": 1.376, "emitted": false}, {"n": 37, "text": "サンジ！", "method": "cover+snap", "start": 189.683, "end": 191.1, "vtt": 200.617, "vdur": 0.917, "emitted": true}, {"n": 38, "text": "お前 なんでよけねえんだよ", "method": "cover", "start": 191.13, "end": 193.215, "vtt": 202.035, "vdur": 2.085, "emitted": true}, {"n": 39, "text": "そこのクソ下っ端が\\N引き金 引いちまうだろ", "method": "cover", "start": 193.95, "end": 197.88, "vtt": 204.829, "vdur": 4.421, "emitted": true}, {"n": 40, "text": "なんでだ", "method": "cover", "start": 197.91, "end": 200.01, "vtt": 210.084, "vdur": 1.043, "emitted": true}, {"n": 41, "text": "この店 捨てりゃ\\N全員 命は助かるんだぜ", "method": "cover", "start": 200.04, "end": 202.98, "vtt": 211.252, "vdur": 2.586, "emitted": true}, {"n": 42, "text": "簡単だろ", "method": "cover", "start": 203.01, "end": 203.96, "vtt": 213.963, "vdur": 1.043, "emitted": true}, {"n": 43, "text": "この店は そのジジイの宝だ", "method": "cover", "start": 203.99, "end": 206.85, "vtt": 215.131, "vdur": 2.086, "emitted": true}, {"n": 44, "text": "俺は クソジジイから\\N何もかも取り上げちまった男だ", "method": "cover", "start": 210.27, "end": 214.816, "vtt": 221.221, "vdur": 4.546, "emitted": true}, {"n": 45, "text": "力も", "method": "cover", "start": 217.33, "end": 218.665, "vtt": 228.102, "vdur": 1.335, "emitted": true}, {"n": 46, "text": "夢も", "method": "cover", "start": 221.03, "end": 222.406, "vtt": 231.731, "vdur": 1.376, "emitted": true}, {"n": 47, "text": "だから 俺はもう―", "method": "cover", "start": 224.89, "end": 226.33, "vtt": 235.735, "vdur": 1.418, "emitted": true}, {"n": 48, "text": "クソジジイには\\N何も失ってほしくねえんだよ！", "method": "cover", "start": 226.75, "end": 230.01, "vtt": 237.695, "vdur": 3.003, "emitted": true}, {"n": 49, "text": "サンジ 危ねえ！", "method": "cover", "start": 230.91, "end": 232.35, "vtt": 241.866, "vdur": 1.001, "emitted": true}, {"n": 50, "text": "パールクローズ！\\Nうわあっ", "method": null, "start": null, "end": null, "vtt": 243.117, "vdur": 2.837, "emitted": false}, {"n": 51, "text": "サンジ！", "method": null, "start": null, "end": null, "vtt": 246.329, "vdur": 1.209, "emitted": false}, {"n": 52, "text": "ああ…", "method": null, "start": null, "end": null, "vtt": 247.914, "vdur": 0.751, "emitted": false}, {"n": 53, "text": "うあ…", "method": null, "start": null, "end": null, "vtt": 249.207, "vdur": 0.959, "emitted": false}, {"n": 54, "text": "オールブルー？", "method": "cover+snap", "start": 241.746, "end": 243.06, "vtt": 252.961, "vdur": 0.875, "emitted": true}, {"n": 55, "text": "ああ 伝説の海さ", "method": "cover", "start": 243.09, "end": 245.9, "vtt": 254.337, "vdur": 2.419, "emitted": true}, {"n": 56, "text": "どこかにあるんだ 必ず", "method": "cover", "start": 246.21, "end": 249.005, "vtt": 257.131, "vdur": 2.795, "emitted": true}, {"n": 57, "text": "バカだなあ お前は", "method": "cover", "start": 255.55, "end": 257.26, "vtt": 266.391, "vdur": 1.793, "emitted": true}, {"n": 58, "text": "そりゃあ そういう伝説は\\Nあるけどよ", "method": "cover", "start": 257.29, "end": 260.19, "vtt": 268.309, "vdur": 2.67, "emitted": true}, {"n": 59, "text": "まあ 確かに\\N俺たちだって 海のコックだ", "method": "cover", "start": 260.37, "end": 263.665, "vtt": 271.104, "vdur": 3.295, "emitted": true}, {"n": 60, "text": "一度は その海を\\N夢見たことあるぜ", "method": "cover", "start": 263.71, "end": 266.27, "vtt": 274.524, "vdur": 2.461, "emitted": true}, {"n": 61, "text": "だろ？", "method": "cover", "start": 266.37, "end": 267.04, "vtt": 277.11, "vdur": 0.959, "emitted": true}, {"n": 62, "text": "俺は いつか必ず\\Nその海を探し出すんだ", "method": "cover", "start": 267.07, "end": 270.53, "vtt": 278.194, "vdur": 3.295, "emitted": true}, {"n": 63, "text": "探すったってなあ サンジ", "method": "cover", "start": 271.21, "end": 272.94, "vtt": 281.823, "vdur": 2.127, "emitted": true}, {"n": 64, "text": "大体 お前―", "method": "cover", "start": 272.97, "end": 274.34, "vtt": 284.075, "vdur": 1.126, "emitted": true}, {"n": 65, "text": "オールブルーがどんなとこか\\N分かってんのか？", "method": "cover", "start": 274.37, "end": 277.04, "vtt": 285.326, "vdur": 2.544, "emitted": true}, {"n": 66, "text": "分かってるよ バカにすんな", "method": "cover", "start": 277.07, "end": 279.31, "vtt": 287.996, "vdur": 1.876, "emitted": true}, {"n": 67, "text": "イーストブルー ウエストブルー\\Nノースブルー サウスブルー", "method": "cover", "start": 279.73, "end": 283.57, "vtt": 290.581, "vdur": 3.838, "emitted": true}, {"n": 68, "text": "この４つの海にいる\\N全種類の魚たちがすんでる海", "method": "cover", "start": 283.71, "end": 287.91, "vtt": 294.544, "vdur": 4.129, "emitted": true}, {"n": 69, "text": "それが オールブルーさ", "method": "cover", "start": 287.95, "end": 289.66, "vtt": 298.798, "vdur": 1.71, "emitted": true}, {"n": 70, "text": "海のコックにとっては\\Nたまらねえ楽園なんだ", "method": "cover", "start": 289.87, "end": 293.332, "vtt": 300.633, "vdur": 3.462, "emitted": true}, {"n": 71, "text": "俺の夢だ", "method": "cover", "start": 295.39, "end": 296.71, "vtt": 306.139, "vdur": 1.209, "emitted": true}, {"n": 72, "text": "そりゃあな 世界中の海の食材が\\Nその海にそろってるんだ", "method": "cover", "start": 297.25, "end": 301.81, "vtt": 308.057, "vdur": 4.546, "emitted": true}, {"n": 73, "text": "料理人の腕が鳴るってもんだろ", "method": "cover", "start": 301.85, "end": 304.49, "vtt": 312.729, "vdur": 2.586, "emitted": true}, {"n": 74, "text": "ああ 命を懸けても\\Nその海を探す価値はある", "method": "cover", "start": 305.53, "end": 309.04, "vtt": 315.44, "vdur": 4.087, "emitted": true}, {"n": 75, "text": "本当にあればな\\Nえっ？", "method": null, "start": null, "end": null, "vtt": 319.652, "vdur": 2.086, "emitted": false}, {"n": 76, "text": "ありえねえんだよ\\Nオールブルーなんて奇跡の海は", "method": "cover", "start": 310.29, "end": 314.85, "vtt": 322.238, "vdur": 3.337, "emitted": true}, {"n": 77, "text": "ちょっと考えれば分かることだ", "method": "cover", "start": 315.11, "end": 317.33, "vtt": 325.7, "vdur": 2.085, "emitted": true}, {"n": 78, "text": "おおかた どこぞの\\N夢見るコックが―", "method": "cover", "start": 317.65, "end": 320.24, "vtt": 328.494, "vdur": 2.419, "emitted": true}, {"n": 79, "text": "大ボラ吹いたんだろ", "method": "cover", "start": 320.27, "end": 321.646, "vtt": 331.039, "vdur": 1.376, "emitted": true}, {"n": 80, "text": "さあ バカ話は終わりだ", "method": "cover", "start": 321.71, "end": 323.962, "vtt": 332.54, "vdur": 2.252, "emitted": true}, {"n": 81, "text": "皿引いてこい サンジ", "method": "cover", "start": 324.17, "end": 326.089, "vtt": 334.917, "vdur": 1.919, "emitted": true}, {"n": 82, "text": "あーあ もったいねえな\\Nこんなに残してくれやがって", "method": "cover", "start": 330.39, "end": 333.81, "vtt": 340.465, "vdur": 4.004, "emitted": true}, {"n": 83, "text": "これなんか ほとんど\\N手つけてねえぞ", "method": "cover", "start": 333.84, "end": 335.88, "vtt": 344.594, "vdur": 2.169, "emitted": true}, {"n": 84, "text": "自信作だったのによ", "method": "cover", "start": 335.91, "end": 337.42, "vtt": 346.846, "vdur": 1.543, "emitted": true}, {"n": 85, "text": "昨今の客は ぜいたくだな おい", "method": "cover", "start": 337.45, "end": 340.286, "vtt": 348.514, "vdur": 2.836, "emitted": true}, {"n": 86, "text": "みんな やめろよ\\N客の残りもんなんて", "method": "cover", "start": 340.45, "end": 343.41, "vtt": 351.476, "vdur": 2.544, "emitted": true}, {"n": 87, "text": "味悪そうな食材も\\Nさっき 捨てといたぞ", "method": "cover", "start": 343.61, "end": 345.88, "vtt": 354.437, "vdur": 2.502, "emitted": true}, {"n": 88, "text": "そういうこと言ってるから\\Nお前は まだ半人前だってんだ", "method": "cover", "start": 345.91, "end": 349.77, "vtt": 357.065, "vdur": 3.545, "emitted": true}, {"n": 89, "text": "俺たちは海のコックだってことを\\N忘れるな", "method": "cover", "start": 350.07, "end": 353.115, "vtt": 360.735, "vdur": 3.045, "emitted": true}, {"n": 90, "text": "海ってのは\\N何が起こるか分からねえ", "method": "cover", "start": 353.37, "end": 355.74, "vtt": 364.238, "vdur": 2.419, "emitted": true}, {"n": 91, "text": "節約しとくに\\N越したことはねえんだよ", "method": "cover", "start": 355.77, "end": 358.61, "vtt": 366.783, "vdur": 2.419, "emitted": true}, {"n": 92, "text": "どうだい お前も うん？", "method": "cover", "start": 359.01, "end": 360.72, "vtt": 369.786, "vdur": 1.71, "emitted": true}, {"n": 93, "text": "フン 要らねえよ", "method": "cover+snap", "start": 360.871, "end": 363.251, "vtt": 371.621, "vdur": 1.877, "emitted": true}, {"n": 94, "text": "皆さん 落ち着いて\\N落ち着いてください", "method": "cover", "start": 364.51, "end": 367.888, "vtt": 375.208, "vdur": 3.378, "emitted": true}, {"n": 95, "text": "うん？", "method": null, "start": null, "end": null, "vtt": 378.878, "vdur": 0.667, "emitted": false}, {"n": 96, "text": "海賊だ", "method": "cover", "start": 372.05, "end": 373.25, "vtt": 382.924, "vdur": 0.709, "emitted": true}, {"n": 97, "text": "いっ…", "method": null, "start": null, "end": null, "vtt": 383.883, "vdur": 0.709, "emitted": false}, {"n": 98, "text": "海賊？", "method": "cover", "start": 375.07, "end": 376.113, "vtt": 385.843, "vdur": 1.043, "emitted": true}, {"n": 99, "text": "あの船は―", "method": "cover", "start": 380.081, "end": 381.75, "vtt": 391.265, "vdur": 1.669, "emitted": true}, {"n": 100, "text": "か… 海賊団\\N赫足のゼフの船だ", "method": "cover", "start": 382.79, "end": 386.21, "vtt": 393.351, "vdur": 3.42, "emitted": true}, {"n": 101, "text": "グランドラインから帰ったのか", "method": "cover", "start": 387.09, "end": 389.635, "vtt": 397.98, "vdur": 2.545, "emitted": true}, {"n": 102, "text": "ヘヘヘヘヘヘッ", "method": null, "start": null, "end": null, "vtt": 406.489, "vdur": 2.127, "emitted": false}, {"n": 103, "text": "ハハハハハハッ", "method": null, "start": null, "end": null, "vtt": 409.534, "vdur": 1.835, "emitted": false}, {"n": 104, "text": "海賊 赫足のゼフ船長かと\\Nお見受けします", "method": "cover", "start": 402.07, "end": 405.98, "vtt": 413.037, "vdur": 4.046, "emitted": true}, {"n": 105, "text": "ご用件は…", "method": "cover", "start": 406.01, "end": 407.61, "vtt": 417.208, "vdur": 0.918, "emitted": true}, {"n": 106, "text": "奪え", "method": "cover", "start": 407.99, "end": 409.17, "vtt": 419.335, "vdur": 0.918, "emitted": true}, {"n": 107, "text": "金品を すべて奪い尽くせ", "method": "cover", "start": 410.47, "end": 414.182, "vtt": 422.004, "vdur": 3.712, "emitted": true}, {"n": 108, "text": "クソッ クソッ\\N殺されてたまるか", "method": "interp1", "start": 416.776, "end": 420.905, "vtt": 428.469, "vdur": 4.129, "emitted": true}, {"n": 109, "text": "あんなやつらに\\N殺されてたまるか", "method": "cover", "start": 421.03, "end": 423.61, "vtt": 432.723, "vdur": 2.336, "emitted": true}, {"n": 110, "text": "うわっ", "method": null, "start": null, "end": null, "vtt": 435.601, "vdur": 2.086, "emitted": false}, {"n": 111, "text": "何だ このガキ", "method": "cover", "start": 426.43, "end": 427.73, "vtt": 437.812, "vdur": 1.084, "emitted": true}, {"n": 112, "text": "おい 坊主", "method": "cover", "start": 428.15, "end": 429.1, "vtt": 439.439, "vdur": 1.209, "emitted": true}, {"n": 113, "text": "危ねえから そんなもん\\N振り回すんじゃねえよ", "method": "cover", "start": 429.13, "end": 432.008, "vtt": 440.773, "vdur": 2.878, "emitted": true}, {"n": 114, "text": "血が出たよ　重傷だ こりゃ", "method": "cover", "start": 432.17, "end": 434.88, "vtt": 443.776, "vdur": 2.336, "emitted": true}, {"n": 115, "text": "うるせえ！", "method": "cover", "start": 434.91, "end": 435.64, "vtt": 446.404, "vdur": 0.917, "emitted": true}, {"n": 116, "text": "お前らなんかに\\N殺されてたまるか", "method": "cover", "start": 435.67, "end": 438.49, "vtt": 447.447, "vdur": 2.377, "emitted": true}, {"n": 117, "text": "ううっ サンジ…", "method": null, "start": null, "end": null, "vtt": 449.949, "vdur": 1.96, "emitted": false}, {"n": 118, "text": "ダメだ　抵抗するな", "method": null, "start": null, "end": null, "vtt": 452.034, "vdur": 2.294, "emitted": false}, {"n": 119, "text": "そんな死にたがりのガキは\\Nとっとと殺しちまえ", "method": "cover", "start": 444.33, "end": 447.88, "vtt": 455.663, "vdur": 3.629, "emitted": true}, {"n": 120, "text": "死にたいもんか", "method": "cover", "start": 447.91, "end": 448.94, "vtt": 459.5, "vdur": 1.001, "emitted": true}, {"n": 121, "text": "お前らに\\N殺されるくらいなら―", "method": "cover", "start": 448.97, "end": 450.6, "vtt": 460.626, "vdur": 1.418, "emitted": true}, {"n": 122, "text": "俺が先に お前らを殺してやる", "method": "cover", "start": 450.63, "end": 453.049, "vtt": 462.17, "vdur": 2.419, "emitted": true}, {"n": 123, "text": "あっ！", "method": null, "start": null, "end": null, "vtt": 465.298, "vdur": 1.126, "emitted": false}, {"n": 124, "text": "サンジ", "method": null, "start": null, "end": null, "vtt": 468.009, "vdur": 0.542, "emitted": false}, {"n": 125, "text": "カーッ やる 船長", "method": "cover", "start": 459.13, "end": 460.44, "vtt": 469.927, "vdur": 1.418, "emitted": true}, {"n": 126, "text": "容赦ねえな", "method": "cover", "start": 460.47, "end": 461.804, "vtt": 471.471, "vdur": 1.334, "emitted": true}, {"n": 127, "text": "うっ…", "method": null, "start": null, "end": null, "vtt": 475.85, "vdur": 0.959, "emitted": false}, {"n": 128, "text": "死んでたまるか", "method": "cover", "start": 472.23, "end": 474.357, "vtt": 483.483, "vdur": 2.127, "emitted": true}, {"n": 129, "text": "俺は…", "method": "interp1", "start": 475.839, "end": 477.132, "vtt": 487.778, "vdur": 1.293, "emitted": true}, {"n": 130, "text": "俺は いつか\\Nオールブルーを見つけるんだ", "method": "cover+snap", "start": 478.425, "end": 484.665, "vtt": 490.364, "vdur": 3.796, "emitted": true}, {"n": 131, "text": "オールブルーだとよ", "method": "cover", "start": 486.01, "end": 487.71, "vtt": 498.789, "vdur": 1.46, "emitted": true}, {"n": 132, "text": "ハハハッ 大いなる志だな", "method": "cover", "start": 488.51, "end": 491.94, "vtt": 500.374, "vdur": 3.587, "emitted": true}, {"n": 133, "text": "船長 言ってやってくださいよ", "method": "cover", "start": 491.97, "end": 494.08, "vtt": 504.295, "vdur": 2.461, "emitted": true}, {"n": 134, "text": "“そんなもんはグランドラインにも\\Nなかった”ってよ", "method": "cover", "start": 494.11, "end": 497.17, "vtt": 506.881, "vdur": 2.711, "emitted": true}, {"n": 135, "text": "あ… あの野郎\\Nまだ あんなことを", "method": "cover", "start": 497.41, "end": 500.05, "vtt": 510.843, "vdur": 2.503, "emitted": true}, {"n": 136, "text": "ああ…", "method": null, "start": null, "end": null, "vtt": 514.013, "vdur": 1.835, "emitted": false}, {"n": 137, "text": "こんなとこで…", "method": "interp1", "start": 504.124, "end": 506.293, "vtt": 525.775, "vdur": 2.169, "emitted": true}, {"n": 138, "text": "こんなとこで クソ海賊に\\N殺されてたまるかよ", "method": "cover", "start": 506.71, "end": 511.256, "vtt": 528.361, "vdur": 4.546, "emitted": true}, {"n": 139, "text": "船長 引き揚げましょう", "method": "cover", "start": 512.11, "end": 514.154, "vtt": 534.867, "vdur": 2.044, "emitted": true}, {"n": 140, "text": "この嵐 予想よりもでかい", "method": "cover", "start": 514.19, "end": 517.735, "vtt": 537.036, "vdur": 3.545, "emitted": true}, {"n": 141, "text": "よし てめえら\\N早えとこ 宝を船に積め", "method": "cover", "start": 518.29, "end": 522.08, "vtt": 541.207, "vdur": 4.004, "emitted": true}, {"n": 142, "text": "引き揚げるぞ", "method": "cover", "start": 522.11, "end": 523.611, "vtt": 545.336, "vdur": 1.501, "emitted": true}, {"n": 143, "text": "うわあっ！", "method": null, "start": null, "end": null, "vtt": 561.978, "vdur": 1.251, "emitted": false}, {"n": 144, "text": "サンジ", "method": null, "start": null, "end": null, "vtt": 564.146, "vdur": 0.584, "emitted": false}, {"n": 145, "text": "チッ", "method": null, "start": null, "end": null, "vtt": 565.147, "vdur": 0.668, "emitted": false}, {"n": 146, "text": "船長！", "method": "cover", "start": 548.055, "end": 549.059, "vtt": 566.19, "vdur": 1.335, "emitted": true}, {"n": 147, "text": "クソガキが", "method": "cover", "start": 549.089, "end": 550.31, "vtt": 574.323, "vdur": 1.21, "emitted": true}, {"n": 148, "text": "船長！", "method": "cover", "start": 554.05, "end": 555.051, "vtt": 579.745, "vdur": 1.001, "emitted": true}, {"n": 149, "text": "どうして そんなガキ１匹…", "method": "cover", "start": 555.41, "end": 558.121, "vtt": 581.33, "vdur": 2.711, "emitted": true}, {"n": 150, "text": "あ？ うわあーっ！", "method": null, "start": null, "end": null, "vtt": 584.166, "vdur": 2.336, "emitted": false}, {"n": 151, "text": "気がついたか？ チビナス", "method": "cover", "start": 600.03, "end": 602.22, "vtt": 678.719, "vdur": 2.252, "emitted": true}, {"n": 152, "text": "運の強え野郎だ", "method": "cover", "start": 602.25, "end": 604.29, "vtt": 681.097, "vdur": 2.002, "emitted": true}, {"n": 153, "text": "かいぞ… アイタッ\\Nイテテテ…", "method": "rescue", "start": 604.32, "end": 607.031, "vtt": 683.599, "vdur": 2.711, "emitted": true}, {"n": 154, "text": "動けるわけねえだろ", "method": "cover+snap", "start": 607.695, "end": 609.48, "vtt": 686.435, "vdur": 1.71, "emitted": true}, {"n": 155, "text": "誰の蹴りを食らったと\\N思ってるんだ", "method": "cover", "start": 609.51, "end": 612.49, "vtt": 688.27, "vdur": 2.92, "emitted": true}, {"n": 156, "text": "船は？", "method": "cover", "start": 613.51, "end": 614.52, "vtt": 692.024, "vdur": 1.126, "emitted": true}, {"n": 157, "text": "さあな", "method": "cover", "start": 614.55, "end": 615.48, "vtt": 693.275, "vdur": 1.168, "emitted": true}, {"n": 158, "text": "あの荒れようだ\\N全滅でも おかしくねえ", "method": "cover", "start": 615.51, "end": 619.65, "vtt": 694.568, "vdur": 3.712, "emitted": true}, {"n": 159, "text": "ここに打ち上げられたのは\\N俺たちだけだ", "method": "cover", "start": 620.15, "end": 623.445, "vtt": 698.781, "vdur": 3.295, "emitted": true}, {"n": 160, "text": "木の実も 動物もいねえ\\Nこの岩山にな", "method": "cover", "start": 623.55, "end": 627.27, "vtt": 702.201, "vdur": 3.545, "emitted": true}, {"n": 161, "text": "海には 魚くらい\\Nいるだろうが", "method": "cover", "start": 628.01, "end": 630.65, "vtt": 706.622, "vdur": 2.544, "emitted": true}, {"n": 162, "text": "岩は波にえぐられて\\N一度 下りたら帰ってこれねえ", "method": "cover", "start": 630.75, "end": 634.2, "vtt": 709.291, "vdur": 3.462, "emitted": true}, {"n": 163, "text": "ネズミ返しになってやがる\\N泣けてくるだろ", "method": "cover", "start": 634.23, "end": 637.31, "vtt": 712.878, "vdur": 2.628, "emitted": true}, {"n": 164, "text": "ヘッ", "method": null, "start": null, "end": null, "vtt": 715.631, "vdur": 1.043, "emitted": false}, {"n": 165, "text": "全部 お前のせいだからな\\Nぶっ殺してやる", "method": "cover", "start": 638.29, "end": 642.13, "vtt": 716.924, "vdur": 3.504, "emitted": true}, {"n": 166, "text": "ほえてろ　どの道\\N助けを待つしかねえんだ", "method": "cover", "start": 642.33, "end": 645.3, "vtt": 720.803, "vdur": 3.17, "emitted": true}, {"n": 167, "text": "来なけりゃ 干からびて\\N白骨になるだけよ", "method": "cover", "start": 645.33, "end": 648.37, "vtt": 724.098, "vdur": 3.003, "emitted": true}, {"n": 168, "text": "白骨？", "method": "cover", "start": 648.77, "end": 650.188, "vtt": 727.393, "vdur": 1.418, "emitted": true}, {"n": 169, "text": "俺が？", "method": "cover", "start": 650.71, "end": 651.544, "vtt": 729.228, "vdur": 0.834, "emitted": true}, {"n": 170, "text": "そこの袋 お前の取り分だ", "method": "cover", "start": 652.25, "end": 655.42, "vtt": 731.021, "vdur": 3.045, "emitted": true}, {"n": 171, "text": "えっ？", "method": null, "start": null, "end": null, "vtt": 734.191, "vdur": 1.043, "emitted": false}, {"n": 172, "text": "運よく打ち上げられた食料", "method": "cover", "start": 658.13, "end": 660.7, "vtt": 736.861, "vdur": 2.502, "emitted": true}, {"n": 173, "text": "普通に食って\\N５日分ってとこか", "method": "cover", "start": 660.73, "end": 664.08, "vtt": 739.488, "vdur": 3.003, "emitted": true}, {"n": 174, "text": "せいぜい 頭を使って食え", "method": "cover", "start": 664.57, "end": 666.54, "vtt": 743.2, "vdur": 1.752, "emitted": true}, {"n": 175, "text": "お互い コックでよかったな", "method": "cover", "start": 666.57, "end": 669.031, "vtt": 745.077, "vdur": 2.461, "emitted": true}, {"n": 176, "text": "待てよ　そっちは\\Nお前の取り分か？", "method": "cover", "start": 672.93, "end": 675.9, "vtt": 751.667, "vdur": 3.003, "emitted": true}, {"n": 177, "text": "全然 多いじゃねえか\\N３倍はある", "method": "cover", "start": 675.93, "end": 679.11, "vtt": 754.795, "vdur": 2.753, "emitted": true}, {"n": 178, "text": "当たり前だ", "method": "cover", "start": 680.37, "end": 682.455, "vtt": 762.47, "vdur": 2.085, "emitted": true}, {"n": 179, "text": "俺は大人なんだ\\N胃袋のでかさが違う", "method": "cover", "start": 682.95, "end": 687.246, "vtt": 765.014, "vdur": 4.296, "emitted": true}, {"n": 180, "text": "分けてやるだけ寛大だと思え", "method": "cover", "start": 687.53, "end": 691.01, "vtt": 769.727, "vdur": 2.794, "emitted": true}, {"n": 181, "text": "妙な哀れみは期待するなよ", "method": "cover", "start": 691.69, "end": 694.86, "vtt": 773.772, "vdur": 3.17, "emitted": true}, {"n": 182, "text": "クソジジイ", "method": "cover", "start": 697.37, "end": 699.205, "vtt": 779.445, "vdur": 1.835, "emitted": true}, {"n": 183, "text": "おめえは反対側の海を見張れ", "method": "rescue", "start": 703.408, "end": 706.161, "vtt": 789.288, "vdur": 2.753, "emitted": true}, {"n": 184, "text": "船が見えたら すぐに知らせろ", "method": "cover", "start": 706.23, "end": 708.48, "vtt": 792.166, "vdur": 2.669, "emitted": true}, {"n": 185, "text": "それまでの接触は一切なしだ", "method": "cover", "start": 708.51, "end": 711.76, "vtt": 794.96, "vdur": 2.836, "emitted": true}, {"n": 186, "text": "ムダなエネルギーだからな", "method": "cover", "start": 711.79, "end": 714.3, "vtt": 797.922, "vdur": 2.335, "emitted": true}, {"n": 187, "text": "幸運を祈る", "method": "cover", "start": 714.33, "end": 716.291, "vtt": 800.382, "vdur": 1.961, "emitted": true}, {"n": 188, "text": "あのクソジジイ", "method": "cover", "start": 716.61, "end": 718.44, "vtt": 802.76, "vdur": 1.543, "emitted": true}, {"n": 189, "text": "船見つけたって\\N教えてやるもんか", "method": "cover", "start": 718.47, "end": 720.56, "vtt": 804.428, "vdur": 2.169, "emitted": true}, {"n": 190, "text": "大丈夫 食料は\\N５日分もあるんだし", "method": "cover", "start": 720.59, "end": 724.23, "vtt": 806.972, "vdur": 3.254, "emitted": true}, {"n": 191, "text": "５日もありゃ\\N船の１隻や２隻 必ず通るさ", "method": "cover", "start": 724.29, "end": 728.31, "vtt": 810.351, "vdur": 3.712, "emitted": true}, {"n": 192, "text": "でも 万が一ということが\\Nあるからな", "method": "cover", "start": 728.91, "end": 731.64, "vtt": 814.813, "vdur": 2.878, "emitted": true}, {"n": 193, "text": "一応 20日分に分けとこう", "method": "cover", "start": 731.67, "end": 734.21, "vtt": 817.816, "vdur": 2.378, "emitted": true}, {"n": 194, "text": "20日間なら絶対 船は通る", "method": "cover", "start": 734.43, "end": 737.0, "vtt": 820.319, "vdur": 2.711, "emitted": true}, {"n": 195, "text": "大丈夫 必ず助かるんだ\\N簡単だ", "method": "cover", "start": 737.03, "end": 741.85, "vtt": 823.948, "vdur": 4.004, "emitted": true}, {"n": 196, "text": "今日は来なかったな", "method": "cover", "start": 755.69, "end": 757.35, "vtt": 841.507, "vdur": 1.543, "emitted": true}, {"n": 197, "text": "大丈夫\\Nもう２～３日の辛抱だ", "method": "cover", "start": 759.01, "end": 762.097, "vtt": 844.426, "vdur": 3.087, "emitted": true}, {"n": 198, "text": "死にたくねえよ…", "method": "cover", "start": 768.05, "end": 770.094, "vtt": 854.186, "vdur": 2.044, "emitted": true}, {"n": 199, "text": "最後のパン カビ生えてら", "method": "cover", "start": 781.91, "end": 785.33, "vtt": 872.538, "vdur": 3.42, "emitted": true}, {"n": 200, "text": "あーあ もったいねえなあ", "method": "cover", "start": 793.61, "end": 795.28, "vtt": 889.471, "vdur": 1.794, "emitted": true}, {"n": 201, "text": "こんなに残してくれやがって", "method": "cover", "start": 795.31, "end": 798.062, "vtt": 891.891, "vdur": 2.752, "emitted": true}, {"n": 202, "text": "みんな やめろよ\\N客の残りもんなんて", "method": "cover", "start": 798.75, "end": 801.61, "vtt": 895.436, "vdur": 2.794, "emitted": true}, {"n": 203, "text": "味悪そうな食材も\\Nさっき 捨てといたぞ", "method": "cover", "start": 801.83, "end": 804.833, "vtt": 898.355, "vdur": 3.003, "emitted": true}, {"n": 204, "text": "どうだい お前も うん？", "method": "cover", "start": 805.27, "end": 807.432, "vtt": 901.859, "vdur": 2.21, "emitted": true}, {"n": 205, "text": "要らねえよ", "method": "interp", "start": 807.462, "end": 808.55, "vtt": 904.904, "vdur": 1.042, "emitted": true}, {"n": 206, "text": "あっ ハッ！", "method": null, "start": null, "end": null, "vtt": 919.793, "vdur": 1.46, "emitted": false}, {"n": 207, "text": "ああっ！", "method": null, "start": null, "end": null, "vtt": 922.212, "vdur": 0.96, "emitted": false}, {"n": 208, "text": "あっ ああ…", "method": null, "start": null, "end": null, "vtt": 926.091, "vdur": 2.461, "emitted": false}, {"n": 209, "text": "最後のパン…", "method": "cover", "start": 832.325, "end": 834.41, "vtt": 929.72, "vdur": 2.085, "emitted": true}, {"n": 210, "text": "あのクソジジイは", "method": "cover", "start": 871.57, "end": 873.655, "vtt": 969.76, "vdur": 2.085, "emitted": true}, {"n": 211, "text": "もう死んだかな…", "method": "cover", "start": 874.15, "end": 876.068, "vtt": 972.221, "vdur": 1.918, "emitted": true}, {"n": 212, "text": "あっ", "method": null, "start": null, "end": null, "vtt": 990.406, "vdur": 1.209, "emitted": false}, {"n": 213, "text": "あいつ まだ生きてる", "method": "cover", "start": 883.65, "end": 885.73, "vtt": 992.449, "vdur": 2.002, "emitted": true}, {"n": 214, "text": "それに食料も…", "method": "cover", "start": 886.65, "end": 888.568, "vtt": 994.952, "vdur": 1.918, "emitted": true}, {"n": 215, "text": "まだ あんなに", "method": "cover", "start": 889.39, "end": 890.891, "vtt": 997.83, "vdur": 1.501, "emitted": true}, {"n": 216, "text": "あんなに食い物がある", "method": "cover", "start": 892.47, "end": 895.35, "vtt": 1001.25, "vdur": 2.836, "emitted": true}, {"n": 217, "text": "何が何でも奪ってやる", "method": "cover", "start": 899.65, "end": 902.194, "vtt": 1008.09, "vdur": 2.544, "emitted": true}, {"n": 218, "text": "もともと 全部\\Nあいつが悪いんだ", "method": "cover", "start": 902.67, "end": 905.798, "vtt": 1011.218, "vdur": 3.128, "emitted": true}, {"n": 219, "text": "俺は生きたいんだ", "method": "cover", "start": 906.41, "end": 908.328, "vtt": 1014.847, "vdur": 1.918, "emitted": true}, {"n": 220, "text": "何しに来た チビナス", "method": "cover", "start": 916.67, "end": 918.798, "vtt": 1024.606, "vdur": 2.128, "emitted": true}, {"n": 221, "text": "船でも見えたか？", "method": "cover", "start": 921.99, "end": 924.117, "vtt": 1029.778, "vdur": 2.127, "emitted": true}, {"n": 222, "text": "お前の食料を奪いに来たんだ", "method": "cover", "start": 927.19, "end": 930.151, "vtt": 1035.826, "vdur": 2.961, "emitted": true}, {"n": 223, "text": "殺せるもんなら 殺してみろよ", "method": "cover", "start": 930.49, "end": 932.58, "vtt": 1038.912, "vdur": 2.044, "emitted": true}, {"n": 224, "text": "どうせ これ以上 食えなきゃ\\N死んじまうんだから", "method": "cover", "start": 932.61, "end": 935.697, "vtt": 1041.081, "vdur": 3.087, "emitted": true}, {"n": 225, "text": "こんなに たくさん\\Nお前だけ！", "method": "cover", "start": 938.21, "end": 940.462, "vtt": 1046.587, "vdur": 2.252, "emitted": true}, {"n": 226, "text": "えっ…", "method": null, "start": null, "end": null, "vtt": 1051.675, "vdur": 1.085, "emitted": false}, {"n": 227, "text": "船が見えるまで\\N接触はなしだと言ったはずだぜ", "method": "cover", "start": 957.47, "end": 962.1, "vtt": 1068.358, "vdur": 4.63, "emitted": true}, {"n": 228, "text": "なんで…", "method": "cover", "start": 963.11, "end": 964.278, "vtt": 1074.323, "vdur": 1.168, "emitted": true}, {"n": 229, "text": "全部 宝だ", "method": "cover", "start": 966.05, "end": 967.468, "vtt": 1077.117, "vdur": 1.418, "emitted": true}, {"n": 230, "text": "金はあるのに食えねえってのも\\Nおかしな話だな", "method": "cover", "start": 968.29, "end": 973.128, "vtt": 1079.703, "vdur": 4.838, "emitted": true}, {"n": 231, "text": "おい", "method": null, "start": null, "end": null, "vtt": 1088.128, "vdur": 1.126, "emitted": false}, {"n": 232, "text": "袋いっぱい 宝だぞ", "method": "cover", "start": 975.53, "end": 978.241, "vtt": 1089.755, "vdur": 2.711, "emitted": true}, {"n": 233, "text": "何だよ これ\\Nどういうことだよ 一体", "method": "cover", "start": 984.89, "end": 987.8, "vtt": 1099.181, "vdur": 3.003, "emitted": true}, {"n": 234, "text": "食料は？ お前 今日まで\\N何も食わなかったのかよ", "method": "cover", "start": 987.83, "end": 991.772, "vtt": 1102.309, "vdur": 3.879, "emitted": true}, {"n": 235, "text": "おい 何とか言え！", "method": "cover+snap", "start": 991.802, "end": 994.054, "vtt": 1106.313, "vdur": 2.252, "emitted": true}, {"n": 236, "text": "あっ", "method": null, "start": null, "end": null, "vtt": 1108.774, "vdur": 0.834, "emitted": false}, {"n": 237, "text": "ハッ…", "method": null, "start": null, "end": null, "vtt": 1112.986, "vdur": 1.085, "emitted": false}, {"n": 238, "text": "どうしたんだよ その足", "method": "cover", "start": 1005.29, "end": 1007.334, "vtt": 1119.91, "vdur": 2.044, "emitted": true}, {"n": 239, "text": "ハッ", "method": null, "start": null, "end": null, "vtt": 1123.997, "vdur": 0.918, "emitted": false}, {"n": 240, "text": "あの時…", "method": null, "start": null, "end": null, "vtt": 1132.381, "vdur": 1.501, "emitted": false}, {"n": 241, "text": "夢じゃなかったのか\\N俺を助けるために それ…", "method": null, "start": null, "end": null, "vtt": 1137.636, "vdur": 3.712, "emitted": false}, {"n": 242, "text": "食料は俺にくれたのが\\N全部だったのか？", "method": "cover", "start": 1008.93, "end": 1012.41, "vtt": 1146.77, "vdur": 3.42, "emitted": true}, {"n": 243, "text": "そうだ", "method": "cover", "start": 1014.229, "end": 1015.23, "vtt": 1152.151, "vdur": 1.001, "emitted": true}, {"n": 244, "text": "その足 なかったら―", "method": "cover", "start": 1016.17, "end": 1017.64, "vtt": 1153.986, "vdur": 1.501, "emitted": true}, {"n": 245, "text": "お前 もう海賊\\Nやれねえじゃねえかよ", "method": "cover", "start": 1017.67, "end": 1020.25, "vtt": 1155.612, "vdur": 2.378, "emitted": true}, {"n": 246, "text": "そうだな", "method": "cover", "start": 1020.63, "end": 1022.215, "vtt": 1158.115, "vdur": 1.585, "emitted": true}, {"n": 247, "text": "なんでだよ\\N余計なことすんなよ", "method": "cover", "start": 1022.85, "end": 1026.02, "vtt": 1160.701, "vdur": 3.128, "emitted": true}, {"n": 248, "text": "俺は お前なんかに\\N優しくされる覚えはねえぞ", "method": "cover", "start": 1026.05, "end": 1029.428, "vtt": 1163.954, "vdur": 3.378, "emitted": true}, {"n": 249, "text": "なんでだよ… なんでだ！", "method": "cover", "start": 1030.97, "end": 1033.82, "vtt": 1168.917, "vdur": 2.753, "emitted": true}, {"n": 250, "text": "お前が…", "method": "cover", "start": 1033.85, "end": 1034.9, "vtt": 1171.795, "vdur": 1.794, "emitted": true}, {"n": 251, "text": "お前が 俺と同じ夢を\\N持ってたからだ", "method": "cover", "start": 1034.93, "end": 1040.45, "vtt": 1174.214, "vdur": 3.879, "emitted": true}, {"n": 252, "text": "オールブルー", "method": "cover", "start": 1042.25, "end": 1043.835, "vtt": 1179.97, "vdur": 1.585, "emitted": true}, {"n": 253, "text": "けど そんなもんないって\\Nお前の仲間も…", "method": "cover", "start": 1045.11, "end": 1048.91, "vtt": 1182.931, "vdur": 3.712, "emitted": true}, {"n": 254, "text": "あるさ", "method": "cover", "start": 1049.23, "end": 1050.74, "vtt": 1186.768, "vdur": 1.669, "emitted": true}, {"n": 255, "text": "時期が来たら\\Nグランドラインを目指せ", "method": "cover", "start": 1050.77, "end": 1053.898, "vtt": 1188.562, "vdur": 3.128, "emitted": true}, {"n": 256, "text": "オールブルーは\\Nきっと あそこにある", "method": "cover", "start": 1053.99, "end": 1057.243, "vtt": 1191.815, "vdur": 3.253, "emitted": true}, {"n": 257, "text": "俺は このとおり\\Nもう海賊は やれねえが", "method": "cover", "start": 1057.61, "end": 1061.14, "vtt": 1195.36, "vdur": 3.379, "emitted": true}, {"n": 258, "text": "今度は お前が行って\\N見つければいい", "method": "cover", "start": 1061.17, "end": 1064.215, "vtt": 1198.864, "vdur": 3.045, "emitted": true}, {"n": 259, "text": "ああ…", "method": null, "start": null, "end": null, "vtt": 1202.534, "vdur": 1.21, "emitted": false}, {"n": 260, "text": "おい ジジイ 死ぬな", "method": "cover", "start": 1066.39, "end": 1068.34, "vtt": 1203.994, "vdur": 2.002, "emitted": true}, {"n": 261, "text": "勝手なことして―", "method": "cover", "start": 1068.37, "end": 1069.705, "vtt": 1206.121, "vdur": 1.335, "emitted": true}, {"n": 262, "text": "勝手に死ぬなよ", "method": "cover", "start": 1070.31, "end": 1072.521, "vtt": 1208.123, "vdur": 2.211, "emitted": true}, {"n": 263, "text": "こ… この海を…", "method": "cover+snap", "start": 1073.743, "end": 1075.995, "vtt": 1211.543, "vdur": 2.252, "emitted": true}, {"n": 264, "text": "この海の広さを呪って\\N死んでったやつが―", "method": "cover", "start": 1077.05, "end": 1080.66, "vtt": 1214.838, "vdur": 3.337, "emitted": true}, {"n": 265, "text": "一体 どれくらい\\Nいるんだろうな", "method": "cover", "start": 1080.69, "end": 1083.443, "vtt": 1218.3, "vdur": 2.753, "emitted": true}, {"n": 266, "text": "今まで物が食えねえ―", "method": "cover", "start": 1085.05, "end": 1087.0, "vtt": 1222.846, "vdur": 1.627, "emitted": true}, {"n": 267, "text": "こういう危機は\\N何度も遭ってきたが", "method": "cover", "start": 1087.03, "end": 1089.34, "vtt": 1224.598, "vdur": 2.544, "emitted": true}, {"n": 268, "text": "そのたびに思う", "method": "cover", "start": 1089.37, "end": 1091.39, "vtt": 1227.267, "vdur": 1.752, "emitted": true}, {"n": 269, "text": "“海の ど真ん中に\\Nレストランでもあったら”ってよ", "method": "cover", "start": 1092.15, "end": 1096.253, "vtt": 1230.02, "vdur": 4.129, "emitted": true}, {"n": 270, "text": "レストラン？\\Nああ", "method": "interp1", "start": 1096.283, "end": 1098.285, "vtt": 1234.274, "vdur": 2.002, "emitted": true}, {"n": 271, "text": "ここから生きて出られたら\\N俺の最後の生きがいに―", "method": "cover", "start": 1098.41, "end": 1102.92, "vtt": 1236.401, "vdur": 4.129, "emitted": true}, {"n": 272, "text": "レストランを\\Nぶっ建てようと思ってた", "method": "cover", "start": 1102.95, "end": 1105.786, "vtt": 1240.656, "vdur": 2.836, "emitted": true}, {"n": 273, "text": "よし 俺もそれ 手伝うよ\\Nだから 死ぬな", "method": "cover", "start": 1106.41, "end": 1110.539, "vtt": 1243.867, "vdur": 4.129, "emitted": true}, {"n": 274, "text": "フン てめえみたいな\\N貧弱なチビナスには無理だ", "method": "cover", "start": 1111.11, "end": 1114.6, "vtt": 1248.247, "vdur": 4.045, "emitted": true}, {"n": 275, "text": "強くだってなるさ", "method": "cover", "start": 1114.63, "end": 1116.23, "vtt": 1252.417, "vdur": 1.544, "emitted": true}, {"n": 276, "text": "だから… 死ぬな", "method": "cover", "start": 1118.29, "end": 1121.085, "vtt": 1255.295, "vdur": 2.795, "emitted": true}, {"n": 277, "text": "ハッ… あっ！", "method": null, "start": null, "end": null, "vtt": 1261.176, "vdur": 1.502, "emitted": false}, {"n": 278, "text": "おーい！", "method": null, "start": null, "end": null, "vtt": 1273.146, "vdur": 2.169, "emitted": false}, {"n": 279, "text": "助けてくれ！", "method": "cover", "start": 1133.8, "end": 1135.886, "vtt": 1276.149, "vdur": 2.086, "emitted": true}, {"n": 280, "text": "ジジイを…", "method": null, "start": null, "end": null, "vtt": 1278.652, "vdur": 1.543, "emitted": false}, {"n": 281, "text": "クソジジイを助けてくれ！", "method": "cover", "start": 1138.93, "end": 1141.85, "vtt": 1280.32, "vdur": 2.92, "emitted": true}, {"n": 282, "text": "うう…", "method": null, "start": null, "end": null, "vtt": 1283.907, "vdur": 2.252, "emitted": false}, {"n": 283, "text": "おーい！", "method": null, "start": null, "end": null, "vtt": 1286.285, "vdur": 2.043, "emitted": false}, {"n": 284, "text": "おーい おーい！", "method": null, "start": null, "end": null, "vtt": 1289.371, "vdur": 3.67, "emitted": false}, {"n": 285, "text": "おーい おーい おーい！", "method": "cover", "start": 1152.09, "end": 1155.468, "vtt": 1293.25, "vdur": 3.378, "emitted": true}, {"n": 286, "text": "おーい…", "method": null, "start": null, "end": null, "vtt": 1296.753, "vdur": 3.045, "emitted": false}, {"n": 287, "text": "クソジジイは―", "method": "cover", "start": 1160.01, "end": 1161.887, "vtt": 1302.217, "vdur": 1.877, "emitted": true}, {"n": 288, "text": "てめえの足の代わりに\\N俺を生かしてくれた", "method": "cover", "start": 1162.59, "end": 1166.43, "vtt": 1304.803, "vdur": 3.795, "emitted": true}, {"n": 289, "text": "ああ…", "method": null, "start": null, "end": null, "vtt": 1309.016, "vdur": 1.209, "emitted": false}, {"n": 290, "text": "俺だって…", "method": "cover", "start": 1170.25, "end": 1171.96, "vtt": 1312.477, "vdur": 1.71, "emitted": true}, {"n": 291, "text": "俺だって\\N死ぬくらいのことしねえと―", "method": "cover", "start": 1172.57, "end": 1174.72, "vtt": 1314.771, "vdur": 2.294, "emitted": true}, {"n": 292, "text": "クソジジイに\\N恩返しできねえんだよ！", "method": "cover", "start": 1174.75, "end": 1177.71, "vtt": 1317.19, "vdur": 2.461, "emitted": true}, {"n": 293, "text": "なぜ立ち上がるんだよ\\Nサンジさん", "method": "cover", "start": 1183.37, "end": 1187.708, "vtt": 1325.699, "vdur": 4.338, "emitted": true}, {"n": 294, "text": "いっときでも長く\\Nここがレストランであるためさ", "method": "cover", "start": 1189.45, "end": 1193.245, "vtt": 1331.747, "vdur": 3.795, "emitted": true}, {"n": 295, "text": "あの野郎 死ぬ気かよ", "method": "cover", "start": 1195.11, "end": 1197.41, "vtt": 1337.294, "vdur": 2.169, "emitted": true}, {"n": 296, "text": "んん くくくっ ううう…", "method": "interp1", "start": 1197.542, "end": 1200.211, "vtt": 1339.755, "vdur": 2.669, "emitted": true}, {"n": 297, "text": "クソガキが", "method": "cover", "start": 1200.67, "end": 1202.88, "vtt": 1342.883, "vdur": 2.21, "emitted": true}, {"n": 298, "text": "ハッ これはまた\\Nいぶし銀なセリフだねえ", "method": "cover", "start": 1202.97, "end": 1206.682, "vtt": 1345.26, "vdur": 3.712, "emitted": true}, {"n": 299, "text": "だが もう このレストランは\\N店じまいだ", "method": "cover", "start": 1206.83, "end": 1209.666, "vtt": 1349.097, "vdur": 2.836, "emitted": true}, {"n": 300, "text": "これからは\\N海賊船に変わるのさ", "method": "cover", "start": 1210.31, "end": 1213.521, "vtt": 1352.434, "vdur": 3.211, "emitted": true}, {"n": 301, "text": "ハアッ！", "method": null, "start": null, "end": null, "vtt": 1356.021, "vdur": 1.043, "emitted": false}, {"n": 302, "text": "うん？", "method": null, "start": null, "end": null, "vtt": 1357.355, "vdur": 0.668, "emitted": false}, {"n": 303, "text": "バカ よせ！\\Nこいつらに 手出すな", "method": "cover", "start": 1216.09, "end": 1218.78, "vtt": 1358.398, "vdur": 2.419, "emitted": true}, {"n": 304, "text": "ああ…", "method": null, "start": null, "end": null, "vtt": 1360.942, "vdur": 0.876, "emitted": false}, {"n": 305, "text": "何する気だ あの野郎", "method": "cover", "start": 1219.71, "end": 1221.25, "vtt": 1361.943, "vdur": 1.418, "emitted": true}, {"n": 306, "text": "ゴムゴムのーっ！", "method": null, "start": null, "end": null, "vtt": 1365.864, "vdur": 3.337, "emitted": false}, {"n": 307, "text": "オノ！", "method": null, "start": null, "end": null, "vtt": 1369.326, "vdur": 2.544, "emitted": false}, {"n": 308, "text": "イーストブルー最強の\\N海賊団とか言ってっけど", "method": null, "start": null, "end": null, "vtt": 1450.866, "vdur": 2.419, "emitted": false}, {"n": 309, "text": "人数が多かっただけだな\\Nおっさん", "method": null, "start": null, "end": null, "vtt": 1453.535, "vdur": 1.793, "emitted": false}, {"n": 310, "text": "キッパリ言いやがるぜ", "method": null, "start": null, "end": null, "vtt": 1455.453, "vdur": 1.252, "emitted": false}, {"n": 311, "text": "ほら ギンもサンジには\\Nかなわねえみたいだぞ", "method": null, "start": null, "end": null, "vtt": 1456.955, "vdur": 2.169, "emitted": false}, {"n": 312, "text": "いや そうでもないぞ", "method": null, "start": null, "end": null, "vtt": 1459.249, "vdur": 1.627, "emitted": false}, {"n": 313, "text": "何だ？ あの\\N串ダンゴみたいな武器", "method": null, "start": null, "end": null, "vtt": 1461.001, "vdur": 2.335, "emitted": false}, {"n": 314, "text": "あいつ 下っ端じゃ\\Nなかったのか", "method": null, "start": null, "end": null, "vtt": 1463.461, "vdur": 1.544, "emitted": false}, {"n": 315, "text": "次回 ワンピース", "method": null, "start": null, "end": null, "vtt": 1465.547, "vdur": 1.043, "emitted": false}, {"n": 316, "text": "「冷徹非情の鬼人\\N海賊艦隊総隊長ギン」", "method": null, "start": null, "end": null, "vtt": 1467.048, "vdur": 4.046, "emitted": false}, {"n": 317, "text": "海賊王に 俺はなる！", "method": null, "start": null, "end": null, "vtt": 1471.219, "vdur": 2.461, "emitted": false}], "parts": [{"parent": 75, "text": "本当にあればな", "start": 309.07, "end": 310.59}]}
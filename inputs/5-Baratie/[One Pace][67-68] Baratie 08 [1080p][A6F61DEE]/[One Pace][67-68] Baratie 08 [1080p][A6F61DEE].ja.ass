Dialogue: 0,0:00:01.27,0:00:03.27,Default,,0,0,0,,富 名声 力
Dialogue: 0,0:00:03.35,0:00:07.44,Default,,0,0,0,,この世のすべてを手に入れた男\N海賊王 ゴールド･ロジャー
Dialogue: 0,0:00:07.65,0:00:11.30,Default,,0,0,0,,彼の死に際に放ったひと言は\N人々を海へ駆り立てた
Dialogue: 0,0:00:11.33,0:00:15.19,Default,,0,0,0,,俺の財宝か？\N欲しけりゃくれてやる
Dialogue: 0,0:00:15.39,0:00:18.93,Default,,0,0,0,,探せ！ この世のすべてを\Nそこに置いてきた
Dialogue: 0,0:00:21.45,0:00:24.00,Default,,0,0,0,,男たちは\Nグランドラインを目指し
Dialogue: 0,0:00:24.03,0:00:25.87,Default,,0,0,0,,夢を追い続ける
Dialogue: 0,0:00:26.13,0:00:29.55,Default,,0,0,0,,世は まさに大海賊時代！
Dialogue: 0,0:00:41.37,0:00:45.33,Default,,0,0,0,,次回 ワンピース
Dialogue: 0,0:02:04.45,0:02:06.92,Default,,0,0,0,,ああっ 帽子　俺の麦わら帽子！
Dialogue: 0,0:02:06.95,0:02:08.34,Default,,0,0,0,,あるだろう？ そこに
Dialogue: 0,0:02:08.37,0:02:09.98,Default,,0,0,0,,えっ？ ああ あった あった
Dialogue: 0,0:02:10.01,0:02:11.61,Default,,0,0,0,,目 覚めたかよ？
Dialogue: 0,0:02:12.49,0:02:14.41,Default,,0,0,0,,あれ？ あいつらは？
Dialogue: 0,0:02:14.51,0:02:16.74,Default,,0,0,0,,帰った　お前のおかげだ
Dialogue: 0,0:02:16.77,0:02:17.90,Default,,0,0,0,,俺の？
Dialogue: 0,0:02:18.07,0:02:20.02,Default,,0,0,0,,グランドラインで\Nまた会おうってよ
Dialogue: 0,0:02:20.05,0:02:21.76,Default,,0,0,0,,ギンが言ってたぜ
Dialogue: 0,0:02:22.51,0:02:24.39,Default,,0,0,0,,へええ ギンが
Dialogue: 0,0:02:24.81,0:02:25.77,Default,,0,0,0,,おめえにか？
Dialogue: 0,0:02:25.80,0:02:27.39,Default,,0,0,0,,てめえにだよ！
Dialogue: 0,0:02:30.43,0:02:33.30,Default,,0,0,0,,そういや 俺\Nあいつら追っ払ったんだから―
Dialogue: 0,0:02:33.33,0:02:35.24,Default,,0,0,0,,今日で雑用 終わりだよな？
Dialogue: 0,0:02:35.27,0:02:36.71,Default,,0,0,0,,おめでとさん
Dialogue: 0,0:02:36.91,0:02:38.16,Default,,0,0,0,,ところで お前…
Dialogue: 0,0:02:38.31,0:02:41.57,Default,,0,0,0,,俺は行かねえぞ\N海賊にはならねえ
Dialogue: 0,0:02:42.35,0:02:44.06,Default,,0,0,0,,ここでコックを続けるよ
Dialogue: 0,0:02:44.09,0:02:47.13,Default,,0,0,0,,クソジジイに\N俺の腕を認めさせるまで
Dialogue: 0,0:02:47.73,0:02:49.87,Default,,0,0,0,,分かった　諦める
Dialogue: 0,0:02:50.09,0:02:52.22,Default,,0,0,0,,手が諦めてねえ
Dialogue: 0,0:02:56.31,0:02:57.89,Default,,0,0,0,,離れられねえよ
Dialogue: 0,0:02:57.99,0:03:01.02,Default,,0,0,0,,どいつもこいつも\N頼りにならねえやつらだからな
Dialogue: 0,0:03:01.05,0:03:04.41,Default,,0,0,0,,でも 俺もいつか\N行こうと思ってるぜ
Dialogue: 0,0:03:05.01,0:03:06.37,Default,,0,0,0,,グランドラインへ
Dialogue: 0,0:03:09.39,0:03:10.98,Default,,0,0,0,,じゃあ 今 行こう
Dialogue: 0,0:03:11.01,0:03:12.97,Default,,0,0,0,,まだ時機じゃねえんだよ
Dialogue: 0,0:03:15.51,0:03:16.64,Default,,0,0,0,,お前さ
Dialogue: 0,0:03:17.85,0:03:19.97,Default,,0,0,0,,オールブルーって知ってるか？
Dialogue: 0,0:03:21.35,0:03:24.73,Default,,0,0,0,,なんだ 知らねえのかよ\N奇跡の海の話さ
Dialogue: 0,0:03:26.65,0:03:27.54,Default,,0,0,0,,その海にはよ…\Nうん
Dialogue: 0,0:03:27.57,0:03:30.96,Default,,0,0,0,,イーストブルー　ウエストブルー\Nノースブルー　サウスブルー
Dialogue: 0,0:03:30.99,0:03:34.41,Default,,0,0,0,,この４つの海にいる\N全種類の魚が住んでるんだ
Dialogue: 0,0:03:36.63,0:03:39.38,Default,,0,0,0,,俺たちコックには\N夢のような楽園だ
Dialogue: 0,0:03:39.87,0:03:42.00,Default,,0,0,0,,それが\Nグランドラインってとこだ
Dialogue: 0,0:03:47.25,0:03:50.17,Default,,0,0,0,,うれしそうな顔しやがって
Dialogue: 0,0:03:50.54,0:03:53.13,Default,,0,0,0,,ハハハッ バカが
Dialogue: 0,0:03:58.81,0:04:01.31,Default,,0,0,0,,メシだあ 野郎ども
Dialogue: 0,0:04:01.99,0:04:03.66,Default,,0,0,0,,やれやれ
Dialogue: 0,0:04:03.69,0:04:05.31,Default,,0,0,0,,やっとメシだぜ
Dialogue: 0,0:04:13.57,0:04:15.06,Default,,0,0,0,,おい 俺たちの席は？
Dialogue: 0,0:04:15.09,0:04:16.10,Default,,0,0,0,,メシは？
Dialogue: 0,0:04:16.13,0:04:18.24,Default,,0,0,0,,おめえらの椅子はねえよ
Dialogue: 0,0:04:18.27,0:04:20.44,Default,,0,0,0,,ヘヘヘッ 床で食え 床で
Dialogue: 0,0:04:20.85,0:04:23.91,Default,,0,0,0,,椅子がねえ？\Nんなことあるかよ
Dialogue: 0,0:04:24.05,0:04:26.01,Default,,0,0,0,,レストランだぜ ここは
Dialogue: 0,0:04:27.71,0:04:28.99,Default,,0,0,0,,しょうがねえな
Dialogue: 0,0:04:29.02,0:04:31.23,Default,,0,0,0,,何か変だな あいつら
Dialogue: 0,0:04:32.42,0:04:34.30,Default,,0,0,0,,ヘッ いつものことだ
Dialogue: 0,0:04:36.37,0:04:39.60,Default,,0,0,0,,おいっ けさのスープの仕込みは\N誰がやったんだ？
Dialogue: 0,0:04:40.43,0:04:44.64,Default,,0,0,0,,おおっ 俺だ俺 うめえだろ？\N今日のは特別にうまく作ったんだ
Dialogue: 0,0:04:45.17,0:04:47.29,Default,,0,0,0,,こんなクソまずいもん\N飲めねえよ
Dialogue: 0,0:04:47.90,0:04:50.41,Default,,0,0,0,,ブタの餌か？ こりゃあ\Nペッ ペッ
Dialogue: 0,0:04:51.16,0:04:52.62,Default,,0,0,0,,うっ くっ く…
Dialogue: 0,0:04:56.87,0:05:00.10,Default,,0,0,0,,おい 人間の食べ物は\Nお口に合わなかったかい？
Dialogue: 0,0:05:00.13,0:05:01.13,Default,,0,0,0,,クソダヌキ
Dialogue: 0,0:05:01.40,0:05:04.53,Default,,0,0,0,,フンッ ここまで\Nまずいと芸術だな
Dialogue: 0,0:05:04.77,0:05:06.94,Default,,0,0,0,,吐き気がするぜ\Nペッ ペッ ペッ
Dialogue: 0,0:05:08.23,0:05:13.40,Default,,0,0,0,,悪いが今日のは自信作だ\Nてめえの舌が どうにかしたか？
Dialogue: 0,0:05:18.40,0:05:20.20,Default,,0,0,0,,うええ まずっ ペーッ
Dialogue: 0,0:05:21.99,0:05:23.77,Default,,0,0,0,,飲めねえ 飲めねえ
Dialogue: 0,0:05:24.35,0:05:26.11,Default,,0,0,0,,ペッペッ なあ？ みんな
Dialogue: 0,0:05:26.44,0:05:28.73,Default,,0,0,0,,ペッ ガハッ こりゃ飲めねえ
Dialogue: 0,0:05:30.23,0:05:32.22,Default,,0,0,0,,クソまずいスープだぜ
Dialogue: 0,0:05:32.25,0:05:33.96,Default,,0,0,0,,飲めねえよ こんなスープ
Dialogue: 0,0:05:33.99,0:05:36.20,Default,,0,0,0,,最低だ 誰か水よこせ
Dialogue: 0,0:05:36.37,0:05:38.70,Default,,0,0,0,,てめえら 一体 何のマネだ
Dialogue: 0,0:05:38.77,0:05:43.37,Default,,0,0,0,,てめえなんざ所詮\Nエセ副料理長だ　ただの古株よ
Dialogue: 0,0:05:43.67,0:05:46.84,Default,,0,0,0,,もう暴力で解決されるのは\Nウンザリだぜ
Dialogue: 0,0:05:47.03,0:05:49.57,Default,,0,0,0,,まずいもんは\Nまずいと言わせてもらう
Dialogue: 0,0:05:57.61,0:05:58.61,Default,,0,0,0,,ジジイ
Dialogue: 0,0:06:01.11,0:06:04.37,Default,,0,0,0,,何だ このヘドロみてえな\Nクソまずいスープは？
Dialogue: 0,0:06:04.49,0:06:07.58,Default,,0,0,0,,こんなもん 客に出されちゃ\N店が潰れちまうぜ
Dialogue: 0,0:06:07.61,0:06:12.36,Default,,0,0,0,,ふざけんな クソジジイ\Nてめえの作ったスープとこれと―
Dialogue: 0,0:06:12.39,0:06:14.38,Default,,0,0,0,,どう違うってんだよ 言ってみろ
Dialogue: 0,0:06:14.41,0:06:16.43,Default,,0,0,0,,俺の作ったもんと？
Dialogue: 0,0:06:19.45,0:06:21.83,Default,,0,0,0,,うぬぼれんな！\Nああっ
Dialogue: 0,0:06:23.37,0:06:25.28,Default,,0,0,0,,オーナーが殴った
Dialogue: 0,0:06:25.31,0:06:26.64,Default,,0,0,0,,蹴らずに…
Dialogue: 0,0:06:26.91,0:06:31.04,Default,,0,0,0,,俺に料理を語るのは\N10億年 早えぞ チビナス
Dialogue: 0,0:06:31.17,0:06:35.34,Default,,0,0,0,,俺は世界の海で\N料理してきた男だぜ
Dialogue: 0,0:06:51.35,0:06:54.60,Default,,0,0,0,,このスープ めちゃくちゃ\Nうめえのになあ ハハッ
Dialogue: 0,0:06:54.71,0:06:56.56,Default,,0,0,0,,そんなことは分かってる\Nえっ？
Dialogue: 0,0:06:56.59,0:07:01.23,Default,,0,0,0,,サンジの料理の腕は\Nここにいる全員が認めてる
Dialogue: 0,0:07:01.86,0:07:03.26,Default,,0,0,0,,まずかねえよ
Dialogue: 0,0:07:03.29,0:07:06.15,Default,,0,0,0,,ああ 上出来だよ このスープは
Dialogue: 0,0:07:06.19,0:07:09.44,Default,,0,0,0,,ああ 怖かった\Nマジでキレんだもんな あいつ
Dialogue: 0,0:07:09.47,0:07:10.68,Default,,0,0,0,,そうそう
Dialogue: 0,0:07:16.33,0:07:21.61,Default,,0,0,0,,だがな こうでもしねえと\N聞かねえのさ あのバカは
Dialogue: 0,0:07:24.79,0:07:29.05,Default,,0,0,0,,お前 船にコックが欲しいって\N言ってたな？
Dialogue: 0,0:07:29.51,0:07:33.01,Default,,0,0,0,,頼み事ってわけでもねえんだが\Nあのチビナスを―
Dialogue: 0,0:07:33.09,0:07:35.97,Default,,0,0,0,,一緒に連れてって\Nやってくれねえか？
Dialogue: 0,0:07:36.75,0:07:38.39,Default,,0,0,0,,グランドラインに
Dialogue: 0,0:07:39.61,0:07:43.79,Default,,0,0,0,,グランドラインはよ\Nあいつの夢なんだ
Dialogue: 0,0:07:46.05,0:07:49.39,Default,,0,0,0,,…ったく オーナーも\Nめんどくさいこと やらせるなあ
Dialogue: 0,0:07:49.51,0:07:53.78,Default,,0,0,0,,おめえの下手な演技でバレねえか\N俺はヒヤヒヤだったぜ グフフッ
Dialogue: 0,0:07:53.81,0:07:56.77,Default,,0,0,0,,アハハハッ おめえこそ\Nド下手な演技で
Dialogue: 0,0:07:57.01,0:07:58.32,Default,,0,0,0,,俺 スープおかわり
Dialogue: 0,0:07:58.35,0:07:59.19,Default,,0,0,0,,俺も
Dialogue: 0,0:08:15.61,0:08:19.36,Default,,0,0,0,,丸聞こえだよ クソ野郎ども
Dialogue: 0,0:08:21.03,0:08:22.82,Default,,0,0,0,,どうなんだ？ 小僧
Dialogue: 0,0:08:23.41,0:08:24.43,Default,,0,0,0,,イヤだ
Dialogue: 0,0:08:26.11,0:08:29.87,Default,,0,0,0,,貴様 船にコックが\N欲しいんじゃなかったのか？
Dialogue: 0,0:08:30.95,0:08:34.61,Default,,0,0,0,,それとも あの野郎じゃ\N不服だってえのか？
Dialogue: 0,0:08:35.31,0:08:39.12,Default,,0,0,0,,不服じゃねえよ 俺だって\Nあいつに一緒に来てほしいけどさ
Dialogue: 0,0:08:39.15,0:08:43.65,Default,,0,0,0,,あいつは ここでコックを\N続けたいって言ってるんだ
Dialogue: 0,0:08:43.81,0:08:47.06,Default,,0,0,0,,おっさんたちに言われても\N俺は連れてけねえよ
Dialogue: 0,0:08:47.71,0:08:52.33,Default,,0,0,0,,あいつの口から直接 聞くまで\N納得できねえってわけか？
Dialogue: 0,0:08:53.05,0:08:54.36,Default,,0,0,0,,わけだ おかわり
Dialogue: 0,0:08:54.39,0:08:56.95,Default,,0,0,0,,まあ 当然の筋だな
Dialogue: 0,0:08:57.53,0:09:02.58,Default,,0,0,0,,だが あのひねくれたクソガキが\N素直に“行く”と言えるかどうか
Dialogue: 0,0:09:02.61,0:09:06.42,Default,,0,0,0,,言えるわけないっすよ\Nあいつはかたくなにアホだから
Dialogue: 0,0:09:06.45,0:09:07.63,Default,,0,0,0,,おかわり
Dialogue: 0,0:09:37.09,0:09:37.84,Default,,0,0,0,,サンジ
Dialogue: 0,0:09:37.87,0:09:40.10,Default,,0,0,0,,何だ？ こいつは　魚人か？
Dialogue: 0,0:09:40.13,0:09:42.84,Default,,0,0,0,,魚人島から はるばる\Nうちのメシを食いに？
Dialogue: 0,0:09:42.87,0:09:45.15,Default,,0,0,0,,バカッ こりゃ人間とパンサメだ
Dialogue: 0,0:09:45.27,0:09:46.48,Default,,0,0,0,,んっ 何だ？
Dialogue: 0,0:09:46.83,0:09:48.85,Default,,0,0,0,,あれっ？ ヨサクじゃねえか
Dialogue: 0,0:09:49.45,0:09:51.54,Default,,0,0,0,,ああ ルフィの兄貴
Dialogue: 0,0:09:51.57,0:09:55.41,Default,,0,0,0,,何でおめえ１人なんだ？\Nあいつらは？ ナミは？
Dialogue: 0,0:10:02.21,0:10:04.38,Default,,0,0,0,,追いついたわけじゃ\Nねえんすけどね
Dialogue: 0,0:10:04.63,0:10:09.26,Default,,0,0,0,,ナミの姉貴の船の進路で\N大体の目的地がつかめたんっす
Dialogue: 0,0:10:09.52,0:10:12.02,Default,,0,0,0,,ふーん じゃあ 連れ戻せるじゃん
Dialogue: 0,0:10:13.13,0:10:16.86,Default,,0,0,0,,それが その…\N姉貴の目的地っつうのが―
Dialogue: 0,0:10:16.89,0:10:20.81,Default,,0,0,0,,あっしらの予想どおりだとしたら\Nとんでもねえ場所で…
Dialogue: 0,0:10:22.47,0:10:25.47,Default,,0,0,0,,とにかく\Nルフィの兄貴の力が必要なんです
Dialogue: 0,0:10:25.53,0:10:26.75,Default,,0,0,0,,あっしと来てください
Dialogue: 0,0:10:27.65,0:10:31.24,Default,,0,0,0,,よし 何か分かんねえけど\N分かった 行こう
Dialogue: 0,0:10:39.40,0:10:40.95,Default,,0,0,0,,待てよ\Nんっ？
Dialogue: 0,0:10:41.53,0:10:45.08,Default,,0,0,0,,バカげた夢は お互いさまだ
Dialogue: 0,0:10:48.49,0:10:52.66,Default,,0,0,0,,俺は俺の目的\Nオールブルーのために
Dialogue: 0,0:10:53.77,0:10:54.67,Default,,0,0,0,,サンジ？
Dialogue: 0,0:10:56.27,0:11:00.52,Default,,0,0,0,,ああ 付き合おうじゃねえか\N海賊王への道とやらに
Dialogue: 0,0:11:02.55,0:11:05.42,Default,,0,0,0,,お前の船のコック\N俺が引き受ける
Dialogue: 0,0:11:05.45,0:11:08.03,Default,,0,0,0,,いいのか？ 悪いのか？
Dialogue: 0,0:11:08.63,0:11:11.06,Default,,0,0,0,,いいさ！ やったああーっ
Dialogue: 0,0:11:11.09,0:11:12.87,Default,,0,0,0,,よかったすね ルフィの兄貴
Dialogue: 0,0:11:13.81,0:11:18.03,Default,,0,0,0,,やったあ やったあ\Nコックだ メシだ ハハハハハッ
Dialogue: 0,0:11:18.15,0:11:19.93,Default,,0,0,0,,そういうわけだ みんな
Dialogue: 0,0:11:20.65,0:11:23.47,Default,,0,0,0,,いろいろ 迷惑かけたな
Dialogue: 0,0:11:23.50,0:11:25.25,Default,,0,0,0,,ケッ 気に食わねえ
Dialogue: 0,0:11:25.47,0:11:29.38,Default,,0,0,0,,てめえは俺の手で ここから\N追い出してやりたかったのに
Dialogue: 0,0:11:29.41,0:11:32.79,Default,,0,0,0,,こうも簡単に\N決断しちまうとはよ
Dialogue: 0,0:11:34.11,0:11:37.80,Default,,0,0,0,,悪かったな\N下手くそな演技までさせちまって
Dialogue: 0,0:11:37.83,0:11:39.54,Default,,0,0,0,,てめえ 知ってたのか？
Dialogue: 0,0:11:39.57,0:11:42.34,Default,,0,0,0,,筒抜けだよ\Nてめえらバカだから
Dialogue: 0,0:11:42.37,0:11:43.33,Default,,0,0,0,,何っ…
Dialogue: 0,0:11:43.77,0:11:47.15,Default,,0,0,0,,つまり そうまでして\N俺を追い出してえんだろ ああ？
Dialogue: 0,0:11:47.23,0:11:48.75,Default,,0,0,0,,クソジジイ
Dialogue: 0,0:11:49.57,0:11:53.63,Default,,0,0,0,,てめえは 何でそういう\N口の利き方しかできねえんだ
Dialogue: 0,0:11:54.63,0:11:57.51,Default,,0,0,0,,フンッ\Nそういうことだ チビナス
Dialogue: 0,0:11:58.05,0:12:01.45,Default,,0,0,0,,もともと俺はガキが嫌いなんだ
Dialogue: 0,0:12:01.61,0:12:03.52,Default,,0,0,0,,くだらねえもん\N生かしちまったと―
Dialogue: 0,0:12:03.55,0:12:06.80,Default,,0,0,0,,後悔しねえ日は\Nなかったぜ クソガキ
Dialogue: 0,0:12:07.06,0:12:10.02,Default,,0,0,0,,ハッ 上等だよ クソジジイ
Dialogue: 0,0:12:10.05,0:12:12.55,Default,,0,0,0,,せいぜい 余生 楽しめよ
Dialogue: 0,0:12:14.11,0:12:16.74,Default,,0,0,0,,ほーっ いい船っすねえ\N使っていいんすか？
Dialogue: 0,0:12:16.77,0:12:19.06,Default,,0,0,0,,サンジの船さ 当然だよ
Dialogue: 0,0:12:19.39,0:12:21.47,Default,,0,0,0,,まだ持ってくのかよ？
Dialogue: 0,0:12:21.55,0:12:23.08,Default,,0,0,0,,うん もっと肉くれ
Dialogue: 0,0:12:23.11,0:12:26.04,Default,,0,0,0,,大体 おめえら\N何日 航海するんだ？
Dialogue: 0,0:12:26.13,0:12:27.05,Default,,0,0,0,,知らねえ
Dialogue: 0,0:12:31.19,0:12:33.16,Default,,0,0,0,,すげえな
Dialogue: 0,0:12:33.19,0:12:36.49,Default,,0,0,0,,クソジジイ\Nこれが海上レストランか？
Dialogue: 0,0:12:57.89,0:13:00.18,Default,,0,0,0,,例えばだ サンジ
Dialogue: 0,0:13:00.33,0:13:02.04,Default,,0,0,0,,んっ 何だ？
Dialogue: 0,0:13:02.41,0:13:06.75,Default,,0,0,0,,どんな大悪党だろうと\N脱獄囚だろうと―
Dialogue: 0,0:13:07.17,0:13:09.09,Default,,0,0,0,,食いたくて 食いたくて―
Dialogue: 0,0:13:09.69,0:13:13.29,Default,,0,0,0,,この店にたどり着いた\Nクソ野郎がいたとしたら―
Dialogue: 0,0:13:14.53,0:13:17.90,Default,,0,0,0,,俺たちがこの店で\N闘い続ける意味は―
Dialogue: 0,0:13:17.93,0:13:20.15,Default,,0,0,0,,あるんじゃねえだろうか
Dialogue: 0,0:13:22.97,0:13:25.27,Default,,0,0,0,,これから忙しくなるぜ
Dialogue: 0,0:13:25.51,0:13:28.43,Default,,0,0,0,,大丈夫さ 俺がいるんだぜ
Dialogue: 0,0:13:35.38,0:13:37.20,Default,,0,0,0,,ああっ 痛っつう
Dialogue: 0,0:13:37.23,0:13:38.77,Default,,0,0,0,,アイタッ…
Dialogue: 0,0:13:40.27,0:13:41.37,Default,,0,0,0,,…ったく
Dialogue: 0,0:13:44.45,0:13:46.83,Default,,0,0,0,,皮が厚すぎだ チビナス
Dialogue: 0,0:13:47.16,0:13:49.24,Default,,0,0,0,,痛ってえな！
Dialogue: 0,0:13:49.33,0:13:53.54,Default,,0,0,0,,人が真剣に料理 作ってる時は\N黙って見てるもんだ
Dialogue: 0,0:13:53.99,0:13:56.66,Default,,0,0,0,,何を？ 生意気 言うな！\Nこのチビナス
Dialogue: 0,0:13:56.69,0:14:00.57,Default,,0,0,0,,俺はチビナスじゃねえ！\Nクソジジイ
Dialogue: 0,0:14:02.89,0:14:05.10,Default,,0,0,0,,ヘヘッ 食ってみてくれ
Dialogue: 0,0:14:05.21,0:14:07.41,Default,,0,0,0,,お前が１人で作ったのか？
Dialogue: 0,0:14:10.83,0:14:12.21,Default,,0,0,0,,どうだ？
Dialogue: 0,0:14:12.31,0:14:15.06,Default,,0,0,0,,…ったく\Nクソまずいぞ チビナス
Dialogue: 0,0:14:16.29,0:14:18.79,Default,,0,0,0,,このっ クソジジイ
Dialogue: 0,0:14:28.55,0:14:30.59,Default,,0,0,0,,遅いっすね コックの兄貴
Dialogue: 0,0:14:41.71,0:14:43.08,Default,,0,0,0,,積年の恨みだああ！
Dialogue: 0,0:14:43.11,0:14:44.81,Default,,0,0,0,,覚悟しろ！ サンジ
Dialogue: 0,0:14:49.27,0:14:49.94,Default,,0,0,0,,どああっ
Dialogue: 0,0:14:52.11,0:14:54.32,Default,,0,0,0,,勝てねえって おめえらじゃ
Dialogue: 0,0:15:07.10,0:15:08.10,Default,,0,0,0,,行こう
Dialogue: 0,0:15:08.39,0:15:10.71,Default,,0,0,0,,いいのか？ 挨拶
Dialogue: 0,0:15:11.29,0:15:12.26,Default,,0,0,0,,いいんだ
Dialogue: 0,0:15:12.29,0:15:13.54,Default,,0,0,0,,サンジ\Nあっ
Dialogue: 0,0:15:14.25,0:15:16.92,Default,,0,0,0,,風邪 ひくなよ
Dialogue: 0,0:15:32.23,0:15:34.27,Default,,0,0,0,,オーナー ゼフ！
Dialogue: 0,0:15:35.63,0:15:39.76,Default,,0,0,0,,長い間 クソお世話になりました
Dialogue: 0,0:15:40.27,0:15:44.32,Default,,0,0,0,,このご恩は一生 忘れません
Dialogue: 0,0:16:02.61,0:16:06.41,Default,,0,0,0,,ううっ クソッタレがああーっ
Dialogue: 0,0:16:08.53,0:16:11.34,Default,,0,0,0,,さみしいぞ チクショーッ
Dialogue: 0,0:16:11.37,0:16:13.27,Default,,0,0,0,,さみしいぞ
Dialogue: 0,0:16:28.38,0:16:29.48,Default,,0,0,0,,さみしいぞ
Dialogue: 0,0:16:29.51,0:16:31.60,Default,,0,0,0,,悲しいぞ チクショー
Dialogue: 0,0:16:38.90,0:16:40.15,Default,,0,0,0,,バカ野郎どもが
Dialogue: 0,0:16:41.67,0:16:44.92,Default,,0,0,0,,男は黙って別れるもんだぜ
Dialogue: 0,0:16:48.09,0:16:50.97,Default,,0,0,0,,いくぞーっ 出航！
Dialogue: 0,0:16:51.31,0:16:55.11,Default,,0,0,0,,また会おうぜ クソ野郎ども！
Dialogue: 0,0:17:07.11,0:17:10.94,Default,,0,0,0,,死をも恐れない\N信念さえあれば
Dialogue: 0,0:17:13.15,0:17:15.99,Default,,0,0,0,,必ず見つかるはずさ
Dialogue: 0,0:17:16.65,0:17:18.82,Default,,0,0,0,,オールブルーがな
Dialogue: 0,0:17:21.33,0:17:24.67,Default,,0,0,0,,野郎ども そろそろ客が来る
Dialogue: 0,0:17:24.81,0:17:27.52,Default,,0,0,0,,さっさと仕事をしくさらせーっ！

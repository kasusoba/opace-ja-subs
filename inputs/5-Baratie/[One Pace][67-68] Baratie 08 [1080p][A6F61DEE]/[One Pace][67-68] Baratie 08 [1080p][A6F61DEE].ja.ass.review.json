: 312, "text": "必ず見つかるはずさ", "method": "cover", "start": 1033.15, "end": 1035.986, "vtt": 1327.826, "vdur": 2.836, "emitted": true}, {"n": 313, "text": "オールブルーがな", "method": "cover", "start": 1036.65, "end": 1038.818, "vtt": 1331.455, "vdur": 2.168, "emitted": true}, {"n": 314, "text": "野郎ども そろそろ客が来る", "method": "cover", "start": 1041.33, "end": 1044.67, "vtt": 1336.126, "vdur": 3.253, "emitted": true}, {"n": 315, "text": "さっさと仕事をしくさらせーっ！", "method": "cover", "start": 1044.81, "end": 1047.521, "vtt": 1339.504, "vdur": 2.711, "emitted": true}, {"n": 316, "text": "ナミさん アーロンパークに\\N向かったらしいぞ", "method": null, "start": null, "end": null, "vtt": 1450.699, "vdur": 2.169, "emitted": false}, {"n": 317, "text": "何だ？ それ", "method": null, "start": null, "end": null, "vtt": 1452.993, "vdur": 0.75, "emitted": false}, {"n": 318, "text": "魚人の海賊が\\N支配するところだよ", "method": null, "start": null, "end": null, "vtt": 1453.869, "vdur": 2.043, "emitted": false}, {"n": 319, "text": "あいつ まさか？", "method": null, "start": null, "end": null, "vtt": 1456.037, "vdur": 1.252, "emitted": false}, {"n": 320, "text": "あの かわいさ\\N彼女は人魚だったりしてなあ", "method": null, "start": null, "end": null, "vtt": 1457.414, "vdur": 2.878, "emitted": false}, {"n": 321, "text": "カッパか", "method": null, "start": null, "end": null, "vtt": 1460.417, "vdur": 0.751, "emitted": false}, {"n": 322, "text": "ぶっ殺すぞ てめえ\\Nじゃ半魚人？", "method": null, "start": null, "end": null, "vtt": 1461.293, "vdur": 1.668, "emitted": false}, {"n": 323, "text": "お前 メシ抜き\\N何で？", "method": null, "start": null, "end": null, "vtt": 1463.086, "vdur": 1.835, "emitted": false}, {"n": 324, "text": "次回 ワンピース", "method": "cover", "start": 41.37, "end": 45.33, "vtt": 1465.589, "vdur": 1.501, "emitted": true}, {"n": 325, "text": "「東の海 最悪の男！\\N魚人海賊アーロン！」", "method": null, "start": null, "end": null, "vtt": 1467.215, "vdur": 3.462, "emitted": false}, {"n": 326, "text": "海賊王に 俺はなる！", "method": null, "start": null, "end": null, "vtt": 1470.969, "vdur": 2.419, "emitted": fals
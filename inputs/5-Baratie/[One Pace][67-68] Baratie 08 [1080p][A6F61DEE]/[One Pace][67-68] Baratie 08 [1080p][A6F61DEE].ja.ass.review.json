{"episode": "[One Pace][67-68] Baratie 08 [1080p][A6F61DEE]", "video": "[One Pace][67-68] Baratie 08 [1080p][A6F61DEE].mkv", "lines": [{"n": 0, "text": "富 名声 力", "method": "cover", "start": 1.27, "end": 3.272, "vtt": 2.21, "vdur": 2.002, "emitted": true}, {"n": 1, "text": "この世のすべてを手に入れた男\\N海賊王 ゴールド･ロジャー", "method": "cover", "start": 3.35, "end": 7.438, "vtt": 4.337, "vdur": 4.088, "emitted": true}, {"n": 2, "text": "彼の死に際に放ったひと言は\\N人々を海へ駆り立てた", "method": "cover", "start": 7.65, "end": 11.3, "vtt": 8.55, "vdur": 3.628, "emitted": true}, {"n": 3, "text": "俺の財宝か？\\N欲しけりゃくれてやる", "method": "cover", "start": 11.33, "end": 15.19, "vtt": 12.303, "vdur": 3.713, "emitted": true}, {"n": 4, "text": "探せ！ この世のすべてを\\Nそこに置いてきた", "method": "cover", "start": 15.39, "end": 18.93, "vtt": 16.141, "vdur": 3.503, "emitted": true}, {"n": 5, "text": "男たちは\\Nグランドラインを目指し", "method": "cover", "start": 21.45, "end": 24.0, "vtt": 22.313, "vdur": 2.461, "emitted": true}, {"n": 6, "text": "夢を追い続ける", "method": "cover", "start": 24.03, "end": 25.866, "vtt": 24.899, "vdur": 1.836, "emitted": true}, {"n": 7, "text": "世は まさに大海賊時代！", "method": "cover", "start": 26.13, "end": 29.55, "vtt": 26.985, "vdur": 3.42, "emitted": true}, {"n": 8, "text": "ゴムゴムの…", "method": null, "start": null, "end": null, "vtt": 111.152, "vdur": 2.795, "emitted": false}, {"n": 9, "text": "ウアーッ", "method": null, "start": null, "end": null, "vtt": 114.072, "vdur": 1.043, "emitted": false}, {"n": 10, "text": "バズーカ！", "method": null, "start": null, "end": null, "vtt": 116.324, "vdur": 2.085, "emitted": false}, {"n": 11, "text": "うあっ ヤベえ", "method": null, "start": null, "end": null, "vtt": 119.41, "vdur": 1.127, "emitted": false}, {"n": 12, "text": "だああっ！\\N手足が出ればこっちのもんだ", "method": null, "start": null, "end": null, "vtt": 120.954, "vdur": 2.627, "emitted": false}, {"n": 13, "text": "何っ？", "method": null, "start": null, "end": null, "vtt": 126.0, "vdur": 1.043, "emitted": false}, {"n": 14, "text": "今度こそ… 終わりだーっ", "method": null, "start": null, "end": null, "vtt": 127.168, "vdur": 2.294, "emitted": false}, {"n": 15, "text": "ウアアーッ", "method": null, "start": null, "end": null, "vtt": 129.754, "vdur": 1.126, "emitted": false}, {"n": 16, "text": "アアアッ…", "method": null, "start": null, "end": null, "vtt": 131.339, "vdur": 1.835, "emitted": false}, {"n": 17, "text": "腹にくくった１本の槍にゃ", "method": null, "start": null, "end": null, "vtt": 139.347, "vdur": 2.085, "emitted": false}, {"n": 18, "text": "かなわねえこともある", "method": null, "start": null, "end": null, "vtt": 141.558, "vdur": 2.002, "emitted": false}, {"n": 19, "text": "くだらねえ理由で その槍を\\Nかみ殺してるバカを―", "method": null, "start": null, "end": null, "vtt": 144.018, "vdur": 4.171, "emitted": false}, {"n": 20, "text": "俺は知ってるがね", "method": null, "start": null, "end": null, "vtt": 148.314, "vdur": 1.836, "emitted": false}, {"n": 21, "text": "ガハッ", "method": null, "start": null, "end": null, "vtt": 152.11, "vdur": 1.626, "emitted": false}, {"n": 22, "text": "オールブルー…", "method": null, "start": null, "end": null, "vtt": 158.575, "vdur": 1.459, "emitted": false}, {"n": 23, "text": "俺は 最強の男だ！", "method": null, "start": null, "end": null, "vtt": 164.789, "vdur": 2.211, "emitted": false}, {"n": 24, "text": "ドン･クリーク", "method": null, "start": null, "end": null, "vtt": 170.628, "vdur": 1.335, "emitted": false}, {"n": 25, "text": "俺たちゃ 負けました", "method": null, "start": null, "end": null, "vtt": 173.089, "vdur": 1.752, "emitted": false}, {"n": 26, "text": "総隊長！", "method": null, "start": null, "end": null, "vtt": 174.966, "vdur": 1.543, "emitted": false}, {"n": 27, "text": "世話になったな サンジさん", "method": null, "start": null, "end": null, "vtt": 178.845, "vdur": 2.669, "emitted": false}, {"n": 28, "text": "その人が目 覚ましたら\\N言っといてくれるかい？", "method": null, "start": null, "end": null, "vtt": 181.89, "vdur": 3.712, "emitted": false}, {"n": 29, "text": "もしかしたら\\N俺の命は あと数時間かも", "method": null, "start": null, "end": null, "vtt": 187.437, "vdur": 3.128, "emitted": false}, {"n": 30, "text": "時間がねえから\\N覚悟が決まるってのも―", "method": null, "start": null, "end": null, "vtt": 191.733, "vdur": 1.96, "emitted": false}, {"n": 31, "text": "マヌケな話だが…", "method": null, "start": null, "end": null, "vtt": 193.818, "vdur": 1.46, "emitted": false}, {"n": 32, "text": "今度は俺の意志で\\Nやってみようと思う", "method": null, "start": null, "end": null, "vtt": 195.403, "vdur": 2.211, "emitted": false}, {"n": 33, "text": "好きなように", "method": null, "start": null, "end": null, "vtt": 197.739, "vdur": 1.334, "emitted": false}, {"n": 34, "text": "そしたらもう\\N逃げ場はねえだろ", "method": null, "start": null, "end": null, "vtt": 199.198, "vdur": 2.42, "emitted": false}, {"n": 35, "text": "敵が怖えだの\\Nてめえが傷つかない方法だの―", "method": null, "start": null, "end": null, "vtt": 202.201, "vdur": 4.046, "emitted": false}, {"n": 36, "text": "くだらねえこと\\N考えなくて済むことを―", "method": null, "start": null, "end": null, "vtt": 206.789, "vdur": 2.378, "emitted": false}, {"n": 37, "text": "その人に教えてもらったよ", "method": null, "start": null, "end": null, "vtt": 209.292, "vdur": 2.127, "emitted": false}, {"n": 38, "text": "じゃあな", "method": null, "start": null, "end": null, "vtt": 213.004, "vdur": 0.876, "emitted": false}, {"n": 39, "text": "ありがたくもらっていくよ", "method": null, "start": null, "end": null, "vtt": 214.672, "vdur": 2.253, "emitted": false}, {"n": 40, "text": "返さなくていいんだろ？\\Nこの船", "method": null, "start": null, "end": null, "vtt": 217.05, "vdur": 2.169, "emitted": false}, {"n": 41, "text": "ああ", "method": null, "start": null, "end": null, "vtt": 219.344, "vdur": 0.959, "emitted": false}, {"n": 42, "text": "返しに来る勇気があったら\\N来てみろよ 雑魚野郎", "method": null, "start": null, "end": null, "vtt": 220.678, "vdur": 3.879, "emitted": false}, {"n": 43, "text": "おうよ", "method": null, "start": null, "end": null, "vtt": 224.682, "vdur": 1.126, "emitted": false}, {"n": 44, "text": "脳みそに ぶち込んどけ", "method": null, "start": null, "end": null, "vtt": 226.059, "vdur": 2.043, "emitted": false}, {"n": 45, "text": "ここは戦う海上レストラン\\Nバラティエだ", "method": null, "start": null, "end": null, "vtt": 228.228, "vdur": 3.086, "emitted": false}, {"n": 46, "text": "フッ おっかねえレストランだな", "method": null, "start": null, "end": null, "vtt": 232.023, "vdur": 2.92, "emitted": false}, {"n": 47, "text": "「旅立ち！\\N海のコックはルフィとともに」", "method": null, "start": null, "end": null, "vtt": 242.617, "vdur": 4.046, "emitted": false}, {"n": 48, "text": "ふんががっ…", "method": null, "start": null, "end": null, "vtt": 253.294, "vdur": 2.711, "emitted": false}, {"n": 49, "text": "ああっ 帽子　俺の麦わら帽子！", "method": "cover", "start": 124.45, "end": 126.92, "vtt": 262.428, "vdur": 2.962, "emitted": true}, {"n": 50, "text": "あるだろう？ そこに", "method": "cover", "start": 126.95, "end": 128.34, "vtt": 265.515, "vdur": 1.418, "emitted": true}, {"n": 51, "text": "えっ？ ああ あった あった", "method": "cover", "start": 128.37, "end": 129.98, "vtt": 267.058, "vdur": 1.585, "emitted": true}, {"n": 52, "text": "目 覚めたかよ？", "method": "cover", "start": 130.01, "end": 131.61, "vtt": 268.851, "vdur": 1.46, "emitted": true}, {"n": 53, "text": "あれ？ あいつらは？", "method": "cover", "start": 132.49, "end": 134.408, "vtt": 270.812, "vdur": 1.918, "emitted": true}, {"n": 54, "text": "帰った　お前のおかげだ", "method": "cover", "start": 134.51, "end": 136.74, "vtt": 273.064, "vdur": 2.294, "emitted": true}, {"n": 55, "text": "俺の？", "method": "cover", "start": 136.77, "end": 137.896, "vtt": 275.483, "vdur": 1.126, "emitted": true}, {"n": 56, "text": "グランドラインで\\Nまた会おうってよ", "method": "cover", "start": 138.07, "end": 140.02, "vtt": 276.734, "vdur": 1.669, "emitted": true}, {"n": 57, "text": "ギンが言ってたぜ", "method": "cover", "start": 140.05, "end": 141.76, "vtt": 278.736, "vdur": 1.71, "emitted": true}, {"n": 58, "text": "へええ ギンが", "method": "cover", "start": 142.51, "end": 144.387, "vtt": 281.197, "vdur": 1.877, "emitted": true}, {"n": 59, "text": "おめえにか？", "method": "cover", "start": 144.81, "end": 145.772, "vtt": 283.658, "vdur": 0.876, "emitted": true}, {"n": 60, "text": "てめえにだよ！", "method": "cover+snap", "start": 145.802, "end": 147.387, "vtt": 284.659, "vdur": 1.585, "emitted": true}, {"n": 61, "text": "そういや 俺\\Nあいつら追っ払ったんだから―", "method": "cover", "start": 150.43, "end": 153.3, "vtt": 289.33, "vdur": 2.836, "emitted": true}, {"n": 62, "text": "今日で雑用 終わりだよな？", "method": "cover", "start": 153.33, "end": 155.24, "vtt": 292.292, "vdur": 1.835, "emitted": true}, {"n": 63, "text": "おめでとさん", "method": "cover", "start": 155.27, "end": 156.71, "vtt": 294.252, "vdur": 1.043, "emitted": true}, {"n": 64, "text": "ところで お前…", "method": "cover", "start": 156.91, "end": 158.162, "vtt": 295.753, "vdur": 1.252, "emitted": true}, {"n": 65, "text": "俺は行かねえぞ\\N海賊にはならねえ", "method": "cover", "start": 158.31, "end": 161.57, "vtt": 297.213, "vdur": 3.212, "emitted": true}, {"n": 66, "text": "むう…", "method": null, "start": null, "end": null, "vtt": 300.967, "vdur": 0.751, "emitted": false}, {"n": 67, "text": "ここでコックを続けるよ", "method": "cover", "start": 162.35, "end": 164.06, "vtt": 301.843, "vdur": 1.585, "emitted": true}, {"n": 68, "text": "クソジジイに\\N俺の腕を認めさせるまで", "method": "cover", "start": 164.09, "end": 167.134, "vtt": 303.553, "vdur": 3.044, "emitted": true}, {"n": 69, "text": "分かった　諦める", "method": "cover", "start": 167.73, "end": 169.87, "vtt": 307.223, "vdur": 1.877, "emitted": true}, {"n": 70, "text": "手が諦めてねえ", "method": "cover", "start": 170.09, "end": 172.217, "vtt": 309.642, "vdur": 2.127, "emitted": true}, {"n": 71, "text": "フウ…", "method": null, "start": null, "end": null, "vtt": 313.229, "vdur": 1.21, "emitted": false}, {"n": 72, "text": "離れられねえよ", "method": "cover", "start": 176.31, "end": 177.89, "vtt": 315.857, "vdur": 1.501, "emitted": true}, {"n": 73, "text": "どいつもこいつも\\N頼りにならねえやつらだからな", "method": "cover", "start": 177.99, "end": 181.02, "vtt": 317.483, "vdur": 3.003, "emitted": true}, {"n": 74, "text": "でも 俺もいつか\\N行こうと思ってるぜ", "method": "cover", "start": 181.05, "end": 184.41, "vtt": 320.862, "vdur": 2.669, "emitted": true}, {"n": 75, "text": "グランドラインへ", "method": "cover", "start": 185.01, "end": 186.37, "vtt": 324.574, "vdur": 1.293, "emitted": true}, {"n": 76, "text": "ウハハッ", "method": null, "start": null, "end": null, "vtt": 326.034, "vdur": 0.75, "emitted": false}, {"n": 77, "text": "じゃあ 今 行こう", "method": "cover", "start": 189.39, "end": 190.975, "vtt": 328.703, "vdur": 1.585, "emitted": true}, {"n": 78, "text": "まだ時機じゃねえんだよ", "method": "cover", "start": 191.01, "end": 192.97, "vtt": 330.413, "vdur": 1.877, "emitted": true}, {"n": 79, "text": "お前さ", "method": "cover", "start": 195.51, "end": 196.636, "vtt": 335.043, "vdur": 1.126, "emitted": true}, {"n": 80, "text": "オールブルーって知ってるか？", "method": "cover", "start": 197.85, "end": 199.97, "vtt": 337.336, "vdur": 1.711, "emitted": true}, {"n": 81, "text": "いや", "method": null, "start": null, "end": null, "vtt": 339.38, "vdur": 0.751, "emitted": false}, {"n": 82, "text": "なんだ 知らねえのかよ\\N奇跡の海の話さ", "method": "cover", "start": 201.35, "end": 204.729, "vtt": 340.506, "vdur": 3.379, "emitted": true}, {"n": 83, "text": "ああ…", "method": null, "start": null, "end": null, "vtt": 344.552, "vdur": 1.001, "emitted": false}, {"n": 84, "text": "その海にはよ…\\Nうん", "method": "cover", "start": 206.65, "end": 207.54, "vtt": 346.095, "vdur": 1.21, "emitted": true}, {"n": 85, "text": "イーストブルー　ウエストブルー\\Nノースブルー　サウスブルー", "method": "cover", "start": 207.57, "end": 210.96, "vtt": 347.43, "vdur": 3.003, "emitted": true}, {"n": 86, "text": "この４つの海にいる\\N全種類の魚が住んでるんだ", "method": "cover", "start": 210.99, "end": 214.41, "vtt": 350.558, "vdur": 2.836, "emitted": true}, {"n": 87, "text": "ふーん", "method": null, "start": null, "end": null, "vtt": 354.228, "vdur": 1.21, "emitted": false}, {"n": 88, "text": "俺たちコックには\\N夢のような楽園だ", "method": "cover", "start": 216.63, "end": 219.383, "vtt": 356.022, "vdur": 2.753, "emitted": true}, {"n": 89, "text": "それが\\Nグランドラインってとこだ", "method": "cover", "start": 219.87, "end": 221.997, "vtt": 359.233, "vdur": 2.127, "emitted": true}, {"n": 90, "text": "うれしそうな顔しやがって", "method": "cover", "start": 227.25, "end": 230.17, "vtt": 366.949, "vdur": 2.795, "emitted": true}, {"n": 91, "text": "ハハハッ バカが", "method": "interp", "start": 230.54, "end": 233.126, "vtt": 370.119, "vdur": 2.586, "emitted": true}, {"n": 92, "text": "メシだあ 野郎ども", "method": "cover", "start": 238.81, "end": 241.312, "vtt": 378.503, "vdur": 2.502, "emitted": true}, {"n": 93, "text": "やれやれ", "method": "cover", "start": 241.99, "end": 243.66, "vtt": 381.464, "vdur": 1.46, "emitted": true}, {"n": 94, "text": "やっとメシだぜ", "method": "cover", "start": 243.69, "end": 245.31, "vtt": 383.049, "vdur": 1.501, "emitted": true}, {"n": 95, "text": "メシ メシ メシ", "method": null, "start": null, "end": null, "vtt": 384.675, "vdur": 1.46, "emitted": false}, {"n": 96, "text": "うーん", "method": null, "start": null, "end": null, "vtt": 389.18, "vdur": 1.71, "emitted": false}, {"n": 97, "text": "おい 俺たちの席は？", "method": "cover", "start": 253.57, "end": 255.06, "vtt": 392.35, "vdur": 2.252, "emitted": true}, {"n": 98, "text": "メシは？", "method": "cover", "start": 255.09, "end": 256.1, "vtt": 394.727, "vdur": 0.793, "emitted": true}, {"n": 99, "text": "おめえらの椅子はねえよ", "method": "cover", "start": 256.13, "end": 258.241, "vtt": 398.523, "vdur": 1.918, "emitted": true}, {"n": 100, "text": "ヘヘヘッ 床で食え 床で", "method": "cover+snap", "start": 258.271, "end": 260.44, "vtt": 400.566, "vdur": 2.169, "emitted": true}, {"n": 101, "text": "椅子がねえ？\\Nんなことあるかよ", "method": "cover", "start": 260.85, "end": 263.91, "vtt": 403.027, "vdur": 2.711, "emitted": true}, {"n": 102, "text": "レストランだぜ ここは", "method": "cover", "start": 264.05, "end": 266.01, "vtt": 406.197, "vdur": 1.919, "emitted": true}, {"n": 103, "text": "しょうがねえな", "method": "cover", "start": 267.71, "end": 268.993, "vtt": 409.742, "vdur": 1.293, "emitted": true}, {"n": 104, "text": "何か変だな あいつら", "method": "cover", "start": 269.023, "end": 271.234, "vtt": 411.16, "vdur": 2.211, "emitted": true}, {"n": 105, "text": "ヘッ いつものことだ", "method": "cover+snap", "start": 272.421, "end": 274.298, "vtt": 414.497, "vdur": 1.877, "emitted": true}, {"n": 106, "text": "おいっ けさのスープの仕込みは\\N誰がやったんだ？", "method": "cover", "start": 276.37, "end": 279.603, "vtt": 418.376, "vdur": 2.961, "emitted": true}, {"n": 107, "text": "おおっ 俺だ俺 うめえだろ？\\N今日のは特別にうまく作ったんだ", "method": "cover", "start": 280.43, "end": 284.642, "vtt": 422.13, "vdur": 4.212, "emitted": true}, {"n": 108, "text": "こんなクソまずいもん\\N飲めねえよ", "method": "cover", "start": 285.17, "end": 287.29, "vtt": 426.884, "vdur": 2.002, "emitted": true}, {"n": 109, "text": "ブタの餌か？ こりゃあ\\Nペッ ペッ", "method": "interp1", "start": 287.902, "end": 290.405, "vtt": 429.011, "vdur": 2.503, "emitted": true}, {"n": 110, "text": "うっ くっ く…", "method": "interp1", "start": 291.156, "end": 292.615, "vtt": 432.265, "vdur": 1.459, "emitted": true}, {"n": 111, "text": "おい 人間の食べ物は\\Nお口に合わなかったかい？", "method": "cover", "start": 296.87, "end": 300.1, "vtt": 437.979, "vdur": 4.045, "emitted": true}, {"n": 112, "text": "クソダヌキ", "method": "cover", "start": 300.13, "end": 301.131, "vtt": 442.15, "vdur": 1.001, "emitted": true}, {"n": 113, "text": "フンッ ここまで\\Nまずいと芸術だな", "method": "cover+snap", "start": 301.402, "end": 304.53, "vtt": 443.401, "vdur": 3.128, "emitted": true}, {"n": 114, "text": "吐き気がするぜ\\Nペッ ペッ ペッ", "method": "interp1", "start": 304.768, "end": 306.937, "vtt": 446.654, "vdur": 2.169, "emitted": true}, {"n": 115, "text": "悪いが今日のは自信作だ\\Nてめえの舌が どうにかしたか？", "method": "cover", "start": 308.23, "end": 313.402, "vtt": 450.116, "vdur": 5.172, "emitted": true}, {"n": 116, "text": "うええ まずっ ペーッ", "method": "interp1", "start": 318.403, "end": 320.197, "vtt": 460.334, "vdur": 1.794, "emitted": true}, {"n": 117, "text": "飲めねえ 飲めねえ", "method": "cover", "start": 321.99, "end": 323.77, "vtt": 463.921, "vdur": 1.71, "emitted": true}, {"n": 118, "text": "ペッペッ なあ？ みんな", "method": "interp1", "start": 324.354, "end": 326.106, "vtt": 466.424, "vdur": 1.752, "emitted": true}, {"n": 119, "text": "ペッ ガハッ こりゃ飲めねえ", "method": "interp", "start": 326.439, "end": 328.733, "vtt": 468.509, "vdur": 2.294, "emitted": true}, {"n": 120, "text": "クソまずいスープだぜ", "method": "cover", "start": 330.23, "end": 332.22, "vtt": 472.597, "vdur": 1.543, "emitted": true}, {"n": 121, "text": "飲めねえよ こんなスープ", "method": "cover", "start": 332.25, "end": 333.96, "vtt": 474.265, "vdur": 1.543, "emitted": true}, {"n": 122, "text": "最低だ 誰か水よこせ", "method": "cover", "start": 333.99, "end": 336.201, "vtt": 475.933, "vdur": 2.211, "emitted": true}, {"n": 123, "text": "てめえら 一体 何のマネだ", "method": "cover", "start": 336.37, "end": 338.7, "vtt": 478.478, "vdur": 2.085, "emitted": true}, {"n": 124, "text": "てめえなんざ所詮\\Nエセ副料理長だ　ただの古株よ", "method": "cover", "start": 338.77, "end": 343.37, "vtt": 480.897, "vdur": 4.588, "emitted": true}, {"n": 125, "text": "もう暴力で解決されるのは\\Nウンザリだぜ", "method": "cover", "start": 343.67, "end": 346.839, "vtt": 485.61, "vdur": 3.169, "emitted": true}, {"n": 126, "text": "まずいもんは\\Nまずいと言わせてもらう", "method": "cover", "start": 347.03, "end": 349.574, "vtt": 488.905, "vdur": 2.544, "emitted": true}, {"n": 127, "text": "くううっ 何だと？", "method": null, "start": null, "end": null, "vtt": 491.574, "vdur": 1.919, "emitted": false}, {"n": 128, "text": "俺たちゃ海のコックだ", "method": null, "start": null, "end": null, "vtt": 496.37, "vdur": 1.627, "emitted": false}, {"n": 129, "text": "スープのしずく１滴\\Nムダにしちゃならん", "method": null, "start": null, "end": null, "vtt": 498.706, "vdur": 2.836, "emitted": false}, {"n": 130, "text": "オーナー", "method": null, "start": null, "end": null, "vtt": 518.476, "vdur": 0.917, "emitted": false}, {"n": 131, "text": "ジジイ", "method": "cover", "start": 357.61, "end": 358.611, "vtt": 519.81, "vdur": 1.001, "emitted": true}, {"n": 132, "text": "何だ このヘドロみてえな\\Nクソまずいスープは？", "method": "cover", "start": 361.11, "end": 364.37, "vtt": 523.314, "vdur": 3.253, "emitted": true}, {"n": 133, "text": "こんなもん 客に出されちゃ\\N店が潰れちまうぜ", "method": "cover", "start": 364.49, "end": 367.58, "vtt": 526.692, "vdur": 3.546, "emitted": true}, {"n": 134, "text": "ふざけんな クソジジイ\\Nてめえの作ったスープとこれと―", "method": "cover", "start": 367.61, "end": 372.36, "vtt": 531.113, "vdur": 3.379, "emitted": true}, {"n": 135, "text": "どう違うってんだよ 言ってみろ", "method": "cover", "start": 372.39, "end": 374.38, "vtt": 534.617, "vdur": 1.919, "emitted": true}, {"n": 136, "text": "俺の作ったもんと？", "method": "cover", "start": 374.41, "end": 376.43, "vtt": 536.661, "vdur": 1.835, "emitted": true}, {"n": 137, "text": "うぬぼれんな！\\Nああっ", "method": "interp1", "start": 379.449, "end": 381.827, "vtt": 541.832, "vdur": 2.378, "emitted": true}, {"n": 138, "text": "ああっ", "method": null, "start": null, "end": null, "vtt": 544.335, "vdur": 0.918, "emitted": false}, {"n": 139, "text": "オーナーが殴った", "method": "cover", "start": 383.37, "end": 385.28, "vtt": 545.753, "vdur": 1.502, "emitted": true}, {"n": 140, "text": "蹴らずに…", "method": "cover", "start": 385.31, "end": 386.644, "vtt": 547.38, "vdur": 1.334, "emitted": true}, {"n": 141, "text": "くっ…", "method": null, "start": null, "end": null, "vtt": 548.923, "vdur": 1.376, "emitted": false}, {"n": 142, "text": "俺に料理を語るのは\\N10億年 早えぞ チビナス", "method": "cover", "start": 386.91, "end": 391.04, "vtt": 551.133, "vdur": 4.13, "emitted": true}, {"n": 143, "text": "俺は世界の海で\\N料理してきた男だぜ", "method": "cover", "start": 391.17, "end": 395.341, "vtt": 555.388, "vdur": 4.171, "emitted": true}, {"n": 144, "text": "うっ うう…", "method": null, "start": null, "end": null, "vtt": 564.605, "vdur": 1.335, "emitted": false}, {"n": 145, "text": "クソッ", "method": null, "start": null, "end": null, "vtt": 569.694, "vdur": 1.167, "emitted": false}, {"n": 146, "text": "クソジジイ 俺は 俺は…", "method": null, "start": null, "end": null, "vtt": 576.075, "vdur": 3.504, "emitted": false}, {"n": 147, "text": "俺はもう チビナスじゃねえ！", "method": null, "start": null, "end": null, "vtt": 581.33, "vdur": 3.504, "emitted": false}, {"n": 148, "text": "ああっ", "method": null, "start": null, "end": null, "vtt": 590.089, "vdur": 0.876, "emitted": false}, {"n": 149, "text": "このスープ めちゃくちゃ\\Nうめえのになあ ハハッ", "method": "cover", "start": 411.35, "end": 414.603, "vtt": 591.632, "vdur": 3.253, "emitted": true}, {"n": 150, "text": "そんなことは分かってる\\Nえっ？", "method": "cover", "start": 414.71, "end": 416.56, "vtt": 595.011, "vdur": 1.918, "emitted": true}, {"n": 151, "text": "サンジの料理の腕は\\Nここにいる全員が認めてる", "method": "cover", "start": 416.59, "end": 421.23, "vtt": 597.138, "vdur": 4.296, "emitted": true}, {"n": 152, "text": "まずかねえよ", "method": "cover", "start": 421.863, "end": 423.26, "vtt": 602.184, "vdur": 1.085, "emitted": true}, {"n": 153, "text": "ああ 上出来だよ このスープは", "method": "cover", "start": 423.29, "end": 426.15, "vtt": 603.394, "vdur": 2.544, "emitted": true}, {"n": 154, "text": "ああ 怖かった\\Nマジでキレんだもんな あいつ", "method": "cover", "start": 426.19, "end": 429.44, "vtt": 606.439, "vdur": 3.128, "emitted": true}, {"n": 155, "text": "そうそう", "method": "cover", "start": 429.47, "end": 430.679, "vtt": 609.692, "vdur": 1.209, "emitted": true}, {"n": 156, "text": "だがな こうでもしねえと\\N聞かねえのさ あのバカは", "method": "cover", "start": 436.33, "end": 441.61, "vtt": 616.741, "vdur": 4.504, "emitted": true}, {"n": 157, "text": "うんっ？", "method": null, "start": null, "end": null, "vtt": 621.37, "vdur": 0.834, "emitted": false}, {"n": 158, "text": "なあ 小僧\\Nんっ？", "method": null, "start": null, "end": null, "vtt": 624.04, "vdur": 1.334, "emitted": false}, {"n": 159, "text": "お前 船にコックが欲しいって\\N言ってたな？", "method": "cover", "start": 444.79, "end": 449.05, "vtt": 625.916, "vdur": 3.504, "emitted": true}, {"n": 160, "text": "頼み事ってわけでもねえんだが\\Nあのチビナスを―", "method": "cover", "start": 449.51, "end": 453.014, "vtt": 629.545, "vdur": 3.504, "emitted": true}, {"n": 161, "text": "一緒に連れてって\\Nやってくれねえか？", "method": "cover", "start": 453.09, "end": 455.97, "vtt": 633.382, "vdur": 2.711, "emitted": true}, {"n": 162, "text": "グランドラインに", "method": "cover", "start": 456.75, "end": 458.39, "vtt": 636.969, "vdur": 1.627, "emitted": true}, {"n": 163, "text": "んっ？", "method": null, "start": null, "end": null, "vtt": 638.721, "vdur": 0.792, "emitted": false}, {"n": 164, "text": "グランドラインはよ\\Nあいつの夢なんだ", "method": "cover", "start": 459.61, "end": 463.79, "vtt": 639.972, "vdur": 3.962, "emitted": true}, {"n": 165, "text": "…ったく オーナーも\\Nめんどくさいこと やらせるなあ", "method": "cover", "start": 466.05, "end": 469.39, "vtt": 646.187, "vdur": 3.253, "emitted": true}, {"n": 166, "text": "おめえの下手な演技でバレねえか\\N俺はヒヤヒヤだったぜ グフフッ", "method": "cover", "start": 469.51, "end": 473.777, "vtt": 649.565, "vdur": 4.296, "emitted": true}, {"n": 167, "text": "アハハハッ おめえこそ\\Nド下手な演技で", "method": "cover+snap", "start": 473.807, "end": 476.768, "vtt": 653.986, "vdur": 2.961, "emitted": true}, {"n": 168, "text": "俺 スープおかわり", "method": "cover", "start": 477.01, "end": 478.32, "vtt": 657.281, "vdur": 1.085, "emitted": true}, {"n": 169, "text": "俺も", "method": "cover", "start": 478.35, "end": 479.19, "vtt": 658.491, "vdur": 0.75, "emitted": true}, {"n": 170, "text": "俺もだ！", "method": null, "start": null, "end": null, "vtt": 659.367, "vdur": 1.126, "emitted": false}, {"n": 171, "text": "丸聞こえだよ クソ野郎ども", "method": "cover", "start": 495.61, "end": 499.364, "vtt": 675.716, "vdur": 3.754, "emitted": true}, {"n": 172, "text": "どうなんだ？ 小僧", "method": "cover", "start": 501.03, "end": 502.824, "vtt": 695.986, "vdur": 1.794, "emitted": true}, {"n": 173, "text": "イヤだ", "method": "cover", "start": 503.41, "end": 504.43, "vtt": 698.28, "vdur": 0.626, "emitted": true}, {"n": 174, "text": "何ーっ！", "method": null, "start": null, "end": null, "vtt": 699.031, "vdur": 0.834, "emitted": false}, {"n": 175, "text": "貴様 船にコックが\\N欲しいんじゃなかったのか？", "method": "cover", "start": 506.11, "end": 509.87, "vtt": 701.2, "vdur": 3.629, "emitted": true}, {"n": 176, "text": "それとも あの野郎じゃ\\N不服だってえのか？", "method": "cover", "start": 510.95, "end": 514.61, "vtt": 705.871, "vdur": 3.42, "emitted": true}, {"n": 177, "text": "不服じゃねえよ 俺だって\\Nあいつに一緒に来てほしいけどさ", "method": "cover", "start": 515.31, "end": 519.12, "vtt": 710.334, "vdur": 4.254, "emitted": true}, {"n": 178, "text": "あいつは ここでコックを\\N続けたいって言ってるんだ", "method": "cover", "start": 519.15, "end": 523.65, "vtt": 715.214, "vdur": 3.212, "emitted": true}, {"n": 179, "text": "おっさんたちに言われても\\N俺は連れてけねえよ", "method": "cover", "start": 523.81, "end": 527.063, "vtt": 718.551, "vdur": 3.253, "emitted": true}, {"n": 180, "text": "あいつの口から直接 聞くまで\\N納得できねえってわけか？", "method": "cover", "start": 527.71, "end": 532.33, "vtt": 722.638, "vdur": 4.588, "emitted": true}, {"n": 181, "text": "わけだ おかわり", "method": "cover", "start": 533.05, "end": 534.36, "vtt": 727.852, "vdur": 1.209, "emitted": true}, {"n": 182, "text": "まあ 当然の筋だな", "method": "cover", "start": 534.39, "end": 536.95, "vtt": 729.311, "vdur": 2.503, "emitted": true}, {"n": 183, "text": "だが あのひねくれたクソガキが\\N素直に“行く”と言えるかどうか", "method": "cover", "start": 537.53, "end": 542.58, "vtt": 732.356, "vdur": 5.13, "emitted": true}, {"n": 184, "text": "言えるわけないっすよ\\Nあいつはかたくなにアホだから", "method": "cover", "start": 542.61, "end": 546.42, "vtt": 737.611, "vdur": 3.754, "emitted": true}, {"n": 185, "text": "おかわり", "method": "cover", "start": 546.45, "end": 547.63, "vtt": 741.49, "vdur": 1.126, "emitted": true}, {"n": 186, "text": "ダバ ダバババ…", "method": null, "start": null, "end": null, "vtt": 748.747, "vdur": 3.17, "emitted": false}, {"n": 187, "text": "あっ？", "method": null, "start": null, "end": null, "vtt": 756.005, "vdur": 0.709, "emitted": false}, {"n": 188, "text": "ふああーっ", "method": null, "start": null, "end": null, "vtt": 757.006, "vdur": 2.085, "emitted": false}, {"n": 189, "text": "うああーっ！", "method": null, "start": null, "end": null, "vtt": 759.216, "vdur": 2.294, "emitted": false}, {"n": 190, "text": "クソッ", "method": null, "start": null, "end": null, "vtt": 775.524, "vdur": 0.709, "emitted": false}, {"n": 191, "text": "サンジ", "method": "cover", "start": 577.09, "end": 577.84, "vtt": 776.358, "vdur": 0.793, "emitted": true}, {"n": 192, "text": "何だ？ こいつは　魚人か？", "method": "cover", "start": 577.87, "end": 580.1, "vtt": 777.276, "vdur": 1.71, "emitted": true}, {"n": 193, "text": "魚人島から はるばる\\Nうちのメシを食いに？", "method": "cover", "start": 580.13, "end": 582.84, "vtt": 779.111, "vdur": 2.628, "emitted": true}, {"n": 194, "text": "バカッ こりゃ人間とパンサメだ", "method": "cover", "start": 582.87, "end": 585.15, "vtt": 781.864, "vdur": 2.085, "emitted": true}, {"n": 195, "text": "んっ 何だ？", "method": "cover+snap", "start": 585.271, "end": 586.481, "vtt": 784.241, "vdur": 1.21, "emitted": true}, {"n": 196, "text": "あれっ？ ヨサクじゃねえか", "method": "cover", "start": 586.83, "end": 588.85, "vtt": 785.784, "vdur": 1.627, "emitted": true}, {"n": 197, "text": "ああ ルフィの兄貴", "method": "cover", "start": 589.45, "end": 591.54, "vtt": 787.995, "vdur": 2.377, "emitted": true}, {"n": 198, "text": "何でおめえ１人なんだ？\\Nあいつらは？ ナミは？", "method": "cover", "start": 591.57, "end": 595.407, "vtt": 790.498, "vdur": 3.837, "emitted": true}, {"n": 199, "text": "追いついたわけじゃ\\Nねえんすけどね", "method": "cover", "start": 602.21, "end": 604.378, "vtt": 801.217, "vdur": 2.168, "emitted": true}, {"n": 200, "text": "ナミの姉貴の船の進路で\\N大体の目的地がつかめたんっす", "method": "cover", "start": 604.63, "end": 609.259, "vtt": 803.511, "vdur": 4.629, "emitted": true}, {"n": 201, "text": "ふーん じゃあ 連れ戻せるじゃん", "method": "cover+snap", "start": 609.517, "end": 612.019, "vtt": 808.307, "vdur": 2.502, "emitted": true}, {"n": 202, "text": "それが その…\\N姉貴の目的地っつうのが―", "method": "cover", "start": 613.13, "end": 616.86, "vtt": 811.852, "vdur": 4.296, "emitted": true}, {"n": 203, "text": "あっしらの予想どおりだとしたら\\Nとんでもねえ場所で…", "method": "cover", "start": 616.89, "end": 620.81, "vtt": 816.273, "vdur": 3.462, "emitted": true}, {"n": 204, "text": "うん？", "method": null, "start": null, "end": null, "vtt": 820.236, "vdur": 0.875, "emitted": false}, {"n": 205, "text": "とにかく\\Nルフィの兄貴の力が必要なんです", "method": "cover", "start": 622.47, "end": 625.47, "vtt": 821.57, "vdur": 2.753, "emitted": true}, {"n": 206, "text": "あっしと来てください", "method": "cover", "start": 625.53, "end": 626.75, "vtt": 824.448, "vdur": 1.085, "emitted": true}, {"n": 207, "text": "よし 何か分かんねえけど\\N分かった 行こう", "method": "cover", "start": 627.65, "end": 631.237, "vtt": 826.033, "vdur": 3.587, "emitted": true}, {"n": 208, "text": "待てよ\\Nんっ？", "method": "interp1", "start": 639.403, "end": 640.946, "vtt": 838.337, "vdur": 1.543, "emitted": true}, {"n": 209, "text": "バカげた夢は お互いさまだ", "method": "cover", "start": 641.53, "end": 645.075, "vtt": 840.464, "vdur": 3.545, "emitted": true}, {"n": 210, "text": "うん？", "method": null, "start": null, "end": null, "vtt": 844.76, "vdur": 0.918, "emitted": false}, {"n": 211, "text": "俺は俺の目的\\Nオールブルーのために", "method": "cover", "start": 648.49, "end": 652.661, "vtt": 847.471, "vdur": 4.171, "emitted": true}, {"n": 212, "text": "サンジ？", "method": "cover", "start": 653.77, "end": 654.67, "vtt": 852.768, "vdur": 0.876, "emitted": true}, {"n": 213, "text": "ああ 付き合おうじゃねえか\\N海賊王への道とやらに", "method": "cover", "start": 656.27, "end": 660.524, "vtt": 854.895, "vdur": 4.254, "emitted": true}, {"n": 214, "text": "えっ？", "method": null, "start": null, "end": null, "vtt": 859.4, "vdur": 1.168, "emitted": false}, {"n": 215, "text": "お前の船のコック\\N俺が引き受ける", "method": "cover", "start": 662.55, "end": 665.42, "vtt": 861.569, "vdur": 3.003, "emitted": true}, {"n": 216, "text": "ええっ？\\Nおっ", "method": null, "start": null, "end": null, "vtt": 865.114, "vdur": 1.334, "emitted": false}, {"n": 217, "text": "いいのか？ 悪いのか？", "method": "cover", "start": 665.45, "end": 668.03, "vtt": 869.869, "vdur": 1.584, "emitted": true}, {"n": 218, "text": "いいさ！ やったああーっ", "method": "cover", "start": 668.63, "end": 671.06, "vtt": 872.246, "vdur": 2.544, "emitted": true}, {"n": 219, "text": "よかったすね ルフィの兄貴", "method": "cover", "start": 671.09, "end": 672.87, "vtt": 874.915, "vdur": 1.669, "emitted": true}, {"n": 220, "text": "ああ！", "method": null, "start": null, "end": null, "vtt": 876.709, "vdur": 0.834, "emitted": false}, {"n": 221, "text": "やったあ やったあ\\Nコックだ メシだ ハハハハハッ", "method": "interp1", "start": 673.812, "end": 678.025, "vtt": 877.668, "vdur": 4.213, "emitted": true}, {"n": 222, "text": "そういうわけだ みんな", "method": "cover", "start": 678.15, "end": 679.93, "vtt": 882.006, "vdur": 1.376, "emitted": true}, {"n": 223, "text": "いろいろ 迷惑かけたな", "method": "cover", "start": 680.65, "end": 683.468, "vtt": 884.842, "vdur": 2.461, "emitted": true}, {"n": 224, "text": "ケッ 気に食わねえ", "method": "cover+snap", "start": 683.498, "end": 685.25, "vtt": 887.553, "vdur": 1.752, "emitted": true}, {"n": 225, "text": "てめえは俺の手で ここから\\N追い出してやりたかったのに", "method": "cover", "start": 685.47, "end": 689.38, "vtt": 889.43, "vdur": 3.879, "emitted": true}, {"n": 226, "text": "こうも簡単に\\N決断しちまうとはよ", "method": "cover", "start": 689.41, "end": 692.79, "vtt": 893.434, "vdur": 3.128, "emitted": true}, {"n": 227, "text": "悪かったな\\N下手くそな演技までさせちまって", "method": "cover", "start": 694.11, "end": 697.8, "vtt": 897.771, "vdur": 3.754, "emitted": true}, {"n": 228, "text": "てめえ 知ってたのか？", "method": "cover", "start": 697.83, "end": 699.54, "vtt": 901.734, "vdur": 1.668, "emitted": true}, {"n": 229, "text": "筒抜けだよ\\Nてめえらバカだから", "method": "cover", "start": 699.57, "end": 702.34, "vtt": 903.527, "vdur": 2.586, "emitted": true}, {"n": 230, "text": "何っ…", "method": "cover", "start": 702.37, "end": 703.329, "vtt": 906.238, "vdur": 0.959, "emitted": true}, {"n": 231, "text": "つまり そうまでして\\N俺を追い出してえんだろ ああ？", "method": "cover", "start": 703.77, "end": 707.149, "vtt": 907.781, "vdur": 3.379, "emitted": true}, {"n": 232, "text": "クソジジイ", "method": "cover", "start": 707.23, "end": 708.75, "vtt": 911.493, "vdur": 1.293, "emitted": true}, {"n": 233, "text": "てめえは 何でそういう\\N口の利き方しかできねえんだ", "method": "cover", "start": 709.57, "end": 713.63, "vtt": 913.537, "vdur": 3.587, "emitted": true}, {"n": 234, "text": "コラッ んっ？", "method": null, "start": null, "end": null, "vtt": 917.249, "vdur": 1.335, "emitted": false}, {"n": 235, "text": "フンッ\\Nそういうことだ チビナス", "method": "interp1", "start": 714.63, "end": 717.508, "vtt": 919.585, "vdur": 2.878, "emitted": true}, {"n": 236, "text": "もともと俺はガキが嫌いなんだ", "method": "cover", "start": 718.05, "end": 721.45, "vtt": 923.005, "vdur": 2.461, "emitted": true}, {"n": 237, "text": "くだらねえもん\\N生かしちまったと―", "method": "cover", "start": 721.61, "end": 723.52, "vtt": 925.591, "vdur": 1.626, "emitted": true}, {"n": 238, "text": "後悔しねえ日は\\Nなかったぜ クソガキ", "method": "cover", "start": 723.55, "end": 726.803, "vtt": 927.343, "vdur": 3.253, "emitted": true}, {"n": 239, "text": "ハッ 上等だよ クソジジイ", "method": "cover+snap", "start": 727.062, "end": 730.02, "vtt": 930.971, "vdur": 2.962, "emitted": true}, {"n": 240, "text": "せいぜい 余生 楽しめよ", "method": "cover", "start": 730.05, "end": 732.552, "vtt": 934.058, "vdur": 2.502, "emitted": true}, {"n": 241, "text": "ほーっ いい船っすねえ\\N使っていいんすか？", "method": "cover", "start": 734.11, "end": 736.74, "vtt": 943.609, "vdur": 3.211, "emitted": true}, {"n": 242, "text": "サンジの船さ 当然だよ", "method": "cover", "start": 736.77, "end": 739.063, "vtt": 946.946, "vdur": 2.293, "emitted": true}, {"n": 243, "text": "まだ持ってくのかよ？", "method": "cover", "start": 739.39, "end": 741.475, "vtt": 949.782, "vdur": 2.085, "emitted": true}, {"n": 244, "text": "うん もっと肉くれ", "method": "cover", "start": 741.55, "end": 743.08, "vtt": 951.992, "vdur": 1.502, "emitted": true}, {"n": 245, "text": "大体 おめえら\\N何日 航海するんだ？", "method": "cover", "start": 743.11, "end": 746.043, "vtt": 953.619, "vdur": 2.878, "emitted": true}, {"n": 246, "text": "知らねえ", "method": "cover", "start": 746.13, "end": 747.047, "vtt": 956.622, "vdur": 0.917, "emitted": true}, {"n": 247, "text": "小僧\\Nんっ？", "method": null, "start": null, "end": null, "vtt": 958.791, "vdur": 1.168, "emitted": false}, {"n": 248, "text": "おっさん\\N持っていくか？", "method": null, "start": null, "end": null, "vtt": 960.084, "vdur": 2.21, "emitted": false}, {"n": 249, "text": "俺がグランドラインに入った\\N１年間の記録だ", "method": null, "start": null, "end": null, "vtt": 962.419, "vdur": 4.296, "emitted": false}, {"n": 250, "text": "いらねえ", "method": null, "start": null, "end": null, "vtt": 967.549, "vdur": 1.252, "emitted": false}, {"n": 251, "text": "ハハハッ やはりな", "method": null, "start": null, "end": null, "vtt": 969.134, "vdur": 1.71, "emitted": false}, {"n": 252, "text": "シヒヒヒヒッ", "method": null, "start": null, "end": null, "vtt": 971.303, "vdur": 1.46, "emitted": false}, {"n": 253, "text": "そっちの霜降り肉も欲しい", "method": null, "start": null, "end": null, "vtt": 974.974, "vdur": 2.21, "emitted": false}, {"n": 254, "text": "いいかげんに しとけーっ！", "method": null, "start": null, "end": null, "vtt": 977.309, "vdur": 1.46, "emitted": false}, {"n": 255, "text": "すげえな", "method": "cover", "start": 751.19, "end": 753.16, "vtt": 986.694, "vdur": 2.085, "emitted": true}, {"n": 256, "text": "クソジジイ\\Nこれが海上レストランか？", "method": "cover", "start": 753.19, "end": 756.485, "vtt": 988.904, "vdur": 3.295, "emitted": true}, {"n": 257, "text": "例えばだ サンジ", "method": "cover", "start": 777.89, "end": 780.184, "vtt": 1013.262, "vdur": 2.294, "emitted": true}, {"n": 258, "text": "んっ 何だ？", "method": "cover", "start": 780.33, "end": 782.04, "vtt": 1015.973, "vdur": 1.71, "emitted": true}, {"n": 259, "text": "どんな大悪党だろうと\\N脱獄囚だろうと―", "method": "cover", "start": 782.41, "end": 786.748, "vtt": 1018.225, "vdur": 4.338, "emitted": true}, {"n": 260, "text": "食いたくて 食いたくて―", "method": "cover", "start": 787.17, "end": 789.09, "vtt": 1022.98, "vdur": 1.877, "emitted": true}, {"n": 261, "text": "この店にたどり着いた\\Nクソ野郎がいたとしたら―", "method": "cover", "start": 789.69, "end": 793.29, "vtt": 1025.399, "vdur": 3.587, "emitted": true}, {"n": 262, "text": "俺たちがこの店で\\N闘い続ける意味は―", "method": "cover", "start": 794.53, "end": 797.9, "vtt": 1030.237, "vdur": 3.295, "emitted": true}, {"n": 263, "text": "あるんじゃねえだろうか", "method": "cover", "start": 797.93, "end": 800.15, "vtt": 1033.949, "vdur": 1.96, "emitted": true}, {"n": 264, "text": "ああ", "method": null, "start": null, "end": null, "vtt": 1036.577, "vdur": 0.917, "emitted": false}, {"n": 265, "text": "これから忙しくなるぜ", "method": "cover", "start": 802.97, "end": 805.27, "vtt": 1038.746, "vdur": 2.168, "emitted": true}, {"n": 266, "text": "大丈夫さ 俺がいるんだぜ", "method": "cover", "start": 805.51, "end": 808.429, "vtt": 1041.04, "vdur": 2.919, "emitted": true}, {"n": 267, "text": "あっ…", "method": null, "start": null, "end": null, "vtt": 1046.795, "vdur": 0.668, "emitted": false}, {"n": 268, "text": "ああっ 痛っつう", "method": "rescue+snap", "start": 815.375, "end": 817.195, "vtt": 1051.633, "vdur": 1.836, "emitted": true}, {"n": 269, "text": "アイタッ…", "method": "interp1", "start": 817.225, "end": 818.768, "vtt": 1053.844, "vdur": 1.543, "emitted": true}, {"n": 270, "text": "…ったく", "method": "cover", "start": 820.27, "end": 821.37, "vtt": 1056.889, "vdur": 0.959, "emitted": true}, {"n": 271, "text": "皮が厚すぎだ チビナス", "method": "cover", "start": 824.45, "end": 826.83, "vtt": 1060.142, "vdur": 1.71, "emitted": true}, {"n": 272, "text": "痛ってえな！", "method": "cover+snap", "start": 827.157, "end": 829.242, "vtt": 1062.895, "vdur": 2.085, "emitted": true}, {"n": 273, "text": "人が真剣に料理 作ってる時は\\N黙って見てるもんだ", "method": "cover", "start": 829.33, "end": 833.543, "vtt": 1065.105, "vdur": 4.213, "emitted": true}, {"n": 274, "text": "何を？ 生意気 言うな！\\Nこのチビナス", "method": "cover", "start": 833.99, "end": 836.66, "vtt": 1069.443, "vdur": 2.753, "emitted": true}, {"n": 275, "text": "俺はチビナスじゃねえ！\\Nクソジジイ", "method": "cover", "start": 836.69, "end": 840.569, "vtt": 1072.321, "vdur": 3.879, "emitted": true}, {"n": 276, "text": "ヘヘッ 食ってみてくれ", "method": "cover", "start": 842.89, "end": 845.1, "vtt": 1078.494, "vdur": 2.21, "emitted": true}, {"n": 277, "text": "お前が１人で作ったのか？", "method": "cover", "start": 845.21, "end": 847.41, "vtt": 1080.996, "vdur": 1.794, "emitted": true}, {"n": 278, "text": "ああ", "method": null, "start": null, "end": null, "vtt": 1083.499, "vdur": 0.875, "emitted": false}, {"n": 279, "text": "どうだ？", "method": "cover", "start": 850.83, "end": 852.206, "vtt": 1086.46, "vdur": 1.376, "emitted": true}, {"n": 280, "text": "…ったく\\Nクソまずいぞ チビナス", "method": "cover", "start": 852.31, "end": 855.063, "vtt": 1087.961, "vdur": 2.753, "emitted": true}, {"n": 281, "text": "このっ クソジジイ", "method": "cover", "start": 856.29, "end": 858.793, "vtt": 1091.548, "vdur": 2.503, "emitted": true}, {"n": 282, "text": "遅いっすね コックの兄貴", "method": "cover", "start": 868.55, "end": 870.594, "vtt": 1103.977, "vdur": 2.044, "emitted": true}, {"n": 283, "text": "うん", "method": null, "start": null, "end": null, "vtt": 1106.146, "vdur": 1.001, "emitted": false}, {"n": 284, "text": "積年の恨みだああ！", "method": "cover", "start": 881.71, "end": 883.08, "vtt": 1123.497, "vdur": 1.209, "emitted": true}, {"n": 285, "text": "覚悟しろ！ サンジ", "method": "cover", "start": 883.11, "end": 884.81, "vtt": 1124.832, "vdur": 1.459, "emitted": true}, {"n": 286, "text": "どああっ", "method": "interp", "start": 889.274, "end": 889.941, "vtt": 1130.754, "vdur": 0.667, "emitted": true}, {"n": 287, "text": "うわああっ", "method": null, "start": null, "end": null, "vtt": 1131.588, "vdur": 0.793, "emitted": false}, {"n": 288, "text": "勝てねえって おめえらじゃ", "method": "cover", "start": 892.11, "end": 894.321, "vtt": 1133.59, "vdur": 2.211, "emitted": true}, {"n": 289, "text": "行こう", "method": "interp1", "start": 907.097, "end": 908.098, "vtt": 1154.736, "vdur": 1.001, "emitted": true}, {"n": 290, "text": "いいのか？ 挨拶", "method": "cover", "start": 908.39, "end": 910.71, "vtt": 1156.029, "vdur": 1.752, "emitted": true}, {"n": 291, "text": "いいんだ", "method": "cover", "start": 911.29, "end": 912.26, "vtt": 1158.323, "vdur": 1.043, "emitted": true}, {"n": 292, "text": "サンジ\\Nあっ", "method": "interp1", "start": 912.29, "end": 913.541, "vtt": 1159.491, "vdur": 1.251, "emitted": true}, {"n": 293, "text": "風邪 ひくなよ", "method": "cover", "start": 914.25, "end": 916.92, "vtt": 1161.451, "vdur": 2.67, "emitted": true}, {"n": 294, "text": "ううっ…", "method": null, "start": null, "end": null, "vtt": 1164.538, "vdur": 0.959, "emitted": false}, {"n": 295, "text": "オーナー ゼフ！", "method": "cover", "start": 932.23, "end": 934.274, "vtt": 1222.095, "vdur": 2.044, "emitted": true}, {"n": 296, "text": "長い間 クソお世話になりました", "method": "cover", "start": 935.63, "end": 939.759, "vtt": 1225.682, "vdur": 4.129, "emitted": true}, {"n": 297, "text":